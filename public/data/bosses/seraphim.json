{
  "id": "seraphim",
  "name": "The Seraphim",
  "enabled": true,
  "hpMult": 1.8,
  "color": "#ffd700",
  "attackChance": 0.08,
  "description": "A celestial mechanical deity that controls orbital rings.",
  "visualType": "seraphim",
  "replaceSprite": false,
  "logic": {
    "drawHp": [
      "const hpR = boss.radius * 2.2;",
      "// Circular Halo Gauge",
      "ctx.save();",
      "ctx.translate(boss.x, boss.y);",
      "ctx.beginPath();",
      "ctx.arc(0, 0, hpR, 0, Math.PI * 2);",
      "ctx.strokeStyle = 'rgba(255, 215, 0, 0.2)';",
      "ctx.lineWidth = 4;",
      "ctx.stroke();",
      "",
      "ctx.beginPath();",
      "ctx.arc(0, 0, hpR, -Math.PI / 2, -Math.PI / 2 + (Math.PI * 2 * pct));",
      "ctx.strokeStyle = '#ffd700';",
      "ctx.lineWidth = 6;",
      "ctx.lineCap = 'round';",
      "ctx.stroke();",
      "ctx.restore();",
      "",
      "// Pct Text",
      "if (pct < 1) {",
      "    ctx.fillStyle = '#fff';",
      "    ctx.font = 'bold 12px monospace';",
      "    ctx.textAlign = 'center';",
      "    ctx.fillText(Math.floor(pct * 100) + '%', 0, hpR + 15);",
      "}"
    ],
    "entrance": {
      "duration": 4500,
      "init": ["boss.rotAngle = 0;"],
      "update": ["boss.rotAngle = boss.timer * (0.01 + progress * 0.05);"],
      "draw": [
        "const p = progress;",
        "const maxR = Math.min(canvas.width, canvas.height) * 0.55;",
        "ctx.save();",
        "ctx.translate(boss.x, boss.y);",
        "",
        "// Ring 1 (Cyan)",
        "const dist1 = (1 - Math.pow(p, 4)) * maxR;",
        "if (dist1 > 0) {",
        "    ctx.rotate(boss.timer * 0.01);",
        "    ctx.strokeStyle = '#00ffff';",
        "    ctx.lineWidth = 4;",
        "    ctx.beginPath();",
        "    for(let i=0; i<4; i++) ctx.arc(0, 0, dist1 + 50, (Math.PI/2)*i, (Math.PI/2)*i + 0.5);",
        "    ctx.stroke();",
        "}",
        "// Core",
        "if (p > 0.5) {",
        "    const coreSize = 10 * ((p-0.5)*2);",
        "    ctx.fillStyle = '#fff';",
        "    if (Math.floor(boss.timer / 50) % 2 === 0) {",
        "        ctx.beginPath(); ctx.arc(0, 0, coreSize, 0, Math.PI*2); ctx.fill();",
        "    }",
        "}",
        "ctx.restore();"
      ]
    },
    "death": {
      "duration": 4000,
      "draw": [
        "const maxR = Math.max(canvas.width, canvas.height);",
        "ctx.save();",
        "ctx.translate(boss.x, boss.y);",
        "ctx.shadowBlur = 0;",
        "// Ring Ejection",
        "if (progress > 0.1) {",
        "    const p1 = (progress - 0.1) / 0.9;",
        "    const r1 = boss.radius + (1 - Math.pow(1 - p1, 3)) * maxR;",
        "    if (r1 < maxR * 1.2) {",
        "        ctx.rotate(boss.timer * 0.05);",
        "        ctx.strokeStyle = '#00ffff';",
        "        ctx.lineWidth = Math.max(1, 15 * (1 - p1));",
        "        ctx.beginPath(); ctx.arc(0, 0, r1, 0, Math.PI * 0.4); ctx.stroke();",
        "        ctx.beginPath(); ctx.arc(0, 0, r1, Math.PI, Math.PI * 1.4); ctx.stroke();",
        "    }",
        "}",
        "// Flash",
        "if (progress > 0.9) {",
        "    ctx.setTransform(1, 0, 0, 1, 0, 0);",
        "    ctx.fillStyle = '#fff';",
        "    ctx.globalAlpha = (progress - 0.9) / 0.1;",
        "    ctx.fillRect(0, 0, canvas.width, canvas.height);",
        "}",
        "ctx.restore();"
      ]
    },
    "update": [
      "boss.rotAngle += 0.08;",
      "// Attack: Divine Beam",
      "if (Math.random() < 0.01) {",
      "    projectiles.push({ x: boss.x, y: boss.y, dx: 0, dy: 12, radius: 20, color: '#ffd700', damage: 50, style: 'orb' });",
      "}",
      "// Attack: Geometry Prison",
      "if (Math.random() < 0.04) {",
      "    const side = Math.random() > 0.5 ? 0 : 800; // Simplified width",
      "    projectiles.push({",
      "        x: side, y: Math.random() * 600,",
      "        dx: (side === 0 ? 10 : -10), dy: 0,",
      "        radius: 4, color: '#fff', style: 'bolt', damage: 20",
      "    });",
      "}"
    ],
    "draw": [
      "// Dynamic Inner Rings (White & Gold)",
      "const r = boss.radius * 1.5;",
      "// Rotate opposite to satellites (Counter-Clockwise first)",
      "const ringAngle = -(boss.rotAngle || 0);",
      "",
      "ctx.save();",
      "ctx.lineWidth = 2;",
      "ctx.translate(boss.x, boss.y);",
      "",
      "// White Ring",
      "ctx.strokeStyle = '#fff';",
      "ctx.beginPath();",
      "// Original static was Math.PI/4. We add the dynamic angle.",
      "ctx.ellipse(0, 0, r*0.8, r*0.2, Math.PI/4 + ringAngle, 0, Math.PI*2);",
      "ctx.stroke();",
      "",
      "// Gold Ring",
      "ctx.strokeStyle = '#ffd700';",
      "ctx.beginPath();",
      "// Original static was -Math.PI/4.",
      "ctx.ellipse(0, 0, r*0.8, r*0.2, -Math.PI/4 + ringAngle, 0, Math.PI*2);",
      "ctx.stroke();",
      "",
      "ctx.restore();",
      "",
      "ctx.save();",
      "ctx.translate(boss.x, boss.y);",
      "",
      "// 3 Satellites",
      "for(let i=0; i<3; i++) {",
      "    const offset = (Math.PI * 2 / 3) * i;",
      "    const currentAngle = (boss.rotAngle || 0) + offset;",
      "    const orbitDist = boss.radius * 1.5;",
      "",
      "    const sx = Math.cos(currentAngle) * orbitDist;",
      "    const sy = Math.sin(currentAngle) * orbitDist;",
      "",
      "    // Draw Satellite (Optimized: No ShadowBlur)",
      "    // Fake Glow (Larger, transparent circle)",
      "    ctx.fillStyle = 'rgba(255,255,255,0.2)';",
      "    ctx.beginPath();",
      "    ctx.arc(sx, sy, 12, 0, Math.PI*2);",
      "    ctx.fill();",
      "",
      "    // Core (Solid white)",
      "    ctx.fillStyle = '#fff';",
      "    // ShadowBlur removed for performance",
      "    ctx.beginPath();",
      "    ctx.arc(sx, sy, 6, 0, Math.PI*2);",
      "    ctx.fill();",
      "",
      "    // Satellite Trail",
      "    ctx.strokeStyle = 'rgba(255,255,255,0.3)';",
      "    ctx.lineWidth = 2;",
      "    ctx.beginPath();",
      "    ctx.arc(0, 0, orbitDist, currentAngle - 0.5, currentAngle);",
      "    ctx.stroke();",
      "}",
      "// Main body core removed to allow Sprite underneath",
      "// ctx.fillStyle = boss.color;",
      "// ctx.beginPath;",
      "// ctx.arc(0, 0, boss.radius, 0, Math.PI*2);",
      "// ctx.fill();",
      "ctx.restore();"
    ]
  }
}