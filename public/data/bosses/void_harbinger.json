{
  "id": "void_harbinger",
  "name": "Void Harbinger",
  "enabled": true,
  "hpMult": 2.0,
  "color": "#9900ff",
  "attackChance": 0.1,
  "description": "An entity from the null dimension wielding gravity.",
  "visualType": "void_harbinger",
  "replaceSprite": true,
  "logic": {
    "drawHp": [
      "const hpR = boss.radius * 2.2;",
      "// Void Gauge (Purple)",
      "ctx.save();",
      "ctx.translate(boss.x, boss.y);",
      "",
      "// Background Ring",
      "ctx.beginPath();",
      "ctx.arc(0, 0, hpR, 0, Math.PI * 2);",
      "ctx.strokeStyle = 'rgba(100, 0, 255, 0.2)';",
      "ctx.lineWidth = 4;",
      "ctx.stroke();",
      "",
      "// Progress Arc",
      "ctx.beginPath();",
      "ctx.arc(0, 0, hpR, -Math.PI / 2, -Math.PI / 2 + (Math.PI * 2 * pct));",
      "ctx.strokeStyle = '#9900ff';",
      "ctx.lineWidth = 6;",
      "ctx.lineCap = 'round';",
      "ctx.shadowColor = '#9900ff';",
      "ctx.shadowBlur = 10;",
      "ctx.stroke();",
      "",
      "// Text",
      "if (pct < 1) {",
      "    ctx.fillStyle = '#fff';",
      "    ctx.font = 'bold 12px monospace';",
      "    ctx.textAlign = 'center';",
      "    ctx.fillText(Math.floor(pct * 100) + '%', 0, hpR + 15);",
      "}",
      "ctx.restore();"
    ],
    "entrance": {
      "duration": 5000,
      "init": ["boss.scale = 0; boss.alpha = 0; boss.spin = 0;"],
      "update": [
        "boss.spin += 0.05;",
        "// Simple lerp for scale and alpha",
        "boss.scale = progress;",
        "boss.alpha = progress;"
      ],
      "draw": [
        "const p = progress;",
        "ctx.save();",
        "ctx.translate(boss.x, boss.y);",
        "",
        "// 1. Portal Effect (Swirling)",
        "if (p < 0.8) {",
        "    const portalSize = boss.radius * 3 * (1-p) + 50;",
        "    ctx.rotate(boss.timer * 0.01);",
        "    ctx.strokeStyle = `rgba(140, 0, 255, ${1-p})`;",
        "    ctx.lineWidth = 3;",
        "    ctx.beginPath();",
        "    for(let i=0; i<3; i++) {",
        "        ctx.arc(0, 0, portalSize - (i*10), i, i + Math.PI);",
        "    }",
        "    ctx.stroke();",
        "}",
        "",
        "// 2. The Crystal Materializing",
        "if (boss.scale > 0.01) {",
        "    ctx.scale(boss.scale, boss.scale);",
        "    ctx.globalAlpha = boss.alpha;",
        "",
        "    // Draw Main Body (Dark Crystal geometry match)",
        "    const size = boss.radius * 2.0;",
        "    ctx.fillStyle = '#000';",
        "    ctx.beginPath();",
        "    ctx.moveTo(0, -size);",
        "    ctx.lineTo(size*0.6, 0);",
        "    ctx.lineTo(0, size);",
        "    ctx.lineTo(-size*0.6, 0);",
        "    ctx.closePath();",
        "    ctx.fill();",
        "",
        "    // Inner Gradient",
        "    const grad = ctx.createRadialGradient(0, 0, size*0.1, 0, 0, size);",
        "    grad.addColorStop(0, '#4b0082');",
        "    grad.addColorStop(1, 'transparent');",
        "    ctx.fillStyle = grad;",
        "    ctx.fill();",
        "",
        "    // Glowing Edges",
        "    ctx.strokeStyle = '#b24dff';",
        "    ctx.lineWidth = 4;",
        "    ctx.lineJoin = 'round';",
        "    ctx.stroke();",
        "",
        "    // Core",
        "    ctx.fillStyle = '#fff';",
        "    ctx.shadowBlur = 20;",
        "    ctx.shadowColor = '#fff';",
        "    ctx.beginPath();",
        "    ctx.arc(0, 0, size * 0.15, 0, Math.PI * 2);",
        "    ctx.fill();",
        "}",
        "ctx.restore();"
      ]
    },
    "death": {
      "duration": 4000,
      "draw": [
        "const maxR = Math.max(canvas.width, canvas.height);",
        "ctx.save();",
        "ctx.translate(boss.x, boss.y);",
        "ctx.shadowBlur = 0;",
        "",
        "// 0. Draw Fading Body (So it doesn't vanish instantly)",
        "if (progress < 0.4) {",
        "    ctx.scale(1 - progress*2, 1 - progress*2); // Shrink",
        "    // Body Geometry",
        "    const size = boss.radius * 2.0;",
        "    ctx.fillStyle = '#000';",
        "    ctx.beginPath();",
        "    ctx.moveTo(0, -size);",
        "    ctx.lineTo(size*0.6, 0);",
        "    ctx.lineTo(0, size);",
        "    ctx.lineTo(-size*0.6, 0);",
        "    ctx.closePath();",
        "    ctx.fill();",
        "    // Edges",
        "    ctx.strokeStyle = '#b24dff';",
        "    ctx.lineWidth = 4;",
        "    ctx.stroke();",
        "}",
        "",
        "// Implosion Effect",
        "if (progress > 0.1) {",
        "    ctx.setTransform(1,0,0,1, boss.x, boss.y); // Reset scale for explosion",
        "    const p1 = (progress - 0.1) / 0.9;",
        "    const r1 = boss.radius + (1 - Math.pow(1 - p1, 3)) * maxR;",
        "    ",
        "    // Expanding Purple Ring",
        "    ctx.strokeStyle = '#9900ff';",
        "    ctx.lineWidth = Math.max(1, 15 * (1 - p1));",
        "    ctx.beginPath();",
        "    ctx.arc(0, 0, r1, 0, Math.PI * 2);",
        "    ctx.stroke();",
        "}",
        "",
        "// Whiteout Flash",
        "if (progress > 0.9) {",
        "    ctx.setTransform(1, 0, 0, 1, 0, 0);",
        "    ctx.fillStyle = '#fff';",
        "    ctx.globalAlpha = (progress - 0.9) / 0.1;",
        "    ctx.fillRect(0, 0, canvas.width, canvas.height);",
        "}",
        "ctx.restore();"
      ]
    },
    "update": [
      "boss.rotAngle = (boss.rotAngle || 0) + 0.02;",
      "boss.y += Math.sin(boss.timer * 0.002) * 0.5;",
      "",
      "// Attack 1: Void Energy Balls",
      "if (Math.random() < 0.03) {",
      "    const angle = Math.atan2(player.y - boss.y, player.x - boss.x);",
      "    projectiles.push({",
      "        x: boss.x, y: boss.y,",
      "        dx: Math.cos(angle) * 6, dy: Math.sin(angle) * 6,",
      "        radius: 12, color: '#9900ff',",
      "        damage: 25, style: 'orb', isTracking: true",
      "    });",
      "}",
      "",
      "// Attack 2: Gravity Well (Slow Zone)",
      "if (Math.random() < 0.01) {",
      "    projectiles.push({",
      "        x: player.x, y: player.y,",
      "        dx: 0, dy: 0,",
      "        radius: 60, color: 'rgba(100,0,255,0.3)',",
      "        damage: 1, type: 'slow', life: 3000",
      "    });",
      "}"
    ],
    "draw": [
      "// Idle State Draw",
      "ctx.save();",
      "// Explicitly reset Alpha to ensure visibility",
      "ctx.globalAlpha = 1;",
      "ctx.translate(boss.x, boss.y);",
      "",
      "// Float Animation",
      "ctx.rotate(Math.sin(boss.timer * 0.001) * 0.1);",
      "",
      "const size = boss.radius * 2.0; // Increased size for better visibility",
      "",
      "// 1. Core Black Crystal Body",
      "ctx.fillStyle = '#000'; // Pure black base for contrast",
      "ctx.beginPath();",
      "ctx.moveTo(0, -size);",
      "ctx.lineTo(size*0.6, 0);",
      "ctx.lineTo(0, size);",
      "ctx.lineTo(-size*0.6, 0);",
      "ctx.closePath();",
      "ctx.fill();",
      "",
      "// 2. Inner Purple Gradient (Void Energy)",
      "const grad = ctx.createRadialGradient(0, 0, size*0.1, 0, 0, size);",
      "grad.addColorStop(0, '#4b0082');",
      "grad.addColorStop(0.6, 'rgba(26, 11, 46, 0.8)');",
      "grad.addColorStop(1, 'transparent');",
      "ctx.fillStyle = grad;",
      "ctx.fill();",
      "",
      "// 3. Neon Edges (Bright Purple)",
      "ctx.strokeStyle = '#b24dff';",
      "ctx.lineWidth = 4;",
      "ctx.lineJoin = 'round';",
      "ctx.stroke();",
      "",
      "// 4. Central Pulsing Core",
      "const pulse = 1 + Math.sin(boss.timer * 0.005) * 0.2;",
      "ctx.shadowBlur = 20 * pulse;",
      "ctx.shadowColor = '#fff';",
      "ctx.fillStyle = '#fff';",
      "ctx.beginPath();",
      "ctx.arc(0, 0, size * 0.15 * pulse, 0, Math.PI * 2);",
      "ctx.fill();",
      "",
      "// 5. Outer Orbiting Particles",
      "ctx.rotate(boss.timer * 0.002);",
      "for(let i=0; i<4; i++) {",
      "   ctx.rotate(Math.PI/2);",
      "   ctx.fillStyle = '#9900ff';",
      "   ctx.beginPath();",
      "   ctx.arc(size*0.8, 0, 4, 0, Math.PI*2);",
      "   ctx.fill();",
      "}",
      "",
      "ctx.restore();"
    ]
  }
}
