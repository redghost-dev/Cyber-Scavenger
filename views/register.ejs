    <script>
        // Custom Dynamic Terms Rendering
        function renderDynamicTerms() {
            const container = document.getElementById('dynamicTermsContent');
            if (!container) return;
            
            container.innerHTML = '';
            let i = 1;
            
            // Wait for translations if not yet loaded
            const currentLang = Loc.currentLang;
            const dict = Loc.translations[currentLang] || {};
            
            while (dict[`auth.terms.h${i}`]) {
                const header = document.createElement('h3');
                header.setAttribute('data-i18n', `auth.terms.h${i}`);
                header.innerText = dict[`auth.terms.h${i}`];
                
                const paragraph = document.createElement('p');
                paragraph.setAttribute('data-i18n', `auth.terms.p${i}`);
                paragraph.innerText = dict[`auth.terms.p${i}`] || '';
                
                container.appendChild(header);
                container.appendChild(paragraph);
                i++;
            }
        }

        // Override applyTranslations to also handle our dynamic terms
        const originalApplyTranslations = Loc.applyTranslations.bind(Loc);
        Loc.applyTranslations = function() {
            renderDynamicTerms();
            originalApplyTranslations();
        };

        // Slider CAPTCHA System
        const canvas = document.getElementById('captchaCanvas');
        const pieceCanvas = document.getElementById('captchaPiece');
        const ctx = canvas.getContext('2d');
        const pieceCtx = pieceCanvas.getContext('2d');
        const sliderButton = document.getElementById('sliderButton');
        const sliderProgress = document.getElementById('sliderProgress');
        const captchaStatus = document.getElementById('captchaStatus');
        
        let captchaData = {
            targetX: 0,
            pieceSize: 50,
            isDragging: false,
            startTime: 0,
            movements: 0,
            startX: 0,
            success: false
        };
        
        function generateCaptcha() {
            // Reset
            captchaData.success = false;
            captchaData.movements = 0;
            captchaData.startTime = Date.now();
            captchaStatus.textContent = '';
            captchaStatus.className = 'captcha-status';
            sliderButton.style.left = '0px';
            sliderProgress.style.width = '0px';
            
            // Set canvas dimensions
            canvas.width = 300;
            canvas.height = 150;
            
            // Random target position (avoid edges)
            captchaData.targetX = 50 + Math.random() * (canvas.width - captchaData.pieceSize - 100);
            
            // Draw background with cyber grid
            ctx.fillStyle = 'rgba(0, 10, 20, 0.9)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Grid pattern
            ctx.strokeStyle = 'rgba(0, 251, 255, 0.1)';
            ctx.lineWidth = 1;
            for(let i = 0; i < canvas.width; i += 20) {
                ctx.beginPath();
                ctx.moveTo(i, 0);
                ctx.lineTo(i, canvas.height);
                ctx.stroke();
            }
            for(let i = 0; i < canvas.height; i += 20) {
                ctx.beginPath();
                ctx.moveTo(0, i);
                ctx.lineTo(canvas.width, i);
                ctx.stroke();
            }
            
            // Draw target slot with glow
            const slotY = (canvas.height - captchaData.pieceSize) / 2;
            ctx.strokeStyle = '#00fbff';
            ctx.lineWidth = 2;
            ctx.shadowColor = '#00fbff';
            ctx.shadowBlur = 15;
            ctx.strokeRect(captchaData.targetX, slotY, captchaData.pieceSize, captchaData.pieceSize);
            ctx.shadowBlur = 0;
            
            // Draw puzzle piece on separate canvas
            const canvasRect = canvas.getBoundingClientRect();
            pieceCanvas.width = captchaData.pieceSize + 10;
            pieceCanvas.height = captchaData.pieceSize + 10;
            pieceCanvas.style.position = 'absolute';
            pieceCanvas.style.top = slotY + 'px';
            pieceCanvas.style.left = '5px';
            pieceCanvas.style.zIndex = '10';
            
            // Draw piece with cyber style
            const gradient = pieceCtx.createLinearGradient(0, 0, captchaData.pieceSize, captchaData.pieceSize);
            gradient.addColorStop(0, '#00fbff');
            gradient.addColorStop(1, '#ff0055');
            
            pieceCtx.fillStyle = gradient;
            pieceCtx.strokeStyle = '#fff';
            pieceCtx.lineWidth = 2;
            pieceCtx.shadowColor = '#00fbff';
            pieceCtx.shadowBlur = 10;
            
            // Simple square piece with notch
            pieceCtx.beginPath();
            pieceCtx.moveTo(5, 5);
            pieceCtx.lineTo(captchaData.pieceSize, 5);
            pieceCtx.lineTo(captchaData.pieceSize, captchaData.pieceSize);
            pieceCtx.lineTo(5, captchaData.pieceSize);
            pieceCtx.closePath();
            pieceCtx.fill();
            pieceCtx.stroke();
            
            // Store answer
            document.getElementById('captchaAnswer').value = Math.round(captchaData.targetX);
        }
        
        // Slider drag handlers with better Chrome compatibility
        function startDrag(e) {
            if (e.type === 'mousedown' && e.button !== 0) return; // Only left click
            e.preventDefault();
            e.stopPropagation();
            
            captchaData.isDragging = true;
            captchaData.startTime = Date.now();
            captchaData.movements = 0;
            
            const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
            const buttonRect = sliderButton.getBoundingClientRect();
            captchaData.startX = clientX - buttonRect.left;
            
            sliderButton.style.cursor = 'grabbing';
            document.body.style.userSelect = 'none';
        }
        
        function drag(e) {
            if (!captchaData.isDragging) return;
            
            captchaData.movements++;
            
            const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
            const sliderTrack = document.querySelector('.slider-track');
            const maxMove = sliderTrack.offsetWidth - sliderButton.offsetWidth;
            
            let newX = clientX - sliderTrack.getBoundingClientRect().left - captchaData.startX;
            newX = Math.max(0, Math.min(newX, maxMove));
            
            sliderButton.style.left = newX + 'px';
            sliderProgress.style.width = newX + 'px';
            
            // Move piece - scale to canvas width
            const canvasScale = canvas.width / sliderTrack.offsetWidth;
            const pieceX = newX * canvasScale;
            pieceCanvas.style.left = (5 + pieceX) + 'px';
        }
        
        function endDrag(e) {
            if (!captchaData.isDragging) return;
            captchaData.isDragging = false;
            sliderButton.style.cursor = 'grab';
            document.body.style.userSelect = '';
            
            const timeElapsed = (Date.now() - captchaData.startTime) / 1000;
            const sliderX = parseInt(sliderButton.style.left) || 0;
            const sliderTrack = document.querySelector('.slider-track');
            const canvasScale = canvas.width / sliderTrack.offsetWidth;
            const actualX = Math.round(sliderX * canvasScale);
            const tolerance = 20;
            
            // Store actual canvas position, timing and movement data
            document.getElementById('captcha').value = actualX;
            document.getElementById('captchaTiming').value = timeElapsed.toFixed(2);
            document.getElementById('captchaMovements').value = captchaData.movements;
            
            // Check if position matches
            if (Math.abs(actualX - captchaData.targetX) <= tolerance) {
                // Success checks
                if (timeElapsed < 0.2) {
                    captchaStatus.textContent = Loc.t('auth.captcha.too_fast');
                    captchaStatus.className = 'captcha-status error';
                    setTimeout(generateCaptcha, 2000);
                    return;
                }
                
                if (captchaData.movements < 2) {
                    captchaStatus.textContent = Loc.t('auth.captcha.only_slide');
                    captchaStatus.className = 'captcha-status error';
                    setTimeout(generateCaptcha, 2000);
                    return;
                }
                
                // Success!
                captchaData.success = true;
                captchaStatus.textContent = Loc.t('auth.captcha.success');
                captchaStatus.className = 'captcha-status success';
                sliderButton.style.background = 'linear-gradient(135deg, #00ff88, #00fbff)';
                sliderProgress.style.background = 'linear-gradient(90deg, #00ff88, #00fbff)';
                checkFormValidity();
            } else {
                const diff = Math.abs(actualX - captchaData.targetX);
                if (diff < 30) {
                    captchaStatus.textContent = Loc.t('auth.captcha.almost');
                } else {
                    captchaStatus.textContent = Loc.t('auth.captcha.inside_box');
                }
                captchaStatus.className = 'captcha-status error';
                setTimeout(generateCaptcha, 2000);
            }
        }
        
        // Event listeners with better cross-browser support
        sliderButton.addEventListener('mousedown', startDrag, false);
        sliderButton.addEventListener('touchstart', startDrag, { passive: false });
        
        // Document-level move and end events
        document.addEventListener('mousemove', drag, false);
        document.addEventListener('mouseup', endDrag, false);
        document.addEventListener('touchmove', drag, { passive: false });
        document.addEventListener('touchend', endDrag, false);
        
        // Prevent context menu on slider button
        sliderButton.addEventListener('contextmenu', (e) => e.preventDefault());
        
        document.getElementById('refreshCaptcha').addEventListener('click', generateCaptcha);
        
        // Terms Modal
        const termsModal = document.getElementById('termsModal');
        const openTermsBtn = document.getElementById('openTermsModal');
        const closeTermsBtn = document.getElementById('closeTermsModal');
        const acceptTermsBtn = document.getElementById('acceptTermsBtn');
        
        openTermsBtn.addEventListener('click', (e) => {
            e.preventDefault();
            termsModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        });
        
        closeTermsBtn.addEventListener('click', () => {
            termsModal.style.display = 'none';
            document.body.style.overflow = '';
        });
        
        acceptTermsBtn.addEventListener('click', () => {
            agreeTerms.checked = true;
            termsModal.style.display = 'none';
            document.body.style.overflow = '';
            checkTerms();
        });
        
        // Close on outside click
        termsModal.addEventListener('click', (e) => {
            if (e.target === termsModal) {
                termsModal.style.display = 'none';
                document.body.style.overflow = '';
            }
        });
        
        // Generate initial captcha
        generateCaptcha();
        
        // Password Strength Checker
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');
        const strengthFill = document.getElementById('strengthFill');
        const strengthLevel = document.getElementById('strengthLevel');
        const passwordMatchHint = document.getElementById('passwordMatchHint');
        const submitBtn = document.getElementById('submitBtn');
        const agreeTerms = document.getElementById('agreeTerms');
        const captchaInput = document.getElementById('captcha');
        
        let passwordStrength = 0;
        let passwordsMatch = false;
        let captchaValid = false;
        let termsAccepted = false;
        
        function checkPasswordStrength(pass) {
            let strength = 0;
            
            if(pass.length >= 6) strength += 1;
            if(pass.length >= 10) strength += 1;
            if(/[a-z]/.test(pass)) strength += 1;
            if(/[A-Z]/.test(pass)) strength += 1;
            if(/[0-9]/.test(pass)) strength += 1;
            if(/[^a-zA-Z0-9]/.test(pass)) strength += 1;
            
            return strength;
        }
        
        function updatePasswordStrength() {
            const pass = password.value;
            passwordStrength = checkPasswordStrength(pass);
            
            const widthPercent = (passwordStrength / 6) * 100;
            strengthFill.style.width = widthPercent + '%';
            
            let levelText = Loc.t('auth.strength.unknown');
            let colorClass = 'weak';
            
            if(passwordStrength === 0) {
                levelText = Loc.t('auth.strength.unknown');
                colorClass = 'weak';
            } else if(passwordStrength <= 2) {
                levelText = Loc.t('auth.strength.weak');
                colorClass = 'weak';
            } else if(passwordStrength <= 4) {
                levelText = Loc.t('auth.strength.medium');
                colorClass = 'medium';
            } else if(passwordStrength === 5) {
                levelText = Loc.t('auth.strength.strong');
                colorClass = 'strong';
            } else {
                levelText = Loc.t('auth.strength.legendary');
                colorClass = 'legendary';
            }
            
            strengthLevel.textContent = levelText;
            strengthFill.className = 'strength-fill ' + colorClass;
            
            checkFormValidity();
        }
        
        function checkPasswordMatch() {
            const pass = password.value;
            const confirmPass = confirmPassword.value;
            
            if(confirmPass.length === 0) {
                passwordMatchHint.textContent = '';
                passwordMatchHint.className = 'password-match-hint';
                passwordsMatch = false;
            } else if(pass === confirmPass) {
                passwordMatchHint.textContent = Loc.t('auth.password.match');
                passwordMatchHint.className = 'password-match-hint match';
                passwordsMatch = true;
            } else {
                passwordMatchHint.textContent = Loc.t('auth.password.no_match');
                passwordMatchHint.className = 'password-match-hint no-match';
                passwordsMatch = false;
            }
            
            checkFormValidity();
        }
        
        function checkTerms() {
            termsAccepted = agreeTerms.checked;
            checkFormValidity();
        }
        
        function checkFormValidity() {
            // En az orta seviye şifre, şifrelerin eşleşmesi, captcha ve sözleşme onayı gerekli
            if(passwordStrength >= 3 && passwordsMatch && captchaData.success && termsAccepted) {
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
            } else {
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.5';
            }
        }
        
        password.addEventListener('input', updatePasswordStrength);
        password.addEventListener('input', checkPasswordMatch);
        confirmPassword.addEventListener('input', checkPasswordMatch);
        agreeTerms.addEventListener('change', checkTerms);
        
        // Form submission validation
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            if(passwordStrength < 3) {
                e.preventDefault();
                alert(Loc.t('auth.alert.weak_pass'));
                return false;
            }
            if(!passwordsMatch) {
                e.preventDefault();
                alert(Loc.t('auth.alert.no_match'));
                return false;
            }
            if(!captchaData.success) {
                e.preventDefault();
                alert(Loc.t('auth.alert.captcha'));
                return false;
            }
            if(!termsAccepted) {
                e.preventDefault();
                alert(Loc.t('auth.alert.terms'));
                return false;
            }
        });
    </script>
</body>
</html>