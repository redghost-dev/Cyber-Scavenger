<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#050510">
  <title>Leaderboard - Cyber Scavenger</title>

  <style>
    html, body { background-color: #050510 !important; margin: 0; padding: 0; }
    #cyber-intro {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background-color: #050510;
      z-index: 99999;
      display: flex; flex-direction: column; justify-content: center; align-items: center;
    }
  </style>

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/intro.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="/css/all.min.css">
  <style>
    body {
      overflow-y: auto !important;
      height: auto !important;
      padding-top: 20px;
      background-color: transparent !important;
      color: #fff;
      font-family: 'Courier New', monospace;
    }
    .container {
      position: relative;
      z-index: 10;
      max-width: 1000px;
      margin: 0 auto;
      padding: 20px;
      padding-top: 140px; /* Space for fixed header */
      padding-bottom: 100px;
    }

    /* Cyber Header Styles */
    .cyber-header {
      position: fixed;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: 95%;
      max-width: 1000px;
      z-index: 1000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 30px;
      margin-bottom: 40px;
      background: rgba(5, 10, 20, 0.9);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(0, 251, 255, 0.2);
      border-top: none;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8), 
                  0 0 20px rgba(0, 251, 255, 0.1) inset;
      clip-path: polygon(0 0, 100% 0, 100% 85%, 98% 100%, 2% 100%, 0 85%);
      transition: all 0.3s ease;
    }
    .cyber-header::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%);
        width: 40%;
        height: 2px;
        background: var(--cyber-blue);
        box-shadow: 0 0 10px var(--cyber-blue), 0 0 20px var(--cyber-blue);
        opacity: 0.8;
        z-index: 1001;
    }
    .header-left {
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .header-title h1 {
        margin: 0;
        font-size: 2.5rem;
        color: #fff;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        font-weight: 900;
        letter-spacing: 2px;
        line-height: 1;
        font-style: italic;
    }
    .header-title h1 span {
        color: var(--cyber-blue);
        text-shadow: 0 0 15px var(--cyber-blue);
    }
    .header-title p {
        margin: 5px 0 0 0;
        color: var(--cyber-blue);
        font-size: 0.8rem;
        opacity: 0.8;
        letter-spacing: 4px;
        text-transform: uppercase;
    }
    .back-btn-mini {
      color: var(--cyber-blue);
      text-decoration: none;
      border: 1px solid rgba(0, 251, 255, 0.3);
      padding: 8px 15px;
      border-radius: 2px;
      transition: all 0.3s;
      background: rgba(0, 50, 100, 0.2);
      font-weight: bold;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .back-btn-mini:hover {
      background: var(--cyber-blue);
      color: #000;
      box-shadow: 0 0 15px var(--cyber-blue);
    }
    
    /* Mobile Responsive Header */
    @media (max-width: 768px) {
        .container {
            padding-top: 240px;
        }
        .cyber-header {
            flex-direction: column;
            gap: 15px;
            padding: 15px;
            clip-path: polygon(0 0, 100% 0, 100% 95%, 95% 100%, 5% 100%, 0 95%);
        }
        .header-left {
            width: 100%;
            justify-content: space-between;
            flex-direction: row;
        }
        .header-title h1 {
            font-size: 1.8rem;
        }
        .header-title p {
            font-size: 0.6rem;
            letter-spacing: 2px;
        }
    }

    .leaderboard-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
      min-width: 300px;
    }
    .table-responsive {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    
    .leaderboard-table th {
      padding: 15px;
      text-align: left;
      background: rgba(0, 10, 30, 0.8);
      color: var(--cyber-blue);
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 2px;
      border-bottom: 2px solid var(--cyber-blue);
      text-shadow: 0 0 5px var(--cyber-blue);
    }
    
    .leaderboard-table td {
      padding: 15px;
      background: rgba(5, 10, 20, 0.8);
      border-top: 1px solid rgba(0, 251, 255, 0.1);
      border-bottom: 1px solid rgba(0, 251, 255, 0.1);
      color: #ddd;
      transition: all 0.3s;
    }
    
    .leaderboard-table tr td:first-child {
        border-left: 1px solid rgba(0, 251, 255, 0.1);
        border-top-left-radius: 6px;
        border-bottom-left-radius: 6px;
    }
    .leaderboard-table tr td:last-child {
        border-right: 1px solid rgba(0, 251, 255, 0.1);
        border-top-right-radius: 6px;
        border-bottom-right-radius: 6px;
    }

    .leaderboard-table tr:hover td {
      background: rgba(0, 251, 255, 0.1);
      border-color: rgba(0, 251, 255, 0.4);
      color: #fff;
      box-shadow: inset 0 0 15px rgba(0, 251, 255, 0.05);
    }

    @media (max-width: 600px) {
      .container {
        padding: 10px;
        padding-top: 240px; /* Ensure header space on mobile */
      }
      .leaderboard-table th, .leaderboard-table td {
        padding: 10px 5px;
        font-size: 0.9rem;
      }
      .player-info {
        gap: 8px;
      }
      .player-avatar {
        width: 30px;
        height: 30px;
      }
      .league-badge {
        font-size: 0.7em;
        padding: 1px 5px;
      }
    }
    .rank {
      font-weight: bold;
      font-size: 1.2em;
      width: 60px;
      text-align: center;
    }
    .rank-1 { color: #ffd700; text-shadow: 0 0 10px #ffd700; }
    .rank-2 { color: #c0c0c0; text-shadow: 0 0 10px #c0c0c0; }
    .rank-3 { color: #cd7f32; text-shadow: 0 0 10px #cd7f32; }
    
    .player-info {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .player-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 2px solid #333;
    }
    .player-name {
      font-weight: bold;
    }
    .league-badge {
      font-size: 0.8em;
      padding: 2px 8px;
      border-radius: 10px;
      background: #333;
      color: #aaa;
    }
    .league-Cyber-Legend { color: #0ff; border: 1px solid #0ff; box-shadow: 0 0 5px #0ff; }
    .league-Diamond { color: #b9f2ff; border: 1px solid #b9f2ff; }
    .league-Gold { color: #ffd700; border: 1px solid #ffd700; }
    .league-Silver { color: #c0c0c0; border: 1px solid #c0c0c0; }
    .league-Bronze { color: #cd7f32; border: 1px solid #cd7f32; }

    .score {
      font-family: monospace;
      font-size: 1.2em;
      color: #fff;
      text-align: right;
    }
    
    .current-user-row td {
      background: rgba(0, 251, 255, 0.15) !important;
      border-color: var(--cyber-blue) !important;
      box-shadow: 0 0 15px rgba(0, 251, 255, 0.1);
      color: #fff;
    }
    .current-user-row td:first-child {
        border-left: 4px solid var(--cyber-blue) !important;
    }
  </style>
</head>
<body>
    <%- include('partials/intro') %>
  <%- include('partials/ux_effects') %>
  <div class="container">
    
    <div class="cyber-header">
        <div class="header-left">
            <a href="/" class="back-btn-mini"><i class="fas fa-chevron-left"></i> <span data-i18n="back_to_base">BASE</span></a>
            <div class="header-title">
                <h1><span data-i18n="leaderboard.title_prefix">LEADER</span><span data-i18n="leaderboard.title_suffix">BOARD</span></h1>
                <p data-i18n="leaderboard.subtitle">TOP PILOTS OF THE GALAXY</p>
            </div>
        </div>
        
        <div style="color: var(--cyber-blue); font-weight: bold; letter-spacing: 1px; font-size: 1.2rem; text-shadow: 0 0 10px var(--cyber-blue);">
            <i class="fas fa-globe"></i> <span data-i18n="leaderboard.global">GLOBAL</span>
        </div>
    </div>

    <div class="table-responsive">
    <table class="leaderboard-table">
      <thead>
        <tr>
          <th style="text-align: center;" data-i18n="leaderboard.rank">#</th>
          <th data-i18n="leaderboard.player">Player</th>
          <th style="text-align: right;" data-i18n="leaderboard.score">High Score</th>
        </tr>
      </thead>
      <tbody>
        <% players.forEach((player, index) => { %>
          <tr class="<%= user && user._id.toString() === player._id.toString() ? 'current-user-row' : '' %>">
            <td class="rank rank-<%= index + 1 %>"><%= index + 1 %></td>
            <td>
              <div class="player-info">
                <% if (player.avatar) { %>
                  <img src="<%= player.avatar %>" class="player-avatar" alt="Avatar">
                <% } else { %>
                  <div class="player-avatar" style="background: #333; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-user"></i>
                  </div>
                <% } %>
                <div>
                  <div class="player-name"><%= player.displayName || player.username %></div>
                  <span class="league-badge league-<%= player.stats.leagueTier.replace(' ', '-') %>">
                    <%= player.stats.leagueTier %>
                  </span>
                </div>
              </div>
            </td>
            <td class="score"><%= player.stats.highScore.toLocaleString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    </div>
  </div>
  <script src="/js/localization.js"></script>
  <script src="/js/intro.js"></script>
</body>
</html>
