          setControlMode('touch');
        }
        
        if(isEditingHUD) return; // Allow drag
        e.preventDefault();
        e.stopPropagation();
        
        const touch = e.touches[0];
        joystickOrigin = { x: touch.clientX, y: touch.clientY };
        joystickActive = true;
        
        joystickVisual.classList.add('active');
        joystickVisual.style.left = joystickOrigin.x + 'px';
        joystickVisual.style.top = joystickOrigin.y + 'px';
        joystickKnob.style.transform = `translate(-50%, -50%)`;
        
        joystickData = { x: 0, y: 0 };
      });
      
      joystickZone.addEventListener('touchmove', (e) => {
        if(!joystickActive) return;
        if(isEditingHUD) return; // Allow drag
        e.preventDefault();
        e.stopPropagation();
        handleJoystickMove(e.touches[0]);
      });
      
      joystickZone.addEventListener('touchend', (e) => {
        if(isEditingHUD) return; // Allow drag
        e.preventDefault();
