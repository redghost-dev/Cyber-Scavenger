      });

    function handleJoystickMove(touch) {
      const maxRadius = 50; // Updated for 100px visual size
      
      let dx = touch.clientX - joystickOrigin.x;
      let dy = touch.clientY - joystickOrigin.y;
      
      const distance = Math.min(Math.hypot(dx, dy), maxRadius);
      const angle = Math.atan2(dy, dx);
      
      const moveX = Math.cos(angle) * distance;
      const moveY = Math.sin(angle) * distance;
      
      joystickKnob.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px))`;
      
      // Normalize -1 to 1
      joystickData.x = moveX / maxRadius;
      joystickData.y = moveY / maxRadius;
    }

    function resizeCanvas() {
      const rect = gameContainer.getBoundingClientRect();
      
      // Safety check: Don't resize to 0,0
      if (rect.width > 0 && rect.height > 0) {
          canvas.width = rect.width;
          canvas.height = rect.height;
      } else {
          // Fallback to window size if container is hidden/0
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
      }
      
      // Keep player in bounds if resized
      if (player.x > canvas.width) player.x = canvas.width / 2;
      if (player.y > canvas.height) player.y = canvas.height / 2;
    }

    window.addEventListener('resize', resizeCanvas);
    // Initial resize
    resizeCanvas();

    function toggleFullscreen() {
      if (!document.fullscreenElement && !document.webkitFullscreenElement) {
        if (gameContainer.requestFullscreen) {
            gameContainer.requestFullscreen().catch(err => {
                console.log(`Error attempting to enable full-screen mode: ${err.message} (${err.name})`);
                // Fallback
                gameContainer.classList.add('fullscreen');
                document.body.classList.add('game-active');
                resizeCanvas();
            });
        } else if (gameContainer.webkitRequestFullscreen) {
            gameContainer.webkitRequestFullscreen().catch(err => {
                console.log(`Error attempting to enable full-screen mode (webkit): ${err.message}`);
                gameContainer.classList.add('fullscreen');
                document.body.classList.add('game-active');
                resizeCanvas();
            });
        } else {
            // Fallback for iOS Safari (iPhone)
            console.log('Fullscreen API not supported. Using CSS fallback.');
            gameContainer.classList.add('fullscreen');
            document.body.classList.add('game-active');
            resizeCanvas();
        }
      } else {
        if (document.exitFullscreen) {
            document.exitFullscreen();
        } else if (document.webkitExitFullscreen) {
            document.webkitExitFullscreen();
        }
        
        // Also remove classes just in case
        gameContainer.classList.remove('fullscreen');
        document.body.classList.remove('game-active');
      }
    }

