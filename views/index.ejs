  <script>
    // --- Modal Logic for Shop, Leaderboard, Profile ---
    
    function closeAllModals() {
        const modals = [
            'shop-modal',
            'inventory-modal',
            'leaderboard-modal',
            'settings-modal',
            'profile-modal',
            'start-screen',
            'main-menu',
            'landing-screen',
            'game-over',
            'pause-screen',
            'upgrade-modal'
        ];
        
        modals.forEach(id => {
            const modal = document.getElementById(id);
            if (modal) {
                modal.classList.add('hidden');
                modal.style.display = 'none';
            }
        });
    }

    function closeModal(modalId) {
        const modal = document.getElementById(modalId + '-modal');
        if (modal) {
            modal.style.display = 'none';
            modal.classList.add('hidden');
        }
        
        // Return to home if not in game
        if (!gameRunning) {
            goToHome();
        }
    }

    // --- SHOP LOGIC ---
    let allShopItems = [];
    let currentShopFilter = 'ship';

    async function openShop() {
        closeAllModals();
        const modal = document.getElementById('shop-modal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        
        // Update Wallet UI
        if (currentUser && currentUser.wallet) {
            document.getElementById('shop-wallet-coins').innerText = currentUser.wallet.coins;
            document.getElementById('shop-wallet-gems').innerText = currentUser.wallet.gems;
        }

        const content = document.getElementById('shop-content');
        content.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #aaa; padding: 50px;"><i class="fas fa-circle-notch fa-spin fa-3x"></i><br><br>LOADING ARMORY DATA...</div>';

        try {
            const res = await fetch('/api/shop/items');
            if (!res.ok) {
                const text = await res.text();
                throw new Error(`Server Error (${res.status}): ${text.substring(0, 50)}...`);
            }
            const items = await res.json();
            
            if (!Array.isArray(items)) {
                 throw new Error('Invalid Data Format');
            }

            allShopItems = items;
            filterShop(currentShopFilter);

        } catch (err) {
            console.error(err);
            content.innerHTML = `<div style="grid-column: 1/-1; text-align: center; color: #f55;">ERROR LOADING DATA<br><span style="font-size:0.8rem; color:#aaa;">${err.message}</span></div>`;
        }
    }

    function filterShop(type) {
        currentShopFilter = type;
        
        // Update Tabs
        document.querySelectorAll('#shop-modal .tab-btn').forEach(btn => btn.classList.remove('active'));
        const activeTab = document.getElementById('tab-' + type);
        if(activeTab) activeTab.classList.add('active');

        const content = document.getElementById('shop-content');
        content.innerHTML = '';

        const filteredItems = allShopItems.filter(item => item.type === type);

        if (filteredItems.length === 0) {
            content.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #aaa; padding: 50px;">NO ITEMS IN THIS CATEGORY</div>';
            return;
        }

        filteredItems.forEach(item => {
            const card = document.createElement('div');
            card.className = 'inventory-card';
            
            let actionBtn = '';
            if (!currentUser) {
                actionBtn = `<button class="equip-btn" disabled style="opacity: 0.5;">LOGIN</button>`;
            } else {
                // Safe check for inventory item structure
                const owned = currentUser.inventory && currentUser.inventory.some(i => {
                    if (!i) return false;
                    const itemId = (typeof i.item === 'object' && i.item !== null) ? i.item._id : i.item;
                    return itemId === item._id;
                });

                if (owned && item.type !== 'powerup') {
                    actionBtn = `<button class="equip-btn secondary" disabled>OWNED</button>`;
                } else {
                    const canAfford = (item.currencyType === 'coin' && currentUser.wallet.coins >= item.price) || 
                                      (item.currencyType === 'gem' && currentUser.wallet.gems >= item.price);
                    
                    actionBtn = `<button onclick="buyItem('${item._id}')" class="equip-btn ${canAfford ? '' : 'danger'}" ${canAfford ? '' : 'disabled'}>
                                    ${item.price} <i class="fas ${item.currencyType === 'coin' ? 'fa-coins' : 'fa-gem'}"></i>
                                 </button>`;
                }
            }

            // Image Handling: Generate Dynamic Preview based on Item Type
            let visualContainer = document.createElement('div');
            visualContainer.style.height = '60px';
            visualContainer.style.display = 'flex';
            visualContainer.style.alignItems = 'center';
            visualContainer.style.justifyContent = 'center';
            visualContainer.style.marginBottom = '10px';
            
            if (item.type === 'ship') {
                const name = item.name.toLowerCase();
                let shape = 'circle';
                if (name.includes('tank')) shape = 'square';
                else if (name.includes('speed')) shape = 'triangle';
                else if (name.includes('interceptor')) shape = 'interceptor';
                else if (name.includes('cruiser') || name.includes('bomber')) shape = 'bomber';
                else if (name.includes('stealth')) shape = 'stealth';
                
                const sprite = createNeonSprite(item.color || '#00fbff', 20, 10, shape);
                const img = document.createElement('img');
                img.src = sprite.image.toDataURL();
                img.style.width = '60px';
                img.style.height = '60px';
                img.style.objectFit = 'contain';
                visualContainer.appendChild(img);
            } 
            else if (item.type === 'weapon') {
                const color = item.color || '#ff0055';
                visualContainer.innerHTML = `<div style="font-size: 35px; color: ${color}; text-shadow: 0 0 15px ${color};"><i class="fas fa-crosshairs"></i></div>`;
            }
            else if (item.type === 'trail') {
                const color = item.color || 'var(--cyber-blue)';
                visualContainer.innerHTML = `<div style="font-size: 40px; color: ${color}; text-shadow: 0 0 15px ${color};"><i class="fas fa-wind"></i></div>`;
            }
            else if (item.type === 'skin') {
                 const color = item.color || '#fff';
                 const sprite = createNeonSprite(color, 20, 10, 'circle');
                 const img = document.createElement('img');
                 img.src = sprite.image.toDataURL();
                 img.style.width = '60px';
                 img.style.height = '60px';
                 img.style.objectFit = 'contain';
                 visualContainer.appendChild(img);
            }
            else if (item.type === 'powerup') {
                 let iconClass = 'fa-bolt';
                 if (item.name.toLowerCase().includes('magnet')) iconClass = 'fa-magnet';
                 else if (item.name.toLowerCase().includes('xp') || item.name.toLowerCase().includes('experience')) iconClass = 'fa-angle-double-up';
                 else if (item.name.toLowerCase().includes('health') || item.name.toLowerCase().includes('repair')) iconClass = 'fa-heart';
                 else if (item.name.toLowerCase().includes('shield')) iconClass = 'fa-shield-alt';
                 
                 visualContainer.innerHTML = `<div style="font-size: 30px; color: #ffd700; text-shadow: 0 0 10px #ffd700;"><i class="fas ${iconClass}"></i></div>`;
            } 
            else if (item.type === 'avatar') {
                 visualContainer.innerHTML = `<img src="${item.imageUrl}" alt="${item.name}" style="width: 60px; height: 60px; border-radius: 50%; border: 2px solid ${item.isPremium ? '#f0f' : 'var(--cyber-blue)'}; box-shadow: 0 0 10px ${item.isPremium ? '#f0f' : 'var(--cyber-blue)'}; background: #000;">`;
            }
            else if (item.imageUrl && item.imageUrl !== '/img/items/default.svg' && !item.imageUrl.includes('placeholder')) {
                 visualContainer.innerHTML = `<img src="${item.imageUrl}" alt="${item.name}" style="width: 60px; height: 60px; object-fit: contain;">`;
            } else {
                 visualContainer.innerHTML = `<div style="font-size: 30px; color: ${item.color || 'var(--cyber-blue)'};"><i class="fas fa-cube"></i></div>`;
            }

            card.appendChild(visualContainer);
            
            const infoDiv = document.createElement('div');
            infoDiv.innerHTML = `
                <div class="item-name">${item.name}</div>
                <div class="item-type" style="font-size: 0.7rem; color: #888; margin-bottom: 5px;">${item.description || item.type.toUpperCase()}</div>
                ${actionBtn}
            `;
            card.appendChild(infoDiv);
            content.appendChild(card);
        });
    }

    async function buyItem(itemId) {
        console.log('Initiating purchase for item:', itemId);
        if (typeof showSystemConfirm !== 'function') {
            console.error('showSystemConfirm is not defined');
            alert('System Error: Modal not loaded. Please refresh.');
            return;
        }

        showSystemConfirm('Are you sure you want to purchase this item?', async () => {
            try {
                console.log('Sending purchase request...');
                const res = await fetch('/api/shop/buy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ itemId })
                });
                
                const data = await res.json();
                console.log('Purchase response:', data);
                
                if (data.success) {
                    showSystemAlert(data.message, 'PURCHASE SUCCESSFUL');
                    // Update local user data
                    currentUser.wallet = data.wallet;
                    currentUser.inventory = data.inventory;
                    // Refresh UI
                    openShop(); 
                } else {
                    showSystemAlert(data.error || 'Unknown Error', 'PURCHASE FAILED');
                }
            } catch (err) {
                console.error('Purchase error:', err);
                showSystemAlert('Transaction Failed: ' + err.message, 'SYSTEM ERROR');
            }
        }, 'CONFIRM PURCHASE');
    }

    // --- LEADERBOARD LOGIC ---
    async function openLeaderboard() {
        closeAllModals();
        const modal = document.getElementById('leaderboard-modal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        loadLeaderboard('global');
    }

    async function loadLeaderboard(type) {
        const content = document.getElementById('leaderboard-content');
        const btnGlobal = document.getElementById('btn-lb-global');
        const btnLeague = document.getElementById('btn-lb-league');
        
        if (type === 'global') {
            btnGlobal.classList.add('active');
            btnLeague.classList.remove('active');
        } else {
            btnGlobal.classList.remove('active');
            btnLeague.classList.add('active');
        }

        content.innerHTML = '<div style="text-align: center; color: #aaa; padding: 50px;"><i class="fas fa-circle-notch fa-spin fa-3x"></i><br><br>ACCESSING DATABASE...</div>';

        try {
            const res = await fetch(`/api/leaderboard/${type}`);
            const data = await res.json();
            
            content.innerHTML = '';
            
            let players = [];
            if (type === 'global') players = data;
            else players = data.leaderboard;

            if (players.length === 0) {
                content.innerHTML = '<div style="text-align: center; color: #aaa;">NO DATA AVAILABLE</div>';
                return;
            }

            players.forEach((p, index) => {
                const rank = index + 1;
                const isMe = currentUser && p.username === currentUser.username;
                const row = document.createElement('div');
                row.className = `leaderboard-row ${isMe ? 'current-user' : ''}`;
                
                let rankClass = '';
                if (rank === 1) rankClass = 'rank-1';
                else if (rank === 2) rankClass = 'rank-2';
                else if (rank === 3) rankClass = 'rank-3';

                const name = p.displayName || p.username;
                const truncatedName = name.length > 7 ? name.substring(0, 7) + '...' : name;

                row.innerHTML = `
                    <div class="row-scanner"></div>
                    <div class="rank-badge ${rankClass}">${rank}</div>
                    <div class="player-avatar-wrapper">
                        <img src="${p.avatar || '/img/default-avatar.svg'}" class="row-avatar">
                    </div>
                    <div class="player-info">
                        <div class="player-name">${truncatedName}</div>
                        <div class="player-stats">LVL ${p.stats.level} | ${p.stats.leagueTier}</div>
                    </div>
                    <div class="player-score">
                        <span class="score-value">${p.stats.highScore.toLocaleString()}</span>
                        <span class="score-label">PTS</span>
                    </div>
                `;
                content.appendChild(row);
            });

        } catch (err) {
            console.error(err);
            content.innerHTML = '<div style="text-align: center; color: #f55;">CONNECTION ERROR</div>';
        }
    }

