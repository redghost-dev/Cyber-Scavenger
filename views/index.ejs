        <div id="pause-screen">
          <h2 class="overlay-title" data-i18n="game.paused">PAUSED</h2>
          <div style="display: flex; flex-direction: column; gap: 15px; width: 250px;">
              <button onclick="togglePause()" class="overlay-btn primary">
                  <span data-i18n="game.resume">RESUME</span>
              </button>
              <button onclick="toggleFullscreen()" class="overlay-btn">
                  <span data-i18n="game.toggle_fullscreen">FULLSCREEN</span>
              </button>
              <button onclick="goToMainMenu()" class="overlay-btn danger">
                  <span data-i18n="game.main_menu">MAIN MENU</span>
              </button>
          </div>
        </div>

        <!-- Game Over Screen -->
        <div id="game-over">
          <div class="cyber-panel">
            <h2 class="overlay-title" data-i18n="game.game_over">SYSTEM FAILURE</h2>
            
            <div class="overlay-score-panel">
              <div class="overlay-score-label" data-i18n="game.score">TOTAL SCORE</div>
              <div id="final-score-value" class="overlay-score-value">0</div>
              <p id="new-high-score" style="color: #ffd700; margin-top: 5px; font-family: 'Orbitron', monospace; font-size: 0.8rem; letter-spacing: 2px; animation: blink 0.5s infinite; display: none;" data-i18n="game.new_high_score">NEW RECORD DETECTED!</p>
            </div>

            <div class="overlay-score-panel" style="border-left-color: #ffd700; background: rgba(255, 215, 0, 0.05); margin-top: 0;">
              <div class="overlay-score-label" style="color: #ffd700;">COINS COLLECTED</div>
              <div id="final-coins-value" class="overlay-score-value" style="text-shadow: 0 0 10px #ffd700;">0</div>
            </div>
            
            <div id="revive-container" style="margin-bottom: 20px; display: none; width: 100%; justify-content: center;">
                <button onclick="watchAdForRevive()" class="cyber-btn" style="--btn-color: #ffd700; color: #000; font-weight: 900; background: #ffd700; border: none; box-shadow: 0 0 15px rgba(255, 215, 0, 0.4); width: 100%;">
                    <i class="fas fa-heart"></i> <span data-i18n="game.revive">RESTORE SYSTEM</span>
                </button>
            </div>

            <div id="double-reward-container" style="margin-bottom: 20px; display: none; width: 100%; justify-content: center;">
                <button onclick="watchAdForDoubleReward()" class="cyber-btn" style="--btn-color: #00f2ff; background: rgba(0, 242, 255, 0.1); border: 1px solid #00f2ff; color: #00f2ff; width: 100%;">
                    <i class="fas fa-bolt"></i> <span data-i18n="ad.double_reward">2X DATA HARVEST</span>
                </button>
            </div>

            <div style="display: flex; flex-direction: row; gap: 8px; width: 100%; margin-top: 10px;">
              <button onclick="resetGame()" class="cyber-btn" style="--btn-color: var(--cyber-blue); flex: 1; min-width: 0; padding: 0 5px;">
                <i class="fas fa-redo" style="font-size: 0.8rem;"></i> <span data-i18n="game.restart" style="font-size: 0.75rem;">REBOOT</span>
              </button>
              <button onclick="goToMainMenu()" class="cyber-btn" style="--btn-color: var(--neon-pink); flex: 1; min-width: 0; padding: 0 5px;">
                <i class="fas fa-power-off" style="font-size: 0.8rem;"></i> <span data-i18n="game.main_menu" style="font-size: 0.75rem;">TERMINATE</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile Controls -->
        <div id="mobile-controls">
          <div id="joystick-zone" class="control-zone"></div>
          <div id="joystick-visual">
            <div id="joystick-knob"></div>
          </div>
          <div id="mobile-dash-btn" class="control-zone" data-i18n="game.dash">DASH</div>
          <div id="mobile-overdrive-btn" class="control-zone" data-i18n="game.ult">ULT</div>
        </div>

                <!-- OVERDRIVE BAR (SHORT, RIGHT SIDE) -->
                <div id="overdrive-bar">
                    <div id="overdrive-fill"></div>
                    <div id="overdrive-text">ULTRA</div>
                </div>
                <div id="overdrive-ready">ULTRA READY</div>

                <!-- Settings Modal & HUD Editor moved to body root -->

        <!-- Start Screen removed from here -->
      </div>

  </div>

  <div id="user-data-store" data-user="<%= JSON.stringify(user || null) %>" style="display:none;"></div>


  <!-- MODULES: Global State & Factories -->
  <script src="/js/game_state.js"></script>
  <script src="/js/game_modules/sprite_factory.js"></script>
  <script src="/js/game_modules/input_manager.js"></script>
  <script src="/js/game_modules/boss_manager.js"></script>

  <script>
    // Inject User Data from Backend (Secured & Clean)
    Object.defineProperty(window, 'currentUser', {
        get: () => window.GameState.user,
        set: (v) => window.GameState.user = v
    });

    Object.defineProperty(window, 'gameConfig', {
        get: () => window.GameState.gameConfig,
        set: (v) => window.GameState.gameConfig = v
    });
    let lastInterstitialTime = Date.now();

    async function fetchGameConfig() {
        try {
            const res = await fetch('/api/config');
            const data = await res.json();
            if (data.success) {
                gameConfig = data.config;
                console.log('Game Config Loaded:', gameConfig);
                
                // Update UI elements with config values
                const adBtnText = document.querySelector('[data-i18n="menu.watch_ad"]');
                if (adBtnText && gameConfig.ads && gameConfig.ads.rewards) {
                    adBtnText.innerText = `WATCH AD (+${gameConfig.ads.rewards.coinsPerAd} COINS)`;
                }
            }
        } catch (err) {
            console.error('Failed to fetch game config:', err);
        }
    }
    try {
        const userDataRaw = document.getElementById('user-data-store').getAttribute('data-user');
        if (userDataRaw && userDataRaw !== 'null') {
            currentUser = JSON.parse(userDataRaw);
        }
    } catch (e) {
        console.error('Error parsing user data:', e);
    }
    
    const isLoggedIn = !!currentUser;
    console.log('Current User Data:', currentUser);
    
    // Improved Sticky Guest Protection
    if (isLoggedIn && currentUser.isGuest === false) {
        localStorage.removeItem('cyber_guest_id');
        document.cookie = "cyber_guest_id=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    }
    
    // Fetch Game Config
    fetchGameConfig();

    // Handle Back-Forward Cache (bfcache)
    window.addEventListener('pageshow', (event) => {
        if (event.persisted) {
            console.log('Page restored from bfcache. Reloading to ensure fresh state...');
            window.location.reload();
        }
    });

    async function refreshInventory() {
        if (!isLoggedIn) return;
        try {
            const res = await fetch('/api/shop/inventory');
            if (res.ok) {
                const inventory = await res.json();
                if (currentUser) {
                    currentUser.inventory = inventory;
                    console.log('Inventory refreshed:', inventory);
                }
            }
        } catch (err) {
            console.error('Failed to refresh inventory:', err);
        }
    }

    function isMobileDevice() {
        return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth <= 768;
    }

    // --- Ad Logic (Web Simulation & Android Bridge) ---
    let isAdPlaying = false;
    let adType = null; // 'revive', 'coins', 'double'

    function watchAdForDoubleReward() {
        if (isAdPlaying) return;
        adType = 'double';
        playAd();
    }

    function watchAdForRevive() {
        if (isAdPlaying) return;
        adType = 'revive';
        playAd();
    }

    function watchAdForCoins() {
        if (isAdPlaying) return;
        adType = 'coins';
        playAd();
    }

    function playAd() {
        isAdPlaying = true;
        
        const adModal = document.getElementById('ad-modal');
        const adProgress = document.getElementById('ad-progress');
        const adCountdown = document.getElementById('ad-countdown');
        
        if (adModal) {
            adModal.style.display = 'flex';
            adModal.classList.remove('hidden');
        }

        // Check if running in Android WebView with JS Interface
        if (window.Android && window.Android.showRewardedAd) {
            console.log('Triggering Android Native Ad...');
            if (adCountdown) adCountdown.innerText = '...';
            window.Android.showRewardedAd();
            // The Android app should call 'onAdCompleted()' or 'onAdFailed()'
        } else {
            // Web Simulation
            console.log('Simulating Web Ad...');
            
            let timeLeft = 5;
            if (adCountdown) adCountdown.innerText = timeLeft;
            if (adProgress) adProgress.style.width = '0%';
            
            const timer = setInterval(() => {
                timeLeft--;
                if (adCountdown) adCountdown.innerText = timeLeft;
                if (adProgress) adProgress.style.width = ((5 - timeLeft) / 5 * 100) + '%';
                
                if (timeLeft <= 0) {
                    clearInterval(timer);
                    setTimeout(() => {
                        if (typeof window.onAdCompleted === 'function') {
                            window.onAdCompleted();
                        }
                    }, 500);
                }
            }, 1000);
        }
    }

    // Callback called by Android App or Web Simulation
    window.onAdCompleted = function() {
        console.log('Ad Completed! Type:', adType);
        isAdPlaying = false;
        
        const adModal = document.getElementById('ad-modal');
        if (adModal) {
            adModal.style.display = 'none';
            adModal.classList.add('hidden');
        }
        
        if (adType === 'revive') {
            revivePlayer();
        } else if (adType === 'coins') {
            grantAdCoins();
        } else if (adType === 'double') {
            grantDoubleReward();
        }
        adType = null;
    };

    window.onAdFailed = function() {
        console.log('Ad Failed / Cancelled');
        isAdPlaying = false;
        adType = null;
        
        const adModal = document.getElementById('ad-modal');
        if (adModal) {
            adModal.style.display = 'none';
            adModal.classList.add('hidden');
        }
        
        showSystemAlert(Loc.t('ad.failed') || 'Ad failed to load.', 'AD ERROR');
    };

    function revivePlayer() {
        hasRevived = true;
        player.hp = player.maxHp;
        player.invincibilityTimer = 3000; // 3 sec immunity
        
        // Clear nearby enemies to prevent instant death
        enemies.forEach(e => {
            const angle = Math.atan2(e.y - player.y, e.x - player.x);
            e.x += Math.cos(angle) * 300;
            e.y += Math.sin(angle) * 300;
        });
        
        document.body.classList.remove('game-over');
        gameOverScreen.classList.add('hidden');
        gameOverScreen.style.display = 'none';
        gameRunning = true;
        lastTime = performance.now();
        animateGame(lastTime);
        
        // Hide revive button
        const reviveContainer = document.getElementById('revive-container');
        if(reviveContainer) reviveContainer.style.display = 'none';
        
        spawnFloatingText(player.x, player.y, "REVIVED!", "var(--cyber-blue)", 30);

        // Log revive on server
        fetch('/api/ads/reward', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'revive' })
        }).catch(console.error);
    }

    function grantDoubleReward() {
        console.log('Granting Multiplied Score Reward...');
        hasDoubledScore = true; // Mark as doubled to prevent further revives or doubles
        const previousScore = score;
        const multiplier = Math.max(2, player.level);
        
        score = score * multiplier;
        // coinsEarned is NOT doubled per user request
        
        // Update UI
        if (finalScoreDisplay) {
            finalScoreDisplay.innerText = score;
            // Add a blue glow effect to indicate duplication
            finalScoreDisplay.style.color = '#00f2ff';
            finalScoreDisplay.parentElement.style.boxShadow = '0 0 30px rgba(0, 242, 255, 0.3)';
        }

        // Coins remain unchanged in UI as well

        // Check for new high score again
        if (score > highScore) {
            highScore = score;
            uiHighScore.innerText = 'HIGH SCORE: ' + highScore;
            newHighScoreDisplay.style.display = 'block';
            if (!isLoggedIn) {
                localStorage.setItem('cyberScavengerHighScore', highScore);
            }
        }
        
        // Submit New Doubled Score to Server
        if (isLoggedIn) {
            const coinsToSubmit = coinsEarned - coinsSent;
            coinsSent = coinsEarned;

            const scoreToSubmit = score - scoreSent;
            scoreSent = score;

            fetch('/api/game/submit-score', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    score: scoreToSubmit,
                    coins: coinsToSubmit,
                    finalScore: score,
                    isFirstSubmit: false // Already submitted once on death
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    console.log('Doubled score saved:', data.newStats);
                    
                    // Update Local Multi-Wallet
                    if (data.wallet) {
                        currentUser.wallet = data.wallet;
                        updateWalletUI();
                    }

                    if (data.newStats.highScore > highScore) {
                        highScore = data.newStats.highScore;
                        uiHighScore.innerText = 'HIGH SCORE: ' + highScore;
                    }
                }
            })
            .catch(err => console.error('Score submission failed:', err));
        }

        const msg = Loc.t('ad.reward_granted_score')
            .replace('{old}', previousScore)
            .replace('{new}', score);
        showSystemAlert(msg, 'SCORE BOOST');
        
        // Hide both buttons after use (can't double twice, can't revive after double)
        const doubleBtn = document.getElementById('double-reward-container');
        if (doubleBtn) doubleBtn.style.display = 'none';
        
        const reviveBtn = document.getElementById('revive-container');
        if (reviveBtn) reviveBtn.style.display = 'none';
    }

    function grantAdCoins() {
        console.log('Granting Ad Reward...');
        const amount = (gameConfig && gameConfig.ads && gameConfig.ads.rewards) ? gameConfig.ads.rewards.coinsPerAd : 100;

        // Call API - Works for both registered and guest users now!
        fetch('/api/ads/reward', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type: 'coins' })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Update local user wallet from server data
                currentUser.wallet = data.wallet;
                updateWalletUI();
                const msg = Loc.t('ad.reward_granted_coins').replace('{amount}', amount);
                showSystemAlert(msg, 'AD REWARD');
            }
        })
        .catch(err => {
            console.error('Coin grant failed:', err);
            showSystemAlert('Sync failed. Please check connection.', 'OFFLINE');
        });
    }

    function updateWalletUI() {
        if (!currentUser || !currentUser.wallet) return;

        // Update ALL elements with wallet classes (Main Menu, Guest Menu, Shop, Profile)
        const coinDisplays = document.querySelectorAll('.wallet-coins-val');
        const gemDisplays = document.querySelectorAll('.wallet-gems-val');
        
        const coinVal = currentUser.wallet.coins || 0;
        const gemVal = currentUser.wallet.gems || 0;

        coinDisplays.forEach(el => {
            el.innerText = coinVal.toLocaleString();
        });

        gemDisplays.forEach(el => {
            el.innerText = gemVal.toLocaleString();
        });

        console.log(`UI: Updated all wallet displays to ${coinVal} coins.`);
    }

    // --- UI Logic ---
    const landingScreen = document.getElementById('landing-screen');
    const mainMenu = document.getElementById('main-menu');
    const gameWrapper = document.getElementById('game-wrapper');
    const startConfigScreen = document.getElementById('start-screen');
    const guestLoginBtn = document.getElementById('guest-login-btn');
    const guestLogoutBtn = document.getElementById('guest-logout-btn');
    const startGameBtn = document.getElementById('start-game-btn');
    
    // Guest Login Handler
    if (guestLoginBtn) {
        guestLoginBtn.addEventListener('click', async () => {
            console.log('Guest Login Requested...');
            
            try {
                let existingGuestId = localStorage.getItem('cyber_guest_id');
                // Try cookie if localStorage failed (useful for some WebViews)
                if (!existingGuestId) {
                    const match = document.cookie.match(new RegExp('(^| )' + 'cyber_guest_id' + '=([^;]+)'));
                    if (match) existingGuestId = match[2];
                }

                const res = await fetch('/auth/guest', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ existingGuestId })
                });
                const data = await res.json();
                
                if (data.success) {
                    if (data.username) {
                        localStorage.setItem('cyber_guest_id', data.username);
                        // PERSISTENT COOKIE (1 Year)
                        const d = new Date();
                        d.setTime(d.getTime() + (365*24*60*60*1000));
                        document.cookie = "cyber_guest_id=" + data.username + "; expires=" + d.toUTCString() + "; path=/; SameSite=Lax";
                    }
                    window.location.reload(); // Reload to initialize with real server data
                } else {
                    showSystemAlert(data.error || 'Guest login failed', 'SYSTEM');
                }
            } catch (err) {
                console.error(err);
                showSystemAlert('Network error during guest login', 'ERROR');
            }
        });
    } else {
        console.log('Guest Login Button NOT Found');
    }
    
    // Guest Logout Handler
    if (guestLogoutBtn) {
        guestLogoutBtn.addEventListener('click', () => {
            // Serious warning for Guest users
            if (currentUser && currentUser.isGuest) {
                showSystemConfirm(
                    Loc.t('auth.guest_logout_warning'),
                    () => {
                        window.location.href = '/auth/logout';
                    },
                    Loc.t('auth.guest_logout_title')
                );
            } else {
                window.location.href = '/auth/logout';
            }
        });
    }
    
    // Start Game Handler (Main Menu -> Game Config)
    if (startGameBtn) {
        console.log('Start Game Button Found');
        startGameBtn.addEventListener('click', () => {
            console.log('Start Game Clicked');
            mainMenu.classList.add('hidden');
            // gameWrapper.classList.remove('hidden'); // Don't show game wrapper yet
            startConfigScreen.classList.remove('hidden'); // Use class instead of style
            startConfigScreen.style.display = 'flex'; 
        });
    } else {
        console.log('Start Game Button NOT Found');
    }

    // Hangar Button Handler
    const btnOpenHangar = document.getElementById('btn-open-hangar');
    if (btnOpenHangar) {
        btnOpenHangar.addEventListener('click', () => {
            openInventory();
        });
    }
    
    function backToMainMenu() {
        document.getElementById('global-dock-menu').style.display = 'flex';
        startConfigScreen.style.display = 'none';
        
        mainMenu.classList.remove('hidden');
        mainMenu.style.display = 'flex';

        // Restart Global UI Effects
        if (typeof toggleGlobalEffects === 'function') toggleGlobalEffects(true);
    }

    function goToMainMenu() {
      // Ana Üs'e dön (goToHome ile aynı mantık)
      document.getElementById('global-dock-menu').style.display = 'flex';

      // Restart Global UI Effects
      if (typeof toggleGlobalEffects === 'function') toggleGlobalEffects(true);
      
      // Force exit fullscreen
      if (document.fullscreenElement) {
        document.exitFullscreen().catch(err => console.log(err));
      }
      
      // Remove manual fullscreen classes
      gameContainer.classList.remove('fullscreen');
      document.body.classList.remove('game-active', 'paused', 'game-over');

      // Tüm overlay'leri kapat
      gameOverScreen.classList.add('hidden');
      gameOverScreen.style.display = 'none';
      pauseScreen.classList.add('hidden');
      pauseScreen.style.display = 'none';
      startConfigScreen.style.display = 'none';
      gameWrapper.classList.add('hidden');
      
      // Ana menüyü göster
      mainMenu.classList.remove('hidden');
      mainMenu.style.display = 'flex';
      
      // Hide mobile controls
      if(mobileControls) {
          mobileControls.style.display = 'none';
          mobileControls.style.pointerEvents = 'none';
      }
      if(fullscreenBtn) fullscreenBtn.style.display = 'none';

      resetGameState();
      gameRunning = false;
      gamePaused = false;
      cancelAnimationFrame(animationId);
    }
    
    // --- Cyber Scavenger v6.0 Game Logic ---
    
    // Audio System
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    let soundEnabled = true;
    let vibrationEnabled = true;

    const Sound = {
      playTone: (freq, type, duration, vol = 0.1) => {
        if (!soundEnabled) return;
        if (audioCtx.state === 'suspended') audioCtx.resume();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(vol, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
      },
      collect: () => Sound.playTone(880, 'sine', 0.1),
      powerup: () => {
        Sound.playTone(440, 'square', 0.1);
        setTimeout(() => Sound.playTone(880, 'square', 0.2), 100);
      },
      dash: () => Sound.playTone(200, 'sawtooth', 0.3),
      hit: () => {
        Sound.playTone(100, 'sawtooth', 0.5);
        triggerVibration(200);
      },
      bossHit: () => {
        Sound.playTone(100, 'square', 0.2);
        setTimeout(() => Sound.playTone(50, 'square', 0.3), 50);
        triggerVibration(100);
      },
      overdrive: () => {
        Sound.playTone(220, 'sawtooth', 0.5);
        setTimeout(() => Sound.playTone(440, 'sawtooth', 0.5), 100);
        setTimeout(() => Sound.playTone(880, 'sawtooth', 0.5), 200);
        triggerVibration([100, 50, 100]);
      },
      gameOver: () => {
        Sound.playTone(150, 'sawtooth', 0.5);
        setTimeout(() => Sound.playTone(100, 'sawtooth', 0.5), 400);
        triggerVibration(500);
      }
    };

    function triggerVibration(pattern) {
      if (vibrationEnabled && navigator.vibrate) {
        navigator.vibrate(pattern);
      }
    }

    const gameContainer = document.getElementById('game-container');
    window.canvas = document.getElementById('game-canvas');
    window.ctx = canvas.getContext('2d');
    window.GameState.canvas = window.canvas;
    window.GameState.ctx = window.ctx;
    const uiScore = document.getElementById('game-ui');
    const uiCoins = document.getElementById('coin-ui');
    const uiHighScore = document.getElementById('high-score-ui');
    const uiDash = document.getElementById('dash-ui');
    const uiPowerups = document.getElementById('powerups-ui');
    const uiCombo = document.getElementById('combo-ui');
    const uiBossHp = document.getElementById('boss-hp-container');
    const uiBossHpFill = document.getElementById('boss-hp-fill');
    const uiOverdriveFill = document.getElementById('overdrive-fill');
    const uiOverdriveReady = document.getElementById('overdrive-ready');
    const uiXpFill = document.getElementById('xp-fill');
    const uiLevelIndicator = document.getElementById('level-indicator');
    const uiHpContainer = document.getElementById('player-hp-container');
    const upgradeModal = document.getElementById('upgrade-modal');
    const settingsModal = document.getElementById('settings-modal');
    const upgradeCardsContainer = document.getElementById('upgrade-cards-container');
    const gameOverScreen = document.getElementById('game-over');
    // startScreen is already declared at the top
    const pauseScreen = document.getElementById('pause-screen');
    const finalScoreDisplay = document.getElementById('final-score-value');
    const finalCoinsDisplay = document.getElementById('final-coins-value');
    const newHighScoreDisplay = document.getElementById('new-high-score');
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    
    // Settings Logic (Moved to bottom with other modal handlers)
    function toggleSetting(setting) {
      const toggle = document.getElementById('toggle-' + setting);
      if (setting === 'sound') {
        soundEnabled = !soundEnabled;
        toggle.classList.toggle('active', soundEnabled);
      } else if (setting === 'vibration') {
        vibrationEnabled = !vibrationEnabled;
        toggle.classList.toggle('active', vibrationEnabled);
        if (vibrationEnabled) triggerVibration(100);
      }
    }


    
    // Mobile UI
    const mobileControls = document.getElementById('mobile-controls');
    const joystickZone = document.getElementById('joystick-zone');
    const joystickKnob = document.getElementById('joystick-knob');
    const joystickVisual = document.getElementById('joystick-visual');
    const mobileDashBtn = document.getElementById('mobile-dash-btn');
    const mobileOverdriveBtn = document.getElementById('mobile-overdrive-btn');

    let gameRunning = false;
    let gamePaused = false;
    let score = 0;
    let coinsEarned = 0;
    let coinsSent = 0;
    let scoreSent = 0;
    
    // Auth State & High Score Init
    // isLoggedIn is already defined at the top
    let highScore = 0;
    
    if (isLoggedIn && currentUser && currentUser.stats) {
        highScore = currentUser.stats.highScore || 0;
    } else {
