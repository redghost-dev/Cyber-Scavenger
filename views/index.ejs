    // --- INVENTORY SYSTEM ---
    let currentInventoryTab = 'ships';

    function openInventory() {
        closeAllModals();
        const modal = document.getElementById('inventory-modal');
        modal.classList.remove('hidden'); // Use classList for consistency
        modal.style.display = 'flex';
        switchInventoryTab('ships'); // Default to ships
        refreshInventoryUI();
    }

    function closeInventory() {
        const modal = document.getElementById('inventory-modal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        if (!gameRunning) {
            goToHome();
        }
    }

    function switchInventoryTab(tab) {
        currentInventoryTab = tab;
        
        // Update Buttons (Scoped to Inventory)
        document.querySelectorAll('#inventory-modal .tab-btn').forEach(btn => {
            if (btn.getAttribute('data-tab') === tab) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Update Views - Hide all grids first (Scoped to Inventory)
        document.querySelectorAll('#inventory-modal .inventory-grid').forEach(grid => {
            grid.classList.add('hidden');
        });
        
        // Show selected grid
        const selectedGrid = document.getElementById(`${tab}-tab`);
        if (selectedGrid) {
            selectedGrid.classList.remove('hidden');
        }
        
        refreshInventoryUI();
    }

    async function refreshInventoryUI() {
        const containerId = `${currentInventoryTab}-tab`;
        const grid = document.getElementById(containerId);
        if(!grid) return;

        grid.innerHTML = '<div class="loading-spinner">Loading...</div>';
        
        await refreshInventory(); // Fetch latest data
        
        if (!currentUser || !currentUser.inventory || currentUser.inventory.length === 0) {
            grid.innerHTML = '<div style="color:#888; text-align:center; width:100%;">No items found. Visit the Shop!</div>';
            return;
        }

        grid.innerHTML = '';
        
        // Filter by current tab (ship or trail)
        // Note: The tab name is plural ('ships', 'trails'), item type is singular ('ship', 'trail')
        const targetType = currentInventoryTab.slice(0, -1); 
        
        const filtered = currentUser.inventory.filter(slot => {
            if (!slot.item) return false;
            return slot.item.type === targetType;
        });

        if (filtered.length === 0) {
            grid.innerHTML = `<div style="color:#888; text-align:center; width:100%;">No ${currentInventoryTab} owned.</div>`;
            return;
        }

        filtered.forEach(slot => {
            try {
                const item = slot.item;
                if (!item) return;

                const card = document.createElement('div');
                card.className = 'inventory-card';
                if (slot.isEquipped) card.classList.add('equipped');
                
                // Visual Preview
                let visualContainer = document.createElement('div');
                visualContainer.style.height = '60px';
                visualContainer.style.display = 'flex';
                visualContainer.style.alignItems = 'center';
                visualContainer.style.justifyContent = 'center';
                visualContainer.style.marginBottom = '10px';

                if (item.type === 'ship') {
                    let shape = 'circle';
                    const name = (item.name || '').toLowerCase();
                    if (name.includes('tank')) shape = 'square';
                    else if (name.includes('speed')) shape = 'triangle';
                    else if (name.includes('interceptor')) shape = 'interceptor';
                    else if (name.includes('cruiser') || name.includes('bomber')) shape = 'bomber';
                    else if (name.includes('stealth')) shape = 'stealth';
                    
                    // Use the existing sprite generator
                    const spriteData = createNeonSprite(item.color || '#00fbff', 20, 10, shape);
                    const img = document.createElement('img');
                    img.src = spriteData.image.toDataURL();
                    img.style.width = '60px';
                    img.style.height = '60px';
                    img.style.objectFit = 'contain';
                    visualContainer.appendChild(img);
                } else if (item.type === 'weapon') {
                    const color = item.color || '#ff0055';
                    visualContainer.innerHTML = `<div style="font-size: 35px; color: ${color}; text-shadow: 0 0 15px ${color};"><i class="fas fa-crosshairs"></i></div>`;
                } else if (item.type === 'trail') {
                    const color = item.color || '#00fbff';
                    visualContainer.innerHTML = `<div style="font-size: 40px; color: ${color}; text-shadow: 0 0 15px ${color};"><i class="fas fa-wind"></i></div>`;
                } else if (item.type === 'skin') {
                    const color = item.color || '#fff';
                    const name = (item.name || '').toLowerCase();
                    let shape = 'circle';
                    if (name.includes('tank')) shape = 'square';
                    else if (name.includes('speed')) shape = 'triangle';
                    else if (name.includes('interceptor')) shape = 'interceptor';
                    else if (name.includes('cruiser') || name.includes('bomber')) shape = 'bomber';
                    else if (name.includes('stealth')) shape = 'stealth';
                    const spriteData = createNeonSprite(color, 20, 10, shape);
                    const img = document.createElement('img');
                    img.src = spriteData.image.toDataURL();
                    img.style.width = '60px';
                    img.style.height = '60px';
                    img.style.objectFit = 'contain';
                    visualContainer.appendChild(img);
                } else if (item.type === 'powerup') {
                    let icon = 'fa-bolt';
                    const name = (item.name || '').toLowerCase();
                    if (name.includes('magnet')) icon = 'fa-magnet';
                    else if (name.includes('xp') || name.includes('experience')) icon = 'fa-angle-double-up';
                    else if (name.includes('health') || name.includes('repair')) icon = 'fa-heart';
                    else if (name.includes('shield')) icon = 'fa-shield-alt';
                    
                    visualContainer.innerHTML = `<div style="font-size: 30px; color: #ffd700; text-shadow: 0 0 10px #ffd700;"><i class="fas ${icon}"></i></div>`;
                } else if (item.type === 'avatar') {
                    const img = document.createElement('img');
                    img.src = item.imageUrl;
                    img.style.width = '60px';
                    img.style.height = '60px';
                    img.style.borderRadius = '50%';
                    img.style.border = '2px solid var(--cyber-blue)';
                    img.style.boxShadow = '0 0 10px rgba(0, 251, 255, 0.5)';
                    img.style.objectFit = 'cover';
                    visualContainer.appendChild(img);
                }

                card.appendChild(visualContainer);
                
                const infoDiv = document.createElement('div');
                infoDiv.innerHTML = `
                    <div class="item-name">${item.name || 'Unknown Item'}</div>
                    <div class="item-type">${(item.type || 'unknown').toUpperCase()}</div>
                    <button onclick="equipItem('${item._id}')" class="equip-btn">
                        ${slot.isEquipped ? 'EQUIPPED' : 'EQUIP'}
                    </button>
                `;
                card.appendChild(infoDiv);
                
                grid.appendChild(card);
            } catch (err) {
                console.error("Error rendering inventory item:", err);
            }
        });
    }

    async function equipItem(itemId) {
        try {
            // Find the item to check its type
            // Ensure we handle cases where item might be null (deleted item)
            const slot = currentUser.inventory.find(s => s.item && s.item._id === itemId);
            
            if (!slot || !slot.item) {
                console.error('Item not found in inventory:', itemId);
                return;
            }

            let res;
            if (slot.item.type === 'avatar') {
                res = await fetch('/api/user/equip-avatar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ itemId })
                });
            } else {
                res = await fetch('/api/shop/equip', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ itemId })
                });
            }
            
            if (res.ok) {
                const data = await res.json();
                
                // Update local user state
                if (slot.item.type === 'avatar') {
                    currentUser.avatar = slot.item.imageUrl;
                    
                    // Update all avatar images in the DOM immediately
                    document.querySelectorAll('.profile-avatar-img').forEach(img => {
                        img.src = currentUser.avatar;
                    });
                    
                    const menuAvatar = document.getElementById('menu-avatar-img');
                    if (menuAvatar) menuAvatar.src = currentUser.avatar;

                    const mainMenuAvatar = document.getElementById('main-menu-avatar');
                    if (mainMenuAvatar) mainMenuAvatar.src = currentUser.avatar;

                    const dockProfileAvatar = document.getElementById('dock-profile-avatar');
                    if (dockProfileAvatar) dockProfileAvatar.src = currentUser.avatar;
                    
                    const profilePreview = document.getElementById('profile-avatar-preview');
                    if (profilePreview) profilePreview.src = currentUser.avatar;

                    // Update leaderboard if visible
                    if (document.getElementById('leaderboard-modal') && !document.getElementById('leaderboard-modal').classList.contains('hidden')) {
                        loadLeaderboard();
                    }
                }

                await refreshInventoryUI();
                
                // Update player state immediately if game is running
                if (gameRunning && slot.item.type !== 'avatar') {
                    if (slot.item.type === 'ship') {
                        player.baseColor = slot.item.color.toLowerCase().trim();
                        player.color = player.baseColor;
                        const name = slot.item.name.toLowerCase();
                        if (name.includes('tank')) player.shape = 'square';
                        else if (name.includes('speed')) player.shape = 'triangle';
                        else if (name.includes('interceptor')) player.shape = 'interceptor';
                        else if (name.includes('cruiser') || name.includes('bomber')) player.shape = 'bomber';
                        else if (name.includes('stealth')) player.shape = 'stealth';
                        else player.shape = 'circle';
                    } else if (slot.item.type === 'trail') {
                        player.trailColor = slot.item.color.toLowerCase().trim();
                    }
                }
                
                showSystemAlert(Loc.t('shop.equipped') || 'Item Equipped!', 'SUCCESS');
            } else {
                const err = await res.json();
                showSystemAlert(err.message || err.error || 'Failed to equip item', 'ERROR');
            }
        } catch (err) {
            console.error('Equip failed:', err);
            showSystemAlert('Connection Error: ' + (err.message || 'Unknown'), 'ERROR');
        }
    }

    let draggedElement = null;
    let dragOffset = { x: 0, y: 0 };

    function startHUDEditor() {
        closeSettings();
        isEditingHUD = true;
        
        // Ensure clean state (remove paused/game-over classes that hide controls)
        document.body.classList.remove('paused', 'game-over');
        
        document.getElementById('hud-editor').classList.remove('hidden');
        document.getElementById('hud-editor').style.display = 'block';
        
        // Ensure game wrapper is visible so controls can be seen
        const gameWrapper = document.getElementById('game-wrapper');
        if(gameWrapper.classList.contains('hidden')) {
            gameWrapper.classList.remove('hidden');
            gameWrapper.dataset.wasHidden = 'true'; // Remember it was hidden
        }
        
        // Hide main menu if visible to avoid clutter
        const mainMenu = document.getElementById('main-menu');
        if(!mainMenu.classList.contains('hidden')) {
            mainMenu.classList.add('hidden');
            mainMenu.dataset.wasVisible = 'true';
        }

        // Force show mobile controls for editing
        const mobileControls = document.getElementById('mobile-controls');
        mobileControls.classList.add('hud-editing');
        mobileControls.style.display = 'block';
        mobileControls.style.pointerEvents = 'none'; // Container should not block clicks
        mobileControls.style.zIndex = '30002'; 
        
        // Make elements draggable
        const draggables = [
            { id: 'joystick-zone', label: Loc.t('hud.joystick') },
            { id: 'mobile-dash-btn', label: Loc.t('game.dash') },
            { id: 'mobile-overdrive-btn', label: Loc.t('game.ult') }
        ];

        draggables.forEach(item => {
            const el = document.getElementById(item.id);
            if(el) {
                el.classList.add('hud-draggable');
                el.style.pointerEvents = 'auto'; // Enable clicks on children
                el.style.border = '2px dashed var(--cyber-blue)';
                el.style.backgroundColor = 'rgba(0, 255, 0, 0.15)';
                el.style.boxShadow = '0 0 15px rgba(0, 255, 0, 0.2)';
                el.style.zIndex = '30006'; // Bring above overlay
                
                // Force visibility for editing
                el.style.display = 'flex';
                el.style.opacity = '1';
                el.style.visibility = 'visible';
                
                // Add Label
                let label = el.querySelector('.hud-label');
                if(!label) {
                    label = document.createElement('div');
                    label.className = 'hud-label';
                    label.innerText = item.label;
                    label.style.position = 'absolute';
                    label.style.top = '50%';
                    label.style.left = '50%';
                    label.style.transform = 'translate(-50%, -50%)';
                    label.style.color = 'var(--cyber-blue)';
                    label.style.fontWeight = 'bold';
                    label.style.fontFamily = 'monospace';
                    label.style.pointerEvents = 'none';
                    label.style.textShadow = '0 0 5px #000';
                    label.style.whiteSpace = 'nowrap';
                    el.appendChild(label);
                }

                // Add Center Marker for Joystick
                if (item.id === 'joystick-zone') {
                    let marker = el.querySelector('.hud-marker');
                    if(!marker) {
                        marker = document.createElement('div');
                        marker.className = 'hud-marker';
                        marker.style.position = 'absolute';
                        marker.style.top = '50%';
                        marker.style.left = '50%';
                        marker.style.width = '10px';
                        marker.style.height = '10px';
                        marker.style.background = 'var(--cyber-blue)';
                        marker.style.borderRadius = '50%';
                        marker.style.transform = 'translate(-50%, -50%)';
                        marker.style.pointerEvents = 'none';
                        marker.style.opacity = '0.5';
                        el.appendChild(marker);
                    }
                }
            }
        });

        // Add event listeners for dragging
        document.addEventListener('mousedown', onHUDDragStart);
        document.addEventListener('mousemove', onHUDDragMove);
        document.addEventListener('mouseup', onHUDDragEnd);
        document.addEventListener('touchstart', onHUDDragStart, {passive: false});
        document.addEventListener('touchmove', onHUDDragMove, {passive: false});
        document.addEventListener('touchend', onHUDDragEnd);
    }

    function cancelHUDEditor() {
        isEditingHUD = false;
        document.getElementById('hud-editor').classList.add('hidden');
        document.getElementById('hud-editor').style.display = 'none';
        
        // Restore game wrapper state
        const gameWrapper = document.getElementById('game-wrapper');
        if(gameWrapper.dataset.wasHidden === 'true') {
            gameWrapper.classList.add('hidden');
            delete gameWrapper.dataset.wasHidden;
        }
        
        // Restore main menu state
        const mainMenu = document.getElementById('main-menu');
        if(mainMenu.dataset.wasVisible === 'true') {
            mainMenu.classList.remove('hidden');
            delete mainMenu.dataset.wasVisible;
        }

        // Revert styles
        const draggables = ['joystick-zone', 'mobile-dash-btn', 'mobile-overdrive-btn'];
        draggables.forEach(id => {
            const el = document.getElementById(id);
            if(el) {
                el.classList.remove('hud-draggable');
                el.style.border = '';
                el.style.backgroundColor = '';
                el.style.boxShadow = '';
                el.style.zIndex = '';
                
                // Remove label
                const label = el.querySelector('.hud-label');
                if(label) label.remove();

                // Remove marker
                const marker = el.querySelector('.hud-marker');
                if(marker) marker.remove();
                
                // Reset display to default logic
                if(id === 'mobile-overdrive-btn') {
                    // Only show if actually active in game
                    el.style.display = (gameRunning && overdrive >= MAX_OVERDRIVE) ? 'flex' : 'none';
                } else if (id === 'mobile-dash-btn') {
                    el.style.display = 'flex';
                }
            }
        });

        // Hide mobile controls if not playing
        const mobileControls = document.getElementById('mobile-controls');
        mobileControls.style.zIndex = ''; // Reset z-index
        if (!gameRunning || controlMode !== 'touch') {
            mobileControls.style.display = 'none';
            mobileControls.style.pointerEvents = 'none';
        } else {
            mobileControls.style.display = 'block';
            mobileControls.style.pointerEvents = 'auto';
        }

        // Remove listeners
        document.removeEventListener('mousedown', onHUDDragStart);
        document.removeEventListener('mousemove', onHUDDragMove);
        document.removeEventListener('mouseup', onHUDDragEnd);
        document.removeEventListener('touchstart', onHUDDragStart);
        document.removeEventListener('touchmove', onHUDDragMove);
        document.removeEventListener('touchend', onHUDDragEnd);
        
        // Re-apply saved layout to undo changes
        applyHUDLayout();
        openSettings();
    }

    function saveHUDLayout() {
        const layout = {};
        const draggables = ['joystick-zone', 'mobile-dash-btn', 'mobile-overdrive-btn'];
        
        draggables.forEach(id => {
            const el = document.getElementById(id);
            if(el) {
                const rect = el.getBoundingClientRect();
                const parentRect = el.parentElement.getBoundingClientRect();
                
                // Sanity check: Don't save if dimensions are zero
                if (rect.width === 0 || rect.height === 0) return;

                const leftPercent = (el.offsetLeft / parentRect.width) * 100;
                const topPercent = (el.offsetTop / parentRect.height) * 100;
                
                layout[id] = { left: leftPercent, top: topPercent };
            }
        });
        
        localStorage.setItem('hudLayout', JSON.stringify(layout));

        // Save to Server if Logged In
        if (isLoggedIn) {
            fetch('/api/user/hud-layout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layout: layout })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    console.log('HUD Layout saved to cloud');
                    // Update local user object so we don't need to refresh
                    if(currentUser) currentUser.hudLayout = layout;
                }
            })
            .catch(err => console.error('Failed to save HUD layout to cloud', err));
        }
        
        // Cleanup (Same as cancel but without re-applying old layout)
        isEditingHUD = false;
        document.getElementById('hud-editor').classList.add('hidden');
        document.getElementById('hud-editor').style.display = 'none';
        
        const gameWrapper = document.getElementById('game-wrapper');
        if(gameWrapper.dataset.wasHidden === 'true') {
            gameWrapper.classList.add('hidden');
            delete gameWrapper.dataset.wasHidden;
        }
        
        const mainMenu = document.getElementById('main-menu');
        if(mainMenu.dataset.wasVisible === 'true') {
            mainMenu.classList.remove('hidden');
            delete mainMenu.dataset.wasVisible;
        }

        draggables.forEach(id => {
            const el = document.getElementById(id);
            if(el) {
                el.classList.remove('hud-draggable');
                el.style.border = '';
                el.style.backgroundColor = '';
                el.style.boxShadow = '';
                el.style.zIndex = '';
                
                const label = el.querySelector('.hud-label');
                if(label) label.remove();
                const marker = el.querySelector('.hud-marker');
                if(marker) marker.remove();

                if(id === 'mobile-overdrive-btn') {
                    el.style.display = (gameRunning && overdrive >= MAX_OVERDRIVE) ? 'flex' : 'none';
                } else if (id === 'mobile-dash-btn') {
                    el.style.display = 'flex';
                }
            }
        });

        const mobileControls = document.getElementById('mobile-controls');
        mobileControls.style.zIndex = ''; 
        if (!gameRunning || controlMode !== 'touch') {
            mobileControls.style.display = 'none';
            mobileControls.style.pointerEvents = 'none';
        } else {
            mobileControls.style.display = 'block';
            mobileControls.style.pointerEvents = 'auto';
        }

        document.removeEventListener('mousedown', onHUDDragStart);
        document.removeEventListener('mousemove', onHUDDragMove);
        document.removeEventListener('mouseup', onHUDDragEnd);
        document.removeEventListener('touchstart', onHUDDragStart);
        document.removeEventListener('touchmove', onHUDDragMove);
        document.removeEventListener('touchend', onHUDDragEnd);
        
        openSettings();
    }

    function resetHUDLayout() {
        // Removed confirm dialog to avoid WebView issues
        localStorage.removeItem('hudLayout');

        // Reset on Server if Logged In
        if (isLoggedIn) {
            fetch('/api/user/hud-layout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ layout: null }) // Send null to reset
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    console.log('HUD Layout reset on cloud');
                    if(currentUser) currentUser.hudLayout = null;
                }
            })
            .catch(err => console.error('Failed to reset HUD layout on cloud', err));
        }
        
        ['joystick-zone', 'mobile-dash-btn', 'mobile-overdrive-btn'].forEach(id => {
            const el = document.getElementById(id);
            if(el) {
                // Completely wipe inline styles to revert to CSS class defaults
                el.style.cssText = '';
                
                // Re-apply display:flex if we are in editor mode, otherwise respect game state
                if (isEditingHUD) {
                    el.style.display = 'flex';
                    // Re-apply editor visual styles
                    el.style.border = '2px dashed var(--cyber-blue)';
                    el.style.backgroundColor = 'rgba(0, 255, 0, 0.15)';
                    el.style.boxShadow = '0 0 15px rgba(0, 255, 0, 0.2)';
                    el.style.zIndex = '30006';
                } else {
                    // If not editing, let CSS or game logic handle display
                    if (id === 'mobile-overdrive-btn') el.style.display = 'none';
                }
                
                // Force reflow
                void el.offsetWidth;
            }
        });
        
        // Show a non-blocking toast or just log
        console.log('HUD Layout Reset');
        // Optional: Visual feedback
        const toolbar = document.getElementById('hud-toolbar');
        if(toolbar) {
            const originalText = toolbar.innerHTML;
            const msg = document.createElement('div');
            msg.innerText = Loc.t('hud.reset_complete');
            msg.style.color = 'var(--cyber-blue)';
            msg.style.background = '#000';
            msg.style.padding = '10px';
            msg.style.position = 'absolute';
            msg.style.top = '100%';
            toolbar.appendChild(msg);
            setTimeout(() => msg.remove(), 2000);
        }
    }

    function applyHUDLayout() {
        let layout = null;

        // Priority 1: Server Data (if logged in)
        if (currentUser && currentUser.hudLayout) {
            layout = currentUser.hudLayout;
            console.log('Loaded HUD Layout from Cloud');
        } 
        // Priority 2: Local Storage (Guest or fallback)
        else {
            const saved = localStorage.getItem('hudLayout');
            if (saved) {
                try {
                    layout = JSON.parse(saved);
                    console.log('Loaded HUD Layout from LocalStorage');
                } catch(e) {
                    console.error('Error parsing local HUD layout', e);
                }
            }
        }

        if(layout) {
            try {
                for (const [id, pos] of Object.entries(layout)) {
                    const el = document.getElementById(id);
                    if(el) {
                        // Sanity Check: If both are 0 for buttons, it's likely a bug
                        if (id !== 'joystick-zone' && pos.left < 1 && pos.top < 1) {
                            continue; 
                        }

                        el.style.bottom = 'auto';
                        el.style.right = 'auto';
                        el.style.left = pos.left + '%';
                        el.style.top = pos.top + '%';
                    }
                }
            } catch(e) {
                console.error('Error applying HUD layout', e);
            }
        }
    }

    function onHUDDragStart(e) {
        if(!isEditingHUD) return;
        if(e.target.closest('#hud-toolbar')) return;

        const target = e.target.closest('.hud-draggable'); 
        if(target) {
            if(e.cancelable) e.preventDefault();
            draggedElement = target;
            draggedElement.style.zIndex = '30010';
            
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            
            const rect = draggedElement.getBoundingClientRect();
            dragOffset.x = clientX - rect.left;
            dragOffset.y = clientY - rect.top;
        }
    }

    function onHUDDragMove(e) {
        if(!isEditingHUD || !draggedElement) return;
        if(e.cancelable) e.preventDefault();
        
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
        
        const parent = draggedElement.parentElement;
        const parentRect = parent.getBoundingClientRect();
        
        let newX = clientX - dragOffset.x - parentRect.left;
        let newY = clientY - dragOffset.y - parentRect.top;
        
        // Constraint: Prevent buttons from going to the top 20% of screen
        if (draggedElement.id !== 'joystick-zone') {
            const topLimit = parentRect.height * 0.2;
            if (newY < topLimit) newY = topLimit;
        }
        
        // Constrain to screen bounds
        newX = Math.max(0, Math.min(newX, parentRect.width - draggedElement.offsetWidth));
        newY = Math.max(0, Math.min(newY, parentRect.height - draggedElement.offsetHeight));
        
        draggedElement.style.left = newX + 'px';
        draggedElement.style.top = newY + 'px';
        draggedElement.style.bottom = 'auto';
        draggedElement.style.right = 'auto';
    }

    function onHUDDragEnd(e) {
        if(draggedElement) {
            // Reset z-index but keep it high enough to be seen
            draggedElement.style.zIndex = isEditingHUD ? '30006' : ''; 
        }
        draggedElement = null;
    }

    // Apply layout on load
    window.addEventListener('load', applyHUDLayout);

  </script>
