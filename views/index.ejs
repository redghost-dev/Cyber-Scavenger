    function spawnCollectibles(count = 1) {
      if (canvas.width < 100) return; // Prevention: Don't spawn on invalid canvas size
      for (let i = 0; i < count; i++) {
        const dropRate = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.coinDropRate : 0.1;
        const hRate = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.healDropRate || 0.15) : 0.15;
        const roll = Math.random();
        
        let type = 'normal';
        let color = '#0ff';
        
        // Very rare chance to drop a direct heal from an enemy
        if (roll < (hRate * 0.05)) { 
          type = 'heal';
          color = '#ff0055'; // Neon Pink (Heal)
        } else if (roll < dropRate * 0.5) {
          type = 'coin';
          color = '#ffd700'; // Gold Color
        } else if (roll < dropRate) {
          type = 'super';
          color = '#e5e4e2'; // Silver Nova
        }

        collectibles.push({
          x: Math.random() * (canvas.width - 20) + 10,
          y: Math.random() * (canvas.height - 20) + 10,
          radius: 6,
          color: color,
          pulse: Math.random() * Math.PI * 2,
          type: type
        });
      }
    }

    function spawnPowerup() {
      const hRate = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.healDropRate || 0.25) : 0.25;
      
      const sW = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.shieldWeight || 1.0) : 1.0;
      const slW = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.slowWeight || 1.0) : 1.0;
      const mW = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.magnetWeight || 1.0) : 1.0;
      const nW = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.nukeWeight || 1.0) : 1.0;
      const totalOtherWeights = sW + slW + mW + nW;

      // Weighted random
      const roll = Math.random();
      let type = 'shield';
      
      // If heal rate is 0.25, then heal is the top 25%
      if (roll < (1 - hRate)) {
          const subRoll = (roll / (1 - hRate)) * totalOtherWeights;
          
          if (subRoll < sW) type = 'shield';
          else if (subRoll < sW + slW) type = 'slow';
          else if (subRoll < sW + slW + mW) type = 'magnet';
          else type = 'nuke';
      } else {
          type = 'heal';
      }

      let color;
      if (type === 'shield') color = '#00f'; 
      if (type === 'slow') color = '#a0f'; 
      if (type === 'magnet') color = '#ff0'; 
      if (type === 'nuke') color = '#f00';
      if (type === 'heal') color = '#ff0055'; // Neon Pink for Heal visibility

      powerups.push({
        x: Math.random() * (canvas.width - 40) + 20,
        y: Math.random() * (canvas.height - 40) + 20,
        radius: 10, // Slightly larger
        color: color,
        type: type,
        life: 8000 // Last longer to be seen
      });
    }

    function activatePowerup(type) {
      Sound.powerup();
      if (type === 'shield') {
        player.shield = true;
        player.color = '#00f';
      } else if (type === 'slow') {
        activeEffects.push({ type: 'slow', duration: 5000 });
      } else if (type === 'magnet') {
        player.magnet = true;
        activeEffects.push({ type: 'magnet', duration: 8000 });
      } else if (type === 'nuke') {
        createShockwave(canvas.width/2, canvas.height/2);
        triggerShake(500, 20);
        enemies.forEach(e => {
           createParticles(e.x, e.y, e.color, 10, 5);
           score += Math.floor(10 * player.scoreMultiplier);
        });
        enemies = [];
        uiScore.innerText = Loc.t('game.score') + ': ' + score;
        spawnFloatingText(player.x, player.y, "NUKE!", "#f00", 40);
      } else if (type === 'heal') {
        if (player.hp < player.maxHp) {
           player.hp++;
           updateHpUI();
           spawnFloatingText(player.x, player.y, "+1 HP", "var(--cyber-blue)", 30);
        } else {
           score += 500;
           uiScore.innerText = Loc.t('game.score') + ': ' + score;
           spawnFloatingText(player.x, player.y, "+500 PTS", "#ff0", 30);
        }
      }
      updatePowerupUI();
    }

    function updatePowerupUI() {
      let html = '';
      if (player.shield) {
        html += `<div class="powerup-item">
          <span class="powerup-icon" style="color:var(--cyber-blue);"></span>
          <span class="powerup-label">SHIELD</span>
        </div>`;
      }
      activeEffects.forEach(eff => {
        let color = eff.type === 'slow' ? '#a0f' : '#ff0';
        let label = eff.type.toUpperCase();
        let seconds = (eff.duration / 1000).toFixed(1);
        html += `<div class="powerup-item">
          <span class="powerup-icon" style="color:${color};"></span>
          <span class="powerup-label">${label} ${seconds}s</span>
        </div>`;
      });
      uiPowerups.innerHTML = html;
    }

    // --- BOSS SPAWN LOGIC ---
    // Moved to public/js/game_modules/boss_manager.js
    // Mapped via window.spawnBoss -> BossManager.spawn()


    function spawnEnemy() {
      if (boss) return; 

      const settings = difficultySettings[difficulty];
      const edge = Math.floor(Math.random() * 4);
      let x, y;
      switch(edge) {
        case 0: x = Math.random() * canvas.width; y = -20; break;
        case 1: x = canvas.width + 20; y = Math.random() * canvas.height; break;
        case 2: x = Math.random() * canvas.width; y = canvas.height + 20; break;
        case 3: x = -20; y = Math.random() * canvas.height; break;
      }

      const typeRoll = Math.random();
      let type = 'normal';
      let radius = 8;
      
      // Dynamic difficulty: Speed increases with Level
      // Start slightly faster and increase more aggressively
      const speedMult = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.enemySpeedMultiplier : 0.25;
      let baseSpeed = 1.2 + (player.level * speedMult);
      let speed = baseSpeed * settings.speedMult;
      let color = '#f00';

      // Enemy Types unlock at higher levels
      let style = 'interceptor'; // Default style

      if (player.level >= 2 && typeRoll > 0.8) {
        type = 'chaser';
        radius = 5;
        speed *= 1.5;
        color = '#ff0055';
        style = 'stealth';
      } else if (player.level >= 3 && typeRoll < 0.15) {
        type = 'tank';
        radius = 15;
        speed *= 0.6;
        color = '#800000';
        style = 'bomber';
      } else if (player.level >= 4 && typeRoll > 0.9) {
        type = 'sniper';
        radius = 8;
        speed *= 0.8;
        color = '#fff';
        style = 'interceptor'; // Snipers look like standard ships but white
      }

      enemies.push({ x, y, radius, color, speed, type, style, shootTimer: 0 });
    }

    function createParticles(x, y, color, count = 8, speed = 4) {
      for (let i = 0; i < count; i++) {
        particles.push({
          x: x,
          y: y,
          dx: (Math.random() - 0.5) * speed,
          dy: (Math.random() - 0.5) * speed,
          life: 1,
          color: color,
          size: Math.random() * 3 + 1
        });
      }
    }

    function createShockwave(x, y) {
      shockwaves.push({ x, y, radius: 1, alpha: 1 });
    }

    function startGame(fullscreen = false) {
      try {
          // Close all possible overlays first
          closeAllModals();
          
          const dock = document.getElementById('global-dock-menu');
          if (dock) dock.style.display = 'none';
          
          if (fullscreen) {
            toggleFullscreen();
          }
          
          // --- PERFORMANCE OPTIMIZATION: PRE-RENDER ASSETS ---
          if (Object.keys(SpriteCache).length === 0) {
              preRenderAssets();
          }
          // ---------------------------------------------------

          // Show game wrapper immediately
          const configScreen = document.getElementById('start-screen');
          if (configScreen) {
              configScreen.classList.add('hidden');
              configScreen.style.display = 'none';
          }
          
          gameWrapper.classList.remove('hidden'); 
          gameWrapper.style.display = 'block';
          
          if (gameContainer) gameContainer.style.display = 'block';

          // Stop Global UI Effects (Background Stars, Ripples) for performance
          if (typeof toggleGlobalEffects === 'function') toggleGlobalEffects(false);
          
          // Delay to ensure browser has updated layout
          setTimeout(async () => {
              try {
                  await refreshInventory(); 
                  resizeCanvas(); 
                  resetGameState(); 
                  
                  // Double check canvas size
                  if (canvas.width < 100) resizeCanvas();
                  
                  gameRunning = true;
                  gamePaused = false;
                  document.body.classList.add('game-active');
                  document.body.classList.remove('paused', 'game-over');
                  
                  if (controlMode === 'touch' || isMobileDevice()) {
                      setControlMode('touch');
                      const mControls = document.getElementById('mobile-controls');
                      if(mControls) mControls.style.display = 'block';
                      if (fullscreenBtn) fullscreenBtn.style.display = 'block';
                  }

                  lastTime = performance.now();
                  animateGame(lastTime);
                  
                  console.log("Game Started Successfully");
              } catch (innerErr) {
                  console.error("Error during game initialization delay:", innerErr);
              }
          }, 100);
      } catch (err) {
          console.error("Critical error in startGame:", err);
          alert("Failed to start mission. Check console.");
      }
    }

    function resetGame() {
      startGame();
    }

    let hasRevived = false;
    let hasDoubledScore = false;

    function resetGameState() {
      survivalTime = 0;
      hasRevived = false;
      hasDoubledScore = false;
      score = 0;
      scoreSent = 0;
      coinsEarned = 0;
      coinsSent = 0;
      combo = 1;
      comboTimer = 0;
      bossKillCounter = 0;
      bossLevel = 1;
      bossMode = 'score'; // Reset mode to score for new game
      bossSpawnThreshold = (gameConfig && gameConfig.gameplay && gameConfig.gameplay.bossInitialScore) ? gameConfig.gameplay.bossInitialScore : 5000;
      boss = null;
      overdrive = 0;
      isOverdriveActive = false;
    updateOverdriveUI();
      uiScore.innerText = Loc.t('game.score') + ': 0';
      uiCoins.innerText = 'COINS: 0';
      uiDash.innerText = Loc.t('game.dash') + ': READY';
      uiDash.style.color = 'var(--cyber-blue)';
      uiPowerups.innerHTML = '';
      uiCombo.style.display = 'none';
      uiBossHp.style.display = 'none';
      
      player.x = canvas.width / 2;
      player.y = canvas.height / 2;
      player.dashCooldown = 0;
      player.isDashing = false;
      player.shield = false;
      player.magnet = false;
      player.baseColor = '#00fbff'; // Default base color
      player.color = player.baseColor;
      player.trailColor = null; // Default no trail
      player.shape = 'circle'; // Default shape

      // Apply Equipped Skin & Trail
      if (typeof currentUser !== 'undefined' && currentUser && currentUser.inventory) {
          const equippedShip = currentUser.inventory.find(slot => slot.isEquipped && slot.item && slot.item.type === 'ship');
          if (equippedShip && equippedShip.item.color) {
              player.baseColor = equippedShip.item.color.toLowerCase().trim();
              player.color = player.baseColor;
              
              // Determine shape based on name
              const name = equippedShip.item.name.toLowerCase().trim();
              if (name.includes('tank')) player.shape = 'square';
              else if (name.includes('speed')) player.shape = 'triangle';
              else if (name.includes('interceptor')) player.shape = 'interceptor';
              else if (name.includes('cruiser') || name.includes('bomber')) player.shape = 'bomber';
              else if (name.includes('stealth')) player.shape = 'stealth';
              else player.shape = 'circle';
          }
          
          const equippedTrail = currentUser.inventory.find(slot => slot.isEquipped && slot.item && slot.item.type === 'trail');
          if (equippedTrail && equippedTrail.item.color) {
              player.trailColor = equippedTrail.item.color.toLowerCase().trim();
          }

          const equippedWeapon = currentUser.inventory.find(slot => slot.isEquipped && slot.item && slot.item.type === 'weapon');
          if (equippedWeapon) {
              player.equippedWeapon = {
                  name: equippedWeapon.item.name || '',
                  damage: equippedWeapon.item.stats ? (equippedWeapon.item.stats.damage || 1) : 1,
                  cooldownTime: equippedWeapon.item.stats ? (equippedWeapon.item.stats.speed * 1000 || 1000) : 1000,
                  color: equippedWeapon.item.color || '#ff0055',
                  cooldown: 0
              };
          } else {
              player.equippedWeapon = null;
          }
      }

      player.baseSpeed = 5;
      player.speed = 5;
      player.level = 1;
      player.xp = 0;
      player.xpToNextLevel = 100;
      player.scoreMultiplier = 1;
      player.pulseNova = false;
      player.magnetRange = 160;
      player.drones = [];
      
      // Health System
      const settings = difficultySettings[difficulty];
      player.maxHp = difficulty === 'easy' ? 5 : (difficulty === 'medium' ? 3 : 1);
      player.hp = player.maxHp;
      player.invincibilityTimer = 0;
      updateHpUI();
      
      activeUpgrades = { dash_cool: 0, dash_dur: 0, shield_dur: 0 };
      uiLevelIndicator.innerText = 'LVL 1';
      uiXpFill.style.width = '0%';
      
      collectibles = [];
      friendlyProjectiles = [];
      enemies = [];
      particles = [];
      shockwaves = [];
      powerups = [];
      activeEffects = [];
      projectiles = [];
      floatingTexts = [];
      spawnCollectibles(3);
    }

    function updateHpUI() {
      uiHpContainer.innerHTML = '';
      for (let i = 0; i < player.maxHp; i++) {
        const heart = document.createElement('div');
        heart.className = 'hp-heart' + (i < player.hp ? '' : ' hp-lost');
        uiHpContainer.appendChild(heart);
      }
    }

    function spawnFloatingText(x, y, text, color = '#fff', size = 20) {
      floatingTexts.push({
        x, y, text, color, size,
        life: 1.0,
        dy: -1
      });
    }

    function showInterstitialIfReady() {
        if (!gameConfig || !gameConfig.ads || !gameConfig.ads.interstitialEnabled) return;
        
        const now = Date.now();
        const intervalMs = (gameConfig.ads.interstitialInterval || 300) * 1000;
        
        if (now - lastInterstitialTime > intervalMs) {
            if (window.Android && window.Android.showInterstitialAd) {
                window.Android.showInterstitialAd();
            } else {
                console.log('Interstitial Ad (Simulated)');
            }
            lastInterstitialTime = now;
        }
    }

    function gameOver() {
      Sound.gameOver();
      gameRunning = false;
      document.body.classList.remove('game-active');
      document.body.classList.add('game-over'); // Hide controls via CSS
      cancelAnimationFrame(animationId);
      
      // Animate score counting
      let currentDisplayScore = 0;
      let currentDisplayCoins = 0;
      const step = Math.max(1, Math.floor(score / 30));
      const coinStep = Math.max(1, Math.floor(coinsEarned / 30));
      
      const scoreInterval = setInterval(() => {
          let done = true;
          
          if (currentDisplayScore < score) {
              currentDisplayScore += step;
              if (currentDisplayScore > score) currentDisplayScore = score;
              finalScoreDisplay.innerText = currentDisplayScore;
              done = false;
          }

          if (currentDisplayCoins < coinsEarned) {
              currentDisplayCoins += coinStep;
              if (currentDisplayCoins > coinsEarned) currentDisplayCoins = coinsEarned;
              if (finalCoinsDisplay) finalCoinsDisplay.innerText = currentDisplayCoins;
              done = false;
          }

          if (done) {
              finalScoreDisplay.innerText = score;
              if (finalCoinsDisplay) finalCoinsDisplay.innerText = coinsEarned;
              clearInterval(scoreInterval);
              
              if (score > highScore) {
                  highScore = score;
                  if (!isLoggedIn) {
                      localStorage.setItem('cyberScavengerHighScore', highScore);
                  }
                  uiHighScore.innerText = 'HIGH SCORE: ' + highScore;
                  newHighScoreDisplay.style.display = 'block';
                  newHighScoreDisplay.classList.add('pulse-glow');
              } else {
                  newHighScoreDisplay.style.display = 'none';
              }
          } else {
              currentDisplayScore += step;
              if (currentDisplayScore > score) currentDisplayScore = score;
              finalScoreDisplay.innerText = currentDisplayScore;
          }
      }, 30);
      
      // Show Interstitial if ready
      showInterstitialIfReady();
      
      // Submit Score to Server if Logged In
      if (isLoggedIn) {
          const isFirstSubmit = (scoreSent === 0);
          const coinsToSubmit = coinsEarned - coinsSent;
          coinsSent = coinsEarned;
          
          const scoreToSubmit = score - scoreSent;
          scoreSent = score;

          fetch('/api/game/submit-score', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ 
                  score: scoreToSubmit,
                  coins: coinsToSubmit,
                  finalScore: score, // Send total for high score check
                  isFirstSubmit: isFirstSubmit
              })
          })
          .then(res => res.json())
          .then(data => {
              if (data.success) {
                  console.log('Score saved:', data.newStats);
                  
                  // Update Global Wallet Indicators immediately
                  if (data.wallet) {
                      currentUser.wallet = data.wallet;
                      updateWalletUI();
                  }

                  // Ensure UI is in sync
                  if (data.newStats.highScore > highScore) {
                      highScore = data.newStats.highScore;
                      uiHighScore.innerText = 'HIGH SCORE: ' + highScore;
                  }
              }
          })
          .catch(err => console.error('Score submission failed:', err));
      }
      
      gameOverScreen.classList.remove('hidden');
      gameOverScreen.style.display = 'flex';
      
      // Show Revive Button if not used yet and revive is enabled in config
      const reviveContainer = document.getElementById('revive-container');
      const doubleRewardContainer = document.getElementById('double-reward-container');
      
      if (reviveContainer) {
          const reviveEnabled = gameConfig && gameConfig.ads && gameConfig.ads.rewards ? gameConfig.ads.rewards.reviveEnabled : true;
          // Only show if not revived and NOT doubled score
          if (!hasRevived && !hasDoubledScore && reviveEnabled) {
              reviveContainer.style.display = 'flex';
          } else {
              reviveContainer.style.display = 'none';
          }
      }

      // Show Double Reward Button if player earned some coins and hasn't doubled yet
      if (doubleRewardContainer) {
          if (score > 10 && !hasDoubledScore) { 
              const multiplier = Math.max(2, player.level);
              const btnSpan = doubleRewardContainer.querySelector('span[data-i18n="ad.double_reward"]');
              if (btnSpan) {
                  btnSpan.innerText = Loc.t('ad.double_reward').replace('{val}', multiplier);
              }
              doubleRewardContainer.style.display = 'flex';
          } else {
              doubleRewardContainer.style.display = 'none';
          }
      }
    }

    function update(deltaTime) {
      survivalTime += deltaTime;
      // Invincibility
      if (player.invincibilityTimer > 0) {
        player.invincibilityTimer -= deltaTime;
      }

      // Floating Texts
      for (let i = floatingTexts.length - 1; i >= 0; i--) {
        const t = floatingTexts[i];
        t.y += t.dy;
        t.life -= deltaTime * 0.001;
        if (t.life <= 0) floatingTexts.splice(i, 1);
      }

      // Pulse Nova (Passive)
      if (player.pulseNova) {
        player.pulseTimer += deltaTime;
        if (player.pulseTimer > 3000) {
          player.pulseTimer = 0;
          createShockwave(player.x, player.y);
          // Damage nearby enemies
          for (let i = enemies.length - 1; i >= 0; i--) {
            const e = enemies[i];
            if (Math.hypot(player.x - e.x, player.y - e.y) < 150) {
               createParticles(e.x, e.y, e.color, 10, 4);
               enemies.splice(i, 1);
               score += Math.floor(10 * player.scoreMultiplier);
               uiScore.innerText = Loc.t('game.score') + ': ' + score;
            }
          }
        }
      }

      // Screen Shake Decay
      if (shakeDuration > 0) {
        shakeDuration -= deltaTime;
        if (shakeDuration <= 0) shakeMagnitude = 0;
      }

      // Combo Logic
      if (comboTimer > 0) {
        comboTimer -= deltaTime;
        if (comboTimer <= 0) {
          combo = 1;
          uiCombo.style.display = 'none';
        }
      }

      // Overdrive Logic
      if (isOverdriveActive) {
        overdriveDuration -= deltaTime;
        overdrive = (overdriveDuration / 5000) * 100;
        
        if (overdriveDuration <= 0) {
          isOverdriveActive = false;
          overdrive = 0;
          player.color = player.shield ? '#00f' : player.baseColor;
        }
                updateOverdriveUI();
            }

      // Active Effects Management
      let slowFactor = isOverdriveActive ? 0.2 : 1; // Super slow mo in overdrive
      for (let i = activeEffects.length - 1; i >= 0; i--) {
        activeEffects[i].duration -= deltaTime;
        if (activeEffects[i].type === 'slow') slowFactor = 0.4;
        if (activeEffects[i].type === 'magnet') player.magnet = true;
        
        if (activeEffects[i].duration <= 0) {
          if (activeEffects[i].type === 'magnet') player.magnet = false;
          activeEffects.splice(i, 1);
          updatePowerupUI();
        }
      }

      // Drones Logic
      player.drones.forEach((d) => {
        d.angle += deltaTime * 0.002;
        d.cooldown -= deltaTime;
        
        if (d.cooldown <= 0) {
          let target = null;
          let minDst = 300;
          
          enemies.forEach(e => {
            const dst = Math.hypot(e.x - player.x, e.y - player.y);
            if (dst < minDst) {
              minDst = dst;
              target = e;
            }
          });
          
          if (!target && boss) {
             const dst = Math.hypot(boss.x - player.x, boss.y - player.y);
             if (dst < minDst) target = boss;
          }

          if (target) {
            d.cooldown = 800; 
            const droneX = player.x + Math.cos(d.angle) * 30;
            const droneY = player.y + Math.sin(d.angle) * 30;
            const angle = Math.atan2(target.y - droneY, target.x - droneX);
            
            friendlyProjectiles.push({
              x: droneX, y: droneY,
              dx: Math.cos(angle) * 8,
              dy: Math.sin(angle) * 8,
              radius: 3,
              color: '#0ff',
              damage: 1, // Drone base damage
              life: 2000
            });
            Sound.playTone(600, 'square', 0.05);
          }
        }
      });

      // Equipped Weapon Firing Logic
      if (player.equippedWeapon) {
        player.equippedWeapon.cooldown -= deltaTime;
        if (player.equippedWeapon.cooldown <= 0) {
          let target = null;
          let minDst = 400; // Weapons have slightly more range than drones
          
          enemies.forEach(e => {
            const dst = Math.hypot(e.x - player.x, e.y - player.y);
            if (dst < minDst) {
              minDst = dst;
              target = e;
            }
          });
          
          if (!target && boss) {
             const dst = Math.hypot(boss.x - player.x, boss.y - player.y);
             if (dst < minDst) target = boss;
          }

          if (target) {
            player.equippedWeapon.cooldown = player.equippedWeapon.cooldownTime || 1000;
            const angle = Math.atan2(target.y - player.y, target.x - player.x);
            
            // Check for Shotgun/Spread type
            if (player.equippedWeapon.name.toLowerCase().includes('spread')) {
                // Fire 5 pellets in a spread
                for (let i = -2; i <= 2; i++) {
                    const spreadAngle = angle + (i * 0.15); // Spread pellets
                    friendlyProjectiles.push({
                        x: player.x, y: player.y,
                        dx: Math.cos(spreadAngle) * (9 + Math.random() * 2), // Vary speed slightly
                        dy: Math.sin(spreadAngle) * (9 + Math.random() * 2),
                        radius: 2.5,
                        color: player.equippedWeapon.color,
                        damage: player.equippedWeapon.damage,
                        life: 1800,
                        isSpread: true,
                        pulse: 0
                    });
                }
                Sound.playTone(300, 'sawtooth', 0.15); // Heavier sound for shotgun
            } else {
                // Regular single shot
                friendlyProjectiles.push({
                    x: player.x, y: player.y,
                    dx: Math.cos(angle) * 10,
                    dy: Math.sin(angle) * 10,
                    radius: 4,
                    color: player.equippedWeapon.color,
                    damage: player.equippedWeapon.damage,
                    life: 2500
                });
                Sound.playTone(400, 'sawtooth', 0.1);
            }
          }
        }
      }

      // Friendly Projectiles
      for (let i = friendlyProjectiles.length - 1; i >= 0; i--) {
        const p = friendlyProjectiles[i];
        p.x += p.dx;
        p.y += p.dy;
        p.life -= deltaTime;
        
        // Pulse animation for spread weapons
        if (p.isSpread) {
            p.pulse = (p.pulse || 0) + deltaTime * 0.01;
        }
        
        if (p.life <= 0) {
          friendlyProjectiles.splice(i, 1);
          continue;
        }
        
        let hit = false;
        for (let j = enemies.length - 1; j >= 0; j--) {
          const e = enemies[j];
          if (Math.hypot(p.x - e.x, p.y - e.y) < e.radius + p.radius) {
            createParticles(e.x, e.y, e.color, 5, 3);
            enemies.splice(j, 1);
            
            // Score Update
            const killScore = Math.floor(10 * player.scoreMultiplier);
            score += killScore;
            
            // Boss Counter Logic - Only count if no boss is present
            if (!boss && bossMode === 'kills') {
                bossKillCounter++;
            }

            uiScore.innerText = Loc.t('game.score') + ': ' + score;
            hit = true;
            break;
          }
        }
        
        if (!hit && boss && Math.hypot(p.x - boss.x, p.y - boss.y) < boss.radius + p.radius) {
           if (boss.state === 'dying') {
               // Ignore hits during death anim
               hit = true; 
               // Still remove projectile to look clean
           } else {
               boss.hp -= p.damage || 1;
               uiBossHpFill.style.width = (boss.hp / boss.maxHp * 100) + '%';
               createParticles(p.x, p.y, p.color || '#f00', 3, 2);
               hit = true;
               if (boss.hp <= 0) {
                  if (boss.blueprint && boss.blueprint.death) {
                      boss.state = 'dying';
                      boss.deathTimer = 0;
                  } else {
                      finalizeBossDeath();
                  }
               }
           }
        }

        if (hit) friendlyProjectiles.splice(i, 1);
      }

      // Dash Logic
      if (player.dashCooldown > 0) player.dashCooldown -= deltaTime;
      if (player.dashDuration > 0) {
        player.dashDuration -= deltaTime;
        if (player.dashDuration <= 0) {
          player.isDashing = false;
          player.speed = player.baseSpeed;
        }
      }

      if (keys.Space && player.dashCooldown <= 0 && !player.isDashing) {
        Sound.dash();
        player.isDashing = true;
        player.dashDuration = 200 * (1 + activeUpgrades.dash_dur * 0.2);
        player.dashCooldown = 1000 * (Math.pow(0.9, activeUpgrades.dash_cool));
        player.speed = player.baseSpeed * 3;
        createShockwave(player.x, player.y);
        createParticles(player.x, player.y, '#0ff', 5, 2);
        triggerShake(200, 5);
      }

      // UI Update for Dash
      if (player.dashCooldown <= 0) {
        uiDash.innerText = Loc.t('game.dash') + ': READY';
        uiDash.style.color = 'var(--cyber-blue)';
        uiDash.style.textShadow = '0 0 10px var(--cyber-blue)';
      } else {
        uiDash.innerText = Loc.t('game.dash') + ': ' + (player.dashCooldown / 1000).toFixed(1) + 's';
        uiDash.style.color = '#555';
        uiDash.style.textShadow = 'none';
      }

      // Player Movement
      player.dx = 0;
      player.dy = 0;

      // CINEMATIC AUTOPILOT
      if (player.isCinematic) {
          // Slide to bottom-center ready position
          const targetX = canvas.width / 2;
          const targetY = canvas.height - 150;
          player.x += (targetX - player.x) * 0.08;
          player.y += (targetY - player.y) * 0.08;
          // Input skipped
      } else {

      // Keyboard
      if (keys.w || keys.ArrowUp) player.dy = -player.speed;
      if (keys.s || keys.ArrowDown) player.dy = player.speed;
      if (keys.a || keys.ArrowLeft) player.dx = -player.speed;
      if (keys.d || keys.ArrowRight) player.dx = player.speed;

      // Joystick Override
      if (joystickActive) {
        player.dx = joystickData.x * player.speed;
        player.dy = joystickData.y * player.speed;
      }

      // Mouse Override
      if (controlMode === 'mouse' && mouseActive) {
        const dx = mouseTarget.x - player.x;
        const dy = mouseTarget.y - player.y;
        const dist = Math.hypot(dx, dy);
        
        if (dist > 5) {
          const angle = Math.atan2(dy, dx);
          player.dx = Math.cos(angle) * player.speed;
          player.dy = Math.sin(angle) * player.speed;
        }
      }

      } // End Cinematic check
      
      // Overdrive Speed Boost
      if (isOverdriveActive) {
        player.dx *= 1.5;
        player.dy *= 1.5;
      }

      player.x += player.dx;
      player.y += player.dy;

      // Boundaries
      if (player.x < player.radius) player.x = player.radius;
      if (player.x > canvas.width - player.radius) player.x = canvas.width - player.radius;
      if (player.y < player.radius) player.y = player.radius;
      if (player.y > canvas.height - player.radius) player.y = canvas.height - player.radius;

      // Trail Effect
      if (player.isDashing || isOverdriveActive || (player.trailColor && (Math.abs(player.dx) > 0.1 || Math.abs(player.dy) > 0.1))) {
        let trailColor = 'rgba(0, 255, 255, 0.5)';
        
        if (isOverdriveActive) {
            trailColor = 'rgba(255, 0, 255, 0.5)';
        } else if (player.trailColor) {
            trailColor = player.trailColor;
        } else if (player.isDashing) {
             trailColor = 'rgba(0, 255, 255, 0.5)';
        }

        particles.push({
          x: player.x,
          y: player.y,
          dx: 0, dy: 0,
          life: 0.5,
          color: trailColor,
          size: player.radius * ((player.isDashing || isOverdriveActive) ? 1 : 0.6)
        });
      }

      // Collectibles
      collectibles.forEach((c, index) => {
        c.pulse += deltaTime * 0.005;
        
        // Magnet Effect
        let magnetActive = player.magnet || isOverdriveActive;
        let magnetRange = isOverdriveActive ? 350 : Math.min(player.magnetRange, 350); // Adjusted from 400
        let magnetStrength = 0.15; // Adjusted from 0.18

        // Mobile Assist: Passive weak magnet
        if (controlMode === 'touch' && !magnetActive) {
           magnetActive = true;
           magnetRange = 100; // Adjusted from 120
           magnetStrength = 0.04; // Adjusted from 0.05
        }

        if (magnetActive) {
          const dist = Math.hypot(player.x - c.x, player.y - c.y);
          if (dist < magnetRange) {
            c.x += (player.x - c.x) * magnetStrength;
            c.y += (player.y - c.y) * magnetStrength;
          }
        }

        const dist = Math.hypot(player.x - c.x, player.y - c.y);
        // Mobile Assist: Slightly larger pickup radius, but not too large
        const pickupRadius = controlMode === 'touch' ? (player.radius + c.radius + 2) : (player.radius + c.radius);

        if (dist < pickupRadius) {
          Sound.collect();
          const settings = difficultySettings[difficulty];
          const baseOrb = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.baseOrbScore : 1;
          const superOrb = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.superOrbScore : 10;
          const points = (c.type === 'super' ? superOrb : baseOrb) * combo * player.scoreMultiplier * settings.scoreMult;
          score += Math.floor(points);
          uiScore.innerText = Loc.t('game.score') + ': ' + score;

          // Super Orb special: High Reward
          if (c.type === 'super') {
             // Coin gain disabled per request
             spawnFloatingText(c.x, c.y, "SUPER!", "#c0c0c0", 25);
          }
          
          // Coin Item pickup
          if (c.type === 'coin') {
             const coinReward = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.coinsPerPickup || 1) : 1;
             coinsEarned += coinReward;
             uiCoins.innerText = 'COINS: ' + coinsEarned;
             uiCoins.style.transform = 'scale(1.2)';
             setTimeout(() => uiCoins.style.transform = 'scale(1)', 150);
             spawnFloatingText(c.x, c.y, `+${coinReward} COIN`, "#ffd700", 25);
          }

          // Heal Item pickup (Collectible version)
          if (c.type === 'heal') {
             if (player.hp < player.maxHp) {
                player.hp++;
                updateHpUI();
                spawnFloatingText(c.x, c.y, "+1 HP", "#ff0055", 30);
             } else {
                score += 500;
                uiScore.innerText = Loc.t('game.score') + ': ' + score;
                spawnFloatingText(c.x, c.y, "+500 PTS", "#ff0", 30);
             }
          }
          
          player.xp += (c.type === 'heal' ? 0 : (c.type === 'super' ? 20 : (c.type === 'coin' ? 10 : 5)));
          checkLevelUp();
          
          // Overdrive Fill
          if (!isOverdriveActive) {
            overdrive = Math.min(overdrive + 5, MAX_OVERDRIVE);
          }
                    updateOverdriveUI();
          
          // Combo Increase
          const cCap = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.comboCap : 5;
          const cDecay = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.comboDecayTime : 2500;
          combo = Math.min(combo + 1, cCap);
          comboTimer = cDecay;
          uiCombo.innerText = 'COMBO x' + combo;
          uiCombo.style.display = 'block';
          uiCombo.style.transform = 'scale(1.5)';
          setTimeout(() => uiCombo.style.transform = 'scale(1)', 100);

          let pColor = c.color;
          if (c.type === 'super') pColor = '#e5e4e2';
          else if (c.type === 'coin') pColor = '#ffd700';
          else if (c.type === 'heal') pColor = '#ff0055';

          createParticles(c.x, c.y, pColor, 10, 5);
          if (c.type === 'super') createShockwave(c.x, c.y);

          collectibles.splice(index, 1);
          spawnCollectibles(1);
          // Prevent exponential growth: Only spawn extra if count is low
          if (Math.random() > 0.7 && collectibles.length < 30) spawnCollectibles(1);
        }
      });

      // Powerups
      powerupSpawnTimer += deltaTime;
      const pInterval = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.powerupSpawnInterval || 10000) : 10000;
      const pChance = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.powerupChance || 0.5) : 0.5;
      
      if (powerupSpawnTimer > pInterval) { 
        if (Math.random() < pChance) spawnPowerup();
        powerupSpawnTimer = 0;
      }

      powerups.forEach((p, index) => {
        p.life -= deltaTime;
        if (p.life <= 0) {
          powerups.splice(index, 1);
          return;
        }
        const dist = Math.hypot(player.x - p.x, player.y - p.y);
        if (dist < player.radius + p.radius) {
          activatePowerup(p.type);
          createParticles(p.x, p.y, p.color, 10, 5);
          powerups.splice(index, 1);
        }
      });

      // Boss Logic
      if (!boss) {
          if (bossMode === 'score') {
              // Phase 1: Spawn at 5000 score (or configured initial score)
              if (score >= bossSpawnThreshold) {
                  spawnBoss();
              }
          } else if (bossMode === 'kills') {
              // Phase 2: Spawn after X kills
              if (bossKillCounter >= bossSpawnThreshold) {
                  spawnBoss();
              }
          }
      }

      if (boss) {
        boss.timer += deltaTime;
        const centerX = canvas.width / 2;
        
        if (boss.blueprint) {
             // --- DNA ARCHITECTURE LOGIC ---
             if (boss.state === 'entering') {
                 // Run entrance logic
                 const maxDur = boss.blueprint.entrance.duration || 4000;
                 if (boss.timer < maxDur) {
                    const progress = boss.timer / maxDur;
                    if (boss.blueprint.entrance.update) boss.blueprint.entrance.update(boss, progress, canvas);
                    // Default safe centering if not handled
                    if (!boss.blueprint.entrance.customPos) { 
                        boss.y = -100 + (canvas.height * 0.25 + 100) * (1 - Math.pow(1 - progress, 3));
                    }
                 } else {
                     boss.state = 'idle';
                     boss.timer = 0;
                     player.isCinematic = false;
                     // Init battle props
                     boss.lastReverse = Date.now();
                 }
             } else if (boss.state === 'dying') {
                 boss.deathTimer = (boss.deathTimer || 0) + deltaTime;
                 const maxDur = boss.blueprint.death.duration || 4000;
                 
                 // Cinematic Safety
                 projectiles = []; 
                 player.invincibilityTimer = 100;

                 // Logic
                 if (boss.blueprint.death.update) boss.blueprint.death.update(boss, boss.deathTimer / maxDur, canvas);

                 if (boss.deathTimer > maxDur) {
                     finalizeBossDeath();
                 }
             } else {
                 // BATTLE LOGIC
                 boss.blueprint.update(boss, player, canvas, projectiles);
             }
        }
        
        // Critical Fix: Boss might have died in the logic above (finalizeBossDeath sets boss=null)
        // If so, skip collision check to avoid crash
        if (boss) {
             // Failsafe: If Boss has no blueprint (how?), kill it to prevent lock
             if (!boss.blueprint) {
                 console.error('Boss exists without blueprint. Forcing death.');
                 boss.hp = 0;
                 finalizeBossDeath();
                 return;
             }

            const dist = Math.hypot(player.x - boss.x, player.y - boss.y);
            // Ignore collision if boss is dying OR entering
            if (dist < player.radius + boss.radius && boss.state !== 'dying' && boss.state !== 'entering') {
          if (player.isDashing || isOverdriveActive) {
            Sound.bossHit();
            boss.hp -= isOverdriveActive ? 20 : 10; 
            uiBossHpFill.style.width = (boss.hp / boss.maxHp * 100) + '%';
            createParticles(boss.x, boss.y, '#f00', 10, 5);
            triggerShake(200, 5);
            
            if (!isOverdriveActive) {
              player.isDashing = false;
              player.dashCooldown = 500;
              const angle = Math.atan2(player.y - boss.y, player.x - boss.x);
              player.x += Math.cos(angle) * 50;
              player.y += Math.sin(angle) * 50;
            }
            
            spawnFloatingText(boss.x, boss.y, isOverdriveActive ? "20" : "10", "#fff", 25);

            if (boss.hp <= 0) {
               if (boss.blueprint && boss.blueprint.death) {
                   // Generic: Trigger Cinematic Death for ANY boss with a blueprint death sequence
                   boss.state = 'dying';
                   boss.deathTimer = 0;
               } else {
                   // Legacy Immediate Death
                   finalizeBossDeath();
               }
            }
          } else {
             if (player.shield) {
                player.shield = false;
                player.color = player.baseColor;
                createShockwave(player.x, player.y);
                updatePowerupUI();
                const angle = Math.atan2(player.y - boss.y, player.x - boss.x);
                player.x += Math.cos(angle) * 50;
                player.y += Math.sin(angle) * 50;
                player.invincibilityTimer = 1000;
             } else if (player.invincibilityTimer <= 0) {
                player.hp--;
                updateHpUI();
                player.invincibilityTimer = 2000;
                triggerShake(500, 10);
                spawnFloatingText(player.x, player.y, "-1 HP", "#f00", 30);
                createParticles(player.x, player.y, '#f00', 20, 5);
                
                const angle = Math.atan2(player.y - boss.y, player.x - boss.x);
                player.x += Math.cos(angle) * 80;
                player.y += Math.sin(angle) * 80;
                
                if (player.hp <= 0) gameOver();
             }
          }
        }
       } // Close the safety check 'if(boss)' added above
      }

      // Projectiles
      projectiles.forEach((p, index) => {
        
        if (p.type === 'wave') {
            p.waveTick = (p.waveTick || 0) + 1;
            
            // Move "Base" position (The imaginary straight line)
            p.baseX = (p.baseX === undefined) ? p.x : p.baseX + p.dx;
            p.baseY = (p.baseY === undefined) ? p.y : p.baseY + p.dy;
            
            // Calculate Wave Offset
            const angle = Math.atan2(p.dy, p.dx);
            const perpAngle = angle + Math.PI/2;
            
            // Increase amplitude over time for "conical" wave
            const offset = Math.sin(p.waveTick * 0.2) * 15;
            
            p.x = p.baseX + Math.cos(perpAngle) * offset;
            p.y = p.baseY + Math.sin(perpAngle) * offset;
        } else {
            p.x += p.dx;
            p.y += p.dy;
        }

        if (p.x < 0 || p.x > canvas.width || p.y < 0 || p.y > canvas.height) {
          projectiles.splice(index, 1);
          return;
        }

        const dist = Math.hypot(player.x - p.x, player.y - p.y);
        if (dist < player.radius + p.radius) {
          if (player.shield || isOverdriveActive) {
            if(!isOverdriveActive) {
              player.shield = false;
              player.color = player.baseColor;
              updatePowerupUI();
              player.invincibilityTimer = 1000;
            }
            createShockwave(player.x, player.y);
            projectiles.splice(index, 1);
          } else if (!player.isDashing) {
            if (player.invincibilityTimer <= 0) {
               player.hp--;
               updateHpUI();
               player.invincibilityTimer = 2000;
               triggerShake(300, 5);
               spawnFloatingText(player.x, player.y, "-1 HP", "#f00", 30);
               createParticles(player.x, player.y, '#f00', 10, 3);
               projectiles.splice(index, 1);
               if (player.hp <= 0) gameOver();
            }
          }
        }
      });

      // Enemies
      enemySpawnTimer += deltaTime;
      const settings = difficultySettings[difficulty];
      
      // Progressive difficulty: Start slow (2500ms), get faster with levels and time
      const initialSR = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.initialSpawnRate : 2500;
      const decreaseSR = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.spawnRateDecreasePerLevel : 200;
      const minSR = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.minSpawnRate : 250;

      // Time Multiplier: Decreases spawn rate by 5% every 30 seconds
      const timeFactor = Math.pow(0.95, Math.floor(survivalTime / 30000));
      let baseSpawnRate = (initialSR - (player.level * decreaseSR)) * timeFactor; 
      const spawnRate = Math.max(minSR, baseSpawnRate * settings.spawnRateMult);
      
      if (enemySpawnTimer > spawnRate) {
        spawnEnemy();
        enemySpawnTimer = 0;
      }

      enemies.forEach((e, index) => {
        const angle = Math.atan2(player.y - e.y, player.x - e.x);
        
        if (e.type === 'sniper') {
           const distToPlayer = Math.hypot(player.x - e.x, player.y - e.y);
           if (distToPlayer > 200) {
             e.x += Math.cos(angle) * e.speed * slowFactor;
             e.y += Math.sin(angle) * e.speed * slowFactor;
           } else if (distToPlayer < 150) {
             // Back away if too close
             e.x -= Math.cos(angle) * e.speed * slowFactor;
             e.y -= Math.sin(angle) * e.speed * slowFactor;
           }
           
           e.shootTimer += deltaTime;
           if (e.shootTimer > 2000) {
             e.shootTimer = 0;
             projectiles.push({
                x: e.x,
                y: e.y,
                dx: Math.cos(angle) * 6,
                dy: Math.sin(angle) * 6,
                radius: 4,
                color: '#fff'
             });
             Sound.playTone(300, 'sawtooth', 0.1);
           }
        } else {
           e.x += Math.cos(angle) * e.speed * slowFactor;
           e.y += Math.sin(angle) * e.speed * slowFactor;
        }

        const dist = Math.hypot(player.x - e.x, player.y - e.y);
        if (dist < player.radius + e.radius) {
          if (player.isDashing || isOverdriveActive) {
            Sound.hit();
            createParticles(e.x, e.y, e.color, 15, 6);
            createShockwave(e.x, e.y);
            triggerShake(100, 3);
            enemies.splice(index, 1);
            const settings = difficultySettings[difficulty];
            const baseKill = (gameConfig && gameConfig.gameplay) ? gameConfig.gameplay.baseKillScore : 5;
            const scoreGain = Math.floor(baseKill * combo * player.scoreMultiplier * settings.scoreMult);
            score += scoreGain;
            spawnFloatingText(e.x, e.y, "+" + scoreGain, "#fff", 15);
            uiScore.innerText = Loc.t('game.score') + ': ' + score;
          } else if (player.shield) {
            Sound.hit();
            player.shield = false;
            player.color = player.baseColor;
            createShockwave(player.x, player.y);
            createParticles(e.x, e.y, '#00f', 10, 5);
            enemies.splice(index, 1); 
            updatePowerupUI();
            triggerShake(200, 5);
            player.invincibilityTimer = 1000;
          } else {
            if (player.invincibilityTimer <= 0) {
               player.hp--;
               updateHpUI();
               player.invincibilityTimer = 2000;
               triggerShake(500, 10);
               spawnFloatingText(player.x, player.y, "-1 HP", "#f00", 30);
               createParticles(player.x, player.y, player.color, 20, 8);
               
               // Push enemies away
               enemies.forEach(en => {
                 const angle = Math.atan2(en.y - player.y, en.x - player.x);
                 en.x += Math.cos(angle) * 100;
                 en.y += Math.sin(angle) * 100;
               });
               
               if (player.hp <= 0) gameOver();
            }
          }
        }
      });

      // Particles
      particles.forEach((p, index) => {
        p.x += p.dx;
        p.y += p.dy;
        p.life -= 0.02;
        if (p.life <= 0) particles.splice(index, 1);
      });

      // Shockwaves
      shockwaves.forEach((s, index) => {
        s.radius += 2;
        s.alpha -= 0.05;
        if (s.alpha <= 0) shockwaves.splice(index, 1);
      });

      // Custom Explosions (Quantum / Sci-Fi)
      explosions.forEach((e, index) => {
          e.radius += (e.maxRadius - e.radius) * 0.1; // Ease out expansion
          e.alpha -= e.decay || 0.05;
          if (e.alpha <= 0) explosions.splice(index, 1);
      });
    }

    function draw() {
      // Screen Shake Transform
      ctx.save();
      if (shakeMagnitude > 0) {
        const dx = (Math.random() - 0.5) * shakeMagnitude;
        const dy = (Math.random() - 0.5) * shakeMagnitude;
        ctx.translate(dx, dy);
      }

      // Clear with trail effect
      ctx.fillStyle = 'rgba(5, 5, 5, 0.2)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);


      // Low HP Vignette
      if (player.hp <= 1) {
        const cx = canvas.width / 2;
        const cy = canvas.height / 2;
        // Dynamic sizing for any screen ratio
        const innerR = Math.min(canvas.width, canvas.height) * 0.25; // Adjusted inward
        const outerR = Math.max(canvas.width, canvas.height) * 0.8; // Brought outer edge closer

        const gradient = ctx.createRadialGradient(cx, cy, innerR, cx, cy, outerR);
        gradient.addColorStop(0, 'transparent');
        gradient.addColorStop(1, `rgba(255, 0, 0, ${0.4 + Math.sin(Date.now() * 0.01) * 0.1})`); // Slightly more intense
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }

      // Grid (Moving & Color Shift)
      const time = Date.now() * 0.001;
      ctx.strokeStyle = isOverdriveActive ? '#f0f' : (combo > 4 ? '#ff0' : '#111');
      ctx.lineWidth = 1;
      const offset = (time * 20) % 40;
      
      for(let i=0; i<canvas.width; i+=40) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
      }
      for(let i=0; i<canvas.height; i+=40) {
        ctx.beginPath(); ctx.moveTo(0, i + offset - 40); ctx.lineTo(canvas.width, i + offset - 40); ctx.stroke();
      }

      // Shockwaves
      shockwaves.forEach(s => {
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(255, 255, 255, ${s.alpha})`;
        ctx.lineWidth = 2;
        ctx.stroke();
      });

      // Custom Explosions
      explosions.forEach(e => {
         ctx.save();
         ctx.beginPath();
         ctx.arc(e.x, e.y, e.radius, 0, Math.PI * 2);
         ctx.strokeStyle = e.color || '#fff';
         ctx.lineWidth = e.width || 10;
         ctx.globalAlpha = Math.max(0, e.alpha);
         ctx.stroke();
         ctx.restore();
      });

      // Powerups
      powerups.forEach(p => {
        ctx.shadowBlur = 15;
        ctx.shadowColor = p.color;
        
        // Background Circle
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fill();
        
        // Inner detail
        ctx.strokeStyle = 'rgba(255,255,255,0.5)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius * 0.8, 0, Math.PI * 2);
        ctx.stroke();

        ctx.fillStyle = '#fff';
        ctx.font = 'bold 12px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        let icon = '?';
        if(p.type === 'shield') icon = '🛡️';
        if(p.type === 'slow') icon = '⏱️';
        if(p.type === 'magnet') icon = '🧲';
        if(p.type === 'nuke') icon = '☢️';
        if(p.type === 'heal') icon = '➕';
        
        ctx.fillText(icon, p.x, p.y);
        
        ctx.shadowBlur = 0;
      });

      // Boss
      if (boss) {
         let skipSprite = false;

         // --- BLUEPRINT VISUALS ---
         if (boss.blueprint) {
              // 1. Entrance
              if (boss.state === 'entering' && boss.blueprint.entrance && boss.blueprint.entrance.draw) {
                  const p = Math.min(1, boss.timer / boss.blueprint.entrance.duration);
                  boss.blueprint.entrance.draw(ctx, boss, p, canvas);
                  skipSprite = true; // Use only the blueprint animation
              }
              // 2. Dying
              else if (boss.state === 'dying' && boss.blueprint.death && boss.blueprint.death.draw) {
                  const maxDur = boss.blueprint.death.duration || 4000;
                  const p = Math.min(1, (boss.deathTimer||0) / maxDur);
                  boss.blueprint.death.draw(ctx, boss, p, canvas);
                  
                  // If replacing sprite, skip it immediately. 
                  // If not (Seraphim), keep sprite until p=0.4 (approx explosion time)
                  if (boss.blueprint.meta.replaceSprite) {
                      skipSprite = true;
                  } else {
                      if (p > 0.4) skipSprite = true; 
                  }
              }
              // 3. Normal State (Active Boss)
              else if (boss.state !== 'dying' && boss.state !== 'entering' && boss.blueprint.draw) {
                  // If JSON has a "draw" function, use it instead of sprites
                  boss.blueprint.draw(ctx, boss, canvas);
                  // Only skip sprite if the blueprint says so (defaults to true)
                  skipSprite = boss.blueprint.meta.replaceSprite; 
              }
         }

         // --- PERFORMANCE OPTIMIZATION: USE CACHED SPRITE ---
         // Only run this if we are NOT using a custom JSON draw function
         const spriteKey = boss.spriteKey || `boss-${boss.subType}-${boss.color}`;
         const sprite = SpriteCache[spriteKey];
         
         if (!skipSprite) {
             if (sprite) {
                 ctx.save();
                 ctx.translate(boss.x, boss.y);
                 
                 ctx.drawImage(sprite.image, -sprite.offset, -sprite.offset);
                 
                 // Dynamic effects that can't be cached (like pulsing glow)
    
                 ctx.restore();
             } else {
                 // Fallback if sprite missing (Should not happen if initialized correctly)
                ctx.shadowBlur = 20;
                ctx.shadowColor = boss.color;
                ctx.fillStyle = boss.color;
                ctx.beginPath();
                ctx.arc(boss.x, boss.y, boss.radius, 0, Math.PI * 2);
                ctx.fill();
             }
         }
         
         // --- BOSS HP GAUGE (INTEGRATED) ---
         if (boss.state !== 'dying' && boss.state !== 'entering' && boss.hp > 0) {
             const pct = Math.max(0, boss.hp / boss.maxHp);
             
             if (boss.blueprint && boss.blueprint.drawHp) {
                 boss.blueprint.drawHp(ctx, boss, pct);
             } else {
                 // Standard Floating Bar (Sleek)
                 const barW = 100;
                 const barH = 6;
                 const bx = boss.x - barW / 2;
                 const by = boss.y - boss.radius - 25;
                 
                 // Bg
                 ctx.fillStyle = 'rgba(0,0,0,0.5)';
                 ctx.fillRect(bx, by, barW, barH);
                 
                 // FG
                 ctx.fillStyle = boss.hp < boss.maxHp * 0.3 ? '#f00' : boss.color;
                 ctx.fillRect(bx, by, barW * pct, barH);
                 
                 // Border
                 ctx.strokeStyle = 'rgba(255,255,255,0.3)';
                 ctx.strokeRect(bx, by, barW, barH);
             }
         }
      }

      // Projectiles (Enemy/Boss)
      projectiles.forEach(p => {
        // --- PERFORMANCE OPTIMIZATION: USE CACHED SPRITE ---
        // New visuals were too heavy (laggy). Reverting to optimized sprite system.
        
        let blur = 10;
        // High intensity for boss projectiles
        if (p.damage > 1) blur = 15;
        
        const size = Math.round(p.radius);
        let color = p.color || '#f00';
        // Normalize color to match cache key format
        color = color.toLowerCase().trim();

        const style = p.style || 'circle';
        
        // Ensure sprite exists
        const key = `${color}-${size}-${blur}-${style}`;
        
        if (!SpriteCache[key]) {
            createNeonSprite(color, size, blur, style);
        }
        
        const sprite = SpriteCache[key];
        
        if (sprite) {
             if (p.angle !== undefined && style !== 'circle' && style !== 'orb') {
                 // Rotate sprite (Missiles, Bolts, etc)
                 // Note: Sprites are generated pointing UP (usually) or need to match angle
                 ctx.save();
                 ctx.translate(p.x, p.y);
                 // Adjust rotation: Standard sprites usually face UP (-90 deg from 0 rad).
                 // But most of my drawings in createNeonSprite face UP (center -> center-r).
                 // Math.atan2(dy, dx) gives 0 for RIGHT.
                 // So we need to add 90 deg (PI/2) to the rotation to align UP-facing sprite to RIGHT-facing angle?
                 // Wait: createNeonSprite nose is at (center, center - r). That is UP.
                 // Arc tangent 0 is RIGHT.
                 // So if projectile moves RIGHT (0 rad), we want sprite to rotate 90 deg (PI/2).
                 
                 ctx.rotate(p.angle + Math.PI / 2);
                 ctx.drawImage(sprite.image, -sprite.offset, -sprite.offset);
                 ctx.restore();
             } else {
                 ctx.drawImage(sprite.image, p.x - sprite.offset, p.y - sprite.offset);
             }
        } else {
             // Fallback
             ctx.shadowBlur = blur;
             ctx.shadowColor = color;
             ctx.fillStyle = color;
             ctx.beginPath();
             ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
             ctx.fill();
        }
      });

      // Player
      if (player.invincibilityTimer <= 0 || Math.floor(Date.now() / 100) % 2 === 0) {
        // --- PERFORMANCE OPTIMIZATION: USE CACHED SPRITE ---
        const blur = (player.isDashing || isOverdriveActive) ? 25 : 15;
        // Determine color based on state (same logic as old code)
        let color = player.color;
        if (isOverdriveActive) color = '#fff';
        else if (player.isDashing) color = '#fff';
        
        // We need to ensure these specific sprites exist in cache
        // If not, create them on the fly (lazy loading)
        const size = Math.round(player.radius);
        // Normalize color for cache key
        const cacheColor = color.toLowerCase().trim();
        const shape = player.shape || 'circle';
        const key = `${cacheColor}-${size}-${blur}-${shape}`;
        
        if (!SpriteCache[key]) {
            createNeonSprite(cacheColor, size, blur, shape);
        }
        
        const sprite = SpriteCache[key];
        if (sprite) {
             // Draw cached player
             ctx.drawImage(sprite.image, player.x - sprite.offset, player.y - sprite.offset);
        } else {
             // Fallback
             ctx.shadowBlur = blur;
             ctx.shadowColor = isOverdriveActive ? '#f0f' : (player.isDashing ? '#0ff' : player.color);
             ctx.fillStyle = color;
             ctx.beginPath();
             
             if (shape === 'square') {
                 // Tank Shape Fallback
                 const r = player.radius;
                 ctx.moveTo(player.x - r, player.y - r);
                 ctx.lineTo(player.x + r, player.y - r);
                 ctx.lineTo(player.x + r, player.y + r);
                 ctx.lineTo(player.x - r, player.y + r);
                 ctx.closePath();
                 ctx.rect(player.x - r/2, player.y - r*1.2, r, r*0.4);
             } else if (shape === 'triangle') {
                 // Speedster Shape Fallback
                 const r = player.radius * 1.3;
                 ctx.moveTo(player.x, player.y - r);
                 ctx.lineTo(player.x + r * 0.8, player.y + r);
                 ctx.lineTo(player.x, player.y + r * 0.5);
                 ctx.lineTo(player.x - r * 0.8, player.y + r);
                 ctx.closePath();
             } else {
                 // Default Fighter Shape Fallback
                 const r = player.radius;
                 ctx.moveTo(player.x, player.y - r);
                 ctx.lineTo(player.x + r, player.y + r);
                 ctx.lineTo(player.x, player.y);
                 ctx.lineTo(player.x - r, player.y + r);
                 ctx.closePath();
             }
             
             ctx.fill();
        }
        // ---------------------------------------------------
      }
      
      // Drones
      player.drones.forEach(d => {
        const dx = player.x + Math.cos(d.angle) * 30;
        const dy = player.y + Math.sin(d.angle) * 30;
        
        ctx.fillStyle = '#0ff';
        ctx.beginPath();
        ctx.arc(dx, dy, 5, 0, Math.PI * 2);
        ctx.fill();
        
        ctx.strokeStyle = 'rgba(0, 255, 255, 0.3)';
        ctx.beginPath();
        ctx.moveTo(player.x, player.y);
        ctx.lineTo(dx, dy);
        ctx.stroke();
      });

      // Friendly Projectiles
      friendlyProjectiles.forEach(p => {
        // --- PERFORMANCE OPTIMIZATION: USE CACHED SPRITE ---
        let scale = 1;
        if (p.isSpread) {
            scale = 0.8 + Math.sin(p.pulse) * 0.4; // Pulse effect for spread balls
            ctx.globalAlpha = 0.6 + Math.sin(p.pulse) * 0.4;
        }

        const size = Math.round(p.radius * scale);
        const key = `${p.color}-${size}-10`; // Standard blur
        const sprite = SpriteCache[key];

        if (sprite) {
            ctx.drawImage(sprite.image, p.x - sprite.offset, p.y - sprite.offset);
        } else {
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius * scale, 0, Math.PI * 2);
            ctx.fill();
        }
        ctx.globalAlpha = 1.0; 
        // ---------------------------------------------------
      });
      
      // Shield Visual
      if (player.shield) {
        ctx.strokeStyle = '#00f';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(player.x, player.y, player.radius + 5, 0, Math.PI * 2);
        ctx.stroke();
      }
      
      ctx.shadowBlur = 0;

      collectibles.forEach(c => {
        const scale = 1 + Math.sin(c.pulse) * 0.2;
        ctx.shadowBlur = 10;
        ctx.shadowColor = c.type === 'coin' ? '#ffd700' : (c.type === 'super' ? '#ffffff' : c.color);
        
        if (c.type === 'coin') {
            // Coin Drawing logic
            ctx.fillStyle = '#ffd700'; // Gold
            ctx.beginPath();
            ctx.arc(c.x, c.y, c.radius * scale, 0, Math.PI * 2);
            ctx.fill();
            
            // Inner circle for coin look
            ctx.strokeStyle = '#b8860b'; // Dark gold
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(c.x, c.y, c.radius * 0.7 * scale, 0, Math.PI * 2);
            ctx.stroke();
            
            // Symbol in coin center
            ctx.fillStyle = '#b8860b';
            ctx.font = `bold ${Math.floor(8 * scale)}px Arial`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('$', c.x, c.y);
            
        } else if (c.type === 'super') {
          ctx.fillStyle = '#e5e4e2'; // Silver Nova
          ctx.beginPath();
          ctx.arc(c.x, c.y, c.radius * scale, 0, Math.PI * 2);
          ctx.fill();
          
          // Outer glow for Nova effect
          ctx.strokeStyle = '#ffffff';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.arc(c.x, c.y, (c.radius + 2) * scale, 0, Math.PI * 2);
          ctx.stroke();
        } else if (c.type === 'heal') {
          // Heal Pack Drawing
          const r = c.radius * scale;
          ctx.fillStyle = '#ff0055'; // Neon Pink
          ctx.beginPath();
          ctx.rect(c.x - r, c.y - r, r * 2, r * 2);
          ctx.fill();
          
          // Cross Icon
          ctx.fillStyle = '#fff';
          ctx.fillRect(c.x - r * 0.6, c.y - r * 0.2, r * 1.2, r * 0.4);
          ctx.fillRect(c.x - r * 0.2, c.y - r * 0.6, r * 0.4, r * 1.2);
        } else {
          ctx.fillStyle = c.color;
          ctx.beginPath();
          ctx.rect(c.x - c.radius * scale, c.y - c.radius * scale, c.radius * 2 * scale, c.radius * 2 * scale);
          ctx.fill();
        }
        ctx.shadowBlur = 0;
      });

      // Enemies
      enemies.forEach(e => {
        // Calculate facing angle
        const angle = Math.atan2(player.y - e.y, player.x - e.x);

        let color = e.color || '#f00';
        color = color.toLowerCase().trim();
        const size = Math.round(e.radius);
        const blur = 10;
        // Determine style if not set (legacy support)
        let style = e.style;
        if (!style) {
             if (e.type === 'tank') style = 'bomber';
             else if (e.type === 'chaser') style = 'stealth';
             else style = 'interceptor';
        }

        const key = `${color}-${size}-${blur}-${style}`;
        
        // Ensure sprite exists
        if (!SpriteCache[key]) {
            createNeonSprite(color, size, blur, style);
        }
        
        const sprite = SpriteCache[key];
        
        if (sprite) {
             ctx.save();
             ctx.translate(e.x, e.y);
             // Rotate to face player
             // Sprite models usually point "Up". 
             // Canvas 0 radians = "Right". 
             // To point Up model to Right, we add 90 deg.
             ctx.rotate(angle + Math.PI / 2);
             ctx.drawImage(sprite.image, -sprite.offset, -sprite.offset);
             
             // Draw Health Bar for Tank/Heavy enemies
             if (e.type === 'tank') {
                 // Rotate back for UI elements to stay horizontal? 
                 // Actually health bar should probably rotate with ship or stay above it?
                 // Let's keep it simple and not draw HP bars yet as they clutter screen
             }
             
             ctx.restore();
        } else {
            // Fallback Rendering
            ctx.shadowBlur = 10;
            ctx.shadowColor = e.color;
            ctx.strokeStyle = e.color;
            ctx.lineWidth = 2;
            ctx.beginPath();
            if (e.type === 'tank') {
              ctx.rect(e.x - e.radius, e.y - e.radius, e.radius*2, e.radius*2);
            } else {
              ctx.arc(e.x, e.y, e.radius, 0, Math.PI * 2);
            }
            ctx.stroke();
            ctx.shadowBlur = 0;
        }
      });

      // Particles
      particles.forEach(p => {
        ctx.globalAlpha = p.life;
        
        // --- PERFORMANCE OPTIMIZATION: USE CACHED SPRITE ---
        // Try to find a matching sprite in cache
        // We use a standard blur of 10 for particles
        const size = Math.round(p.size || 2);
        // Explicitly append '-circle' to match the key format from createNeonSprite
        const key = `${p.color}-${size}-10-circle`;
        const sprite = SpriteCache[key];

        if (sprite) {
            // Draw the cached image (FAST)
            // We need to center it: x - offset, y - offset
            ctx.drawImage(sprite.image, p.x - sprite.offset, p.y - sprite.offset);
        } else {
            // Fallback to old method if not in cache (SLOW but SAFE)
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
            ctx.fill();
        }
        // ---------------------------------------------------
        
        ctx.globalAlpha = 1;
      });

      // Floating Texts
      floatingTexts.forEach(t => {
        ctx.globalAlpha = Math.max(0, t.life);
        ctx.fillStyle = t.color;
        ctx.font = 'bold ' + t.size + 'px monospace';
        ctx.textAlign = 'center';
        ctx.fillText(t.text, t.x, t.y);
        ctx.globalAlpha = 1;
      });

      ctx.restore(); // Restore from shake
    }

    function finalizeBossDeath() {
        createShockwave(boss.x, boss.y);
        createParticles(boss.x, boss.y, '#f00', 50, 10);
        
        // --- VICTORY REWARD ---
        // Restore HP or give over-shield
        if (player.hp < player.maxHp) {
            player.hp++;
            spawnFloatingText(player.x, player.y - 20, "REPAIRED", "#0f0", 20);
            updateHpUI();
        } else {
            // Score bonus for perfect health
            score += 1000;
            spawnFloatingText(player.x, player.y - 20, "PERFECT BONUS", "#ff0", 20);
        }
        // ----------------------
        
        const settings = difficultySettings[difficulty];
        const baseBossScore = (gameConfig && gameConfig.gameplay) ? (gameConfig.gameplay.baseKillScore * 25) : 500; // Scaled boss score
        const scoreGain = Math.floor(baseBossScore * player.scoreMultiplier * settings.scoreMult);
        score += scoreGain;
        spawnFloatingText(boss.x, boss.y, "+" + scoreGain, "#ff0", 40);
        uiScore.innerText = Loc.t('game.score') + ': ' + score;
        
        // --- BOSS DEATH & NEXT SPAWN LOGIC ---
        boss = null;
        uiBossHp.style.display = 'none';
        triggerShake(1000, 10);

        // Switch to Kills mode for subsequent bosses
        bossMode = 'kills'; 
        bossKillCounter = 0; // Reset counter
        bossLevel++; // Increase Boss Level for next spawn HP calc

        // Set next threshold loaded from config or default 100
        // FORCE TEST: Ignore DB config and set to 20 so user can see Void Harbinger quickly
        bossSpawnThreshold = 20; 
        console.log(`Next Boss Spawn Threshold set to FORCE TEST MODE: ${bossSpawnThreshold} kills`);
        // -------------------------------------
    }

    function animateGame(timestamp) {
      if (!gameRunning || gamePaused) return;
      const deltaTime = timestamp - lastTime;
      lastTime = timestamp;

      update(deltaTime);
      draw();
      
      // Update Debug Info HTML
      const debugDiv = document.getElementById('debug-info');
      if(debugDiv) {
          let equippedInfo = "None";
          if (typeof currentUser !== 'undefined' && currentUser && currentUser.inventory) {
             const ship = currentUser.inventory.find(s => s.isEquipped && s.item && s.item.type === 'ship');
             if(ship && ship.item) equippedInfo = `${ship.item.name} (${ship.item.color})`;
          }
          
          debugDiv.innerHTML = `FPS: ${Math.round(1000 / deltaTime)}<br>
                                Particles: ${particles.length}<br>
                                Cached Sprites: ${Object.keys(SpriteCache).length}<br>
                                Ship: ${equippedInfo}<br>
                                P.Color: ${player.color}<br>
                                Shape: ${player.shape}`;
      }

      animationId = requestAnimationFrame(animateGame);
    }

