    function toggleProfileEdit() {
        const viewMode = document.getElementById('profile-view-mode');
        const editMode = document.getElementById('profile-edit-mode');
        
        if (viewMode.classList.contains('hidden')) {
            viewMode.classList.remove('hidden');
            editMode.classList.add('hidden');
        } else {
            viewMode.classList.add('hidden');
            editMode.classList.remove('hidden');
        }
    }

    async function equipAvatar(itemId) {
        try {
            const res = await fetch('/api/user/equip-avatar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId })
            });
            const data = await res.json();
            
            if (data.success) {
                currentUser.avatar = data.avatar;
                showSystemAlert('Avatar Equipped!', 'SUCCESS');
                openProfile(); // Refresh to show checkmark
            } else {
                showSystemAlert(data.error, 'ERROR');
            }
        } catch (err) {
            console.error(err);
            showSystemAlert('Server Error', 'SYSTEM ERROR');
        }
    }

    async function saveProfileChanges() {
        const usernameInput = document.getElementById('edit-username');
        if (!usernameInput) return;
        
        const username = usernameInput.value;
        
        try {
            const res = await fetch('/api/user/update-profile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username })
            });
            const data = await res.json();
            
            if (data.success) {
                showSystemAlert('Username updated successfully!', 'SUCCESS');
                currentUser.username = data.user.username;
                currentUser.displayName = data.user.username;
                currentUser.usernameChangeCount = data.user.usernameChangeCount;
                openProfile(); // Refresh view
            } else {
                showSystemAlert(data.error, 'UPDATE FAILED');
            }
        } catch (err) {
            console.error(err);
            showSystemAlert('Server Error', 'SYSTEM ERROR');
        }
    }

    async function changePassword() {
        const currentPassword = document.getElementById('edit-current-pass').value;
        const newPassword = document.getElementById('edit-new-pass').value;
        
        if (!currentPassword || !newPassword) {
            showSystemAlert('Please fill in all password fields', 'VALIDATION ERROR');
            return;
        }

        try {
            const res = await fetch('/api/user/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword, newPassword })
            });
            const data = await res.json();
            
            if (data.success) {
                showSystemAlert('Password changed successfully!', 'SUCCESS');
                document.getElementById('edit-current-pass').value = '';
                document.getElementById('edit-new-pass').value = '';
            } else {
                showSystemAlert(data.error, 'CHANGE FAILED');
            }
        } catch (err) {
            console.error(err);
            showSystemAlert('Server Error', 'SYSTEM ERROR');
        }
    }

    // --- GUEST CONVERSION LOGIC ---
    function openConvertGuestModal() {
        if (!currentUser || !currentUser.isGuest) return;
        
        closeAllModals(); // Close profile modal first
        const modal = document.getElementById('convert-guest-modal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        
        // Pre-fill username if it's default guest name
        const usernameInput = document.getElementById('convert-username');
        if (currentUser.username.startsWith('GUEST_')) {
            usernameInput.value = '';
            usernameInput.placeholder = Loc.t('auth.username_hint') || "SELECT CODENAME...";
        } else {
            usernameInput.value = currentUser.username;
        }

        // Initialize CAPTCHA with a tiny delay to ensure layout is ready
        setTimeout(initConvertCaptcha, 50);
    }

    async function submitConvertGuest() {
        const username = document.getElementById('convert-username').value;
        const email = document.getElementById('convert-email').value;
        const password = document.getElementById('convert-password').value;
        const passwordConfirm = document.getElementById('convert-password-confirm').value;
        const agreeTerms = document.getElementById('convert-agree-terms').checked;
        
        // New fields
        const avatarColor = document.getElementById('convert-avatar-color').value;
        const countryCode = document.getElementById('convert-country-code').value;
        const captcha = document.getElementById('convert-captcha-val').value;
        const captchaAnswer = document.getElementById('convert-captcha-answer').value;
        const captchaTiming = document.getElementById('convert-captcha-timing').value;
        const captchaMovements = document.getElementById('convert-captcha-movements').value;

        if (!username || !email || !password) {
            showSystemAlert(Loc.t('auth.alert.all_fields') || 'Required fields: Codename, Email, Passkey', 'VALIDATION ERROR');
            return;
        }

        if (password !== passwordConfirm) {
            showSystemAlert(Loc.t('auth.alert.no_match') || 'Passwords do not match!', 'VALIDATION ERROR');
            return;
        }

        if (!agreeTerms) {
            showSystemAlert(Loc.t('auth.alert.terms') || 'You must accept the Pilot Code of Conduct!', 'VALIDATION ERROR');
            return;
        }

        if (!convertCaptchaData.success) {
            showSystemAlert(Loc.t('auth.alert.captcha') || 'Please complete security verification!', 'VALIDATION ERROR');
            return;
        }
        
        try {
            const res = await fetch('/api/user/convert-guest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    username, email, password, 
                    avatarColor, countryCode,
                    captcha, captchaAnswer, captchaTiming, captchaMovements
                })
            });
            const data = await res.json();
            
            if (data.success) {
                showSystemAlert('Identity Secured! Connection persistent.', 'SUCCESS');
                
                // Refresh page to update all EJS-rendered components and session state
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } else {
                showSystemAlert(data.error || 'Identity Link Failed', 'ERROR');
            }
        } catch (err) {
            console.error(err);
            showSystemAlert('Neural network error', 'SYSTEM ERROR');
        }
    }

    // --- TERMS LOGIC FOR GUEST CONVERSION ---
    function showTermsModal() {
        renderIndexDynamicTerms();
        const modal = document.getElementById('terms-modal');
        modal.style.display = 'flex';
        modal.classList.remove('hidden');
    }

    function acceptTermsAndClose() {
        const checkbox = document.getElementById('convert-agree-terms');
        if (checkbox) checkbox.checked = true;
        closeModal('terms');
    }

    function renderIndexDynamicTerms() {
        const container = document.getElementById('index-dynamic-terms');
        if (!container) return;
        
        container.innerHTML = '';
        let i = 1;
        
        const currentLang = Loc.currentLang;
        const dict = Loc.translations[currentLang] || {};
        
        while (dict[`auth.terms.h${i}`]) {
            const header = document.createElement('h3');
            header.style.color = 'var(--cyber-blue)';
            header.style.fontSize = '1.1rem';
            header.style.marginTop = '20px';
            header.style.marginBottom = '10px';
            header.innerText = dict[`auth.terms.h${i}`];
            
            const paragraph = document.createElement('p');
            paragraph.style.marginBottom = '15px';
            paragraph.innerText = dict[`auth.terms.p${i}`] || '';
            
            container.appendChild(header);
            container.appendChild(paragraph);
            i++;
        }
    }

    // --- CONVERT CAPTCHA SYSTEM (Direct copy from registration for consistency) ---
    let convertCaptchaData = {
        targetX: 0,
        pieceSize: 50,
        isDragging: false,
        startTime: 0,
        movements: 0,
        startX: 0,
        success: false
    };

    function initConvertCaptcha() {
        const canvas = document.getElementById('convertCaptchaCanvas');
        const pieceCanvas = document.getElementById('convertCaptchaPiece');
        const sliderButton = document.getElementById('convertSliderButton');
        const sliderProgress = document.getElementById('convertSliderProgress');
        const captchaStatus = document.getElementById('convertCaptchaStatus');

        if (!canvas) return;

        // Reset
        convertCaptchaData.success = false;
        convertCaptchaData.movements = 0;
        convertCaptchaData.startTime = Date.now();
        captchaStatus.textContent = '';
        captchaStatus.className = 'captcha-status';
        sliderButton.style.left = '0px';
        sliderButton.style.background = ''; // Reset success color
        sliderProgress.style.width = '0px';
        sliderProgress.style.background = ''; // Reset success gradient
        
        const ctx = canvas.getContext('2d');
        const pieceCtx = pieceCanvas.getContext('2d');
        
        // Random target position (avoid edges)
        convertCaptchaData.targetX = 50 + Math.random() * (canvas.width - convertCaptchaData.pieceSize - 100);
        
        // Draw background with cyber grid
        ctx.fillStyle = 'rgba(0, 10, 20, 0.9)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        // Grid pattern
        ctx.strokeStyle = 'rgba(0, 251, 255, 0.1)';
        ctx.lineWidth = 1;
        for(let i = 0; i < canvas.width; i += 20) {
            ctx.beginPath();
            ctx.moveTo(i, 0);
            ctx.lineTo(i, canvas.height);
            ctx.stroke();
        }
        for(let i = 0; i < canvas.height; i += 20) {
            ctx.beginPath();
            ctx.moveTo(0, i);
            ctx.lineTo(canvas.width, i);
            ctx.stroke();
        }
        
        // Draw target slot with glow
        const slotY = (canvas.height - convertCaptchaData.pieceSize) / 2;
        ctx.strokeStyle = '#00fbff';
        ctx.lineWidth = 2;
        ctx.shadowColor = '#00fbff';
        ctx.shadowBlur = 15;
        ctx.strokeRect(convertCaptchaData.targetX, slotY, convertCaptchaData.pieceSize, convertCaptchaData.pieceSize);
        ctx.shadowBlur = 0;
        
        // Draw puzzle piece on separate canvas
        pieceCanvas.width = convertCaptchaData.pieceSize + 10;
        pieceCanvas.height = convertCaptchaData.pieceSize + 10;
        pieceCanvas.style.position = 'absolute';
        pieceCanvas.style.top = slotY + 'px';
        pieceCanvas.style.left = '5px';
        pieceCanvas.style.zIndex = '10';
        
        // Draw piece with cyber style
        const gradient = pieceCtx.createLinearGradient(0, 0, convertCaptchaData.pieceSize, convertCaptchaData.pieceSize);
        gradient.addColorStop(0, '#00fbff');
        gradient.addColorStop(1, '#ff0055');
        
        pieceCtx.fillStyle = gradient;
        pieceCtx.strokeStyle = '#fff';
        pieceCtx.lineWidth = 2;
        pieceCtx.shadowColor = '#00fbff';
        pieceCtx.shadowBlur = 10;
        
        pieceCtx.beginPath();
        pieceCtx.moveTo(5, 5);
        pieceCtx.lineTo(convertCaptchaData.pieceSize, 5);
        pieceCtx.lineTo(convertCaptchaData.pieceSize, convertCaptchaData.pieceSize);
        pieceCtx.lineTo(5, convertCaptchaData.pieceSize);
        pieceCtx.closePath();
        pieceCtx.fill();
        pieceCtx.stroke();
        
        document.getElementById('convert-captcha-answer').value = Math.round(convertCaptchaData.targetX);
    }

    // Move events OUTSIDE to avoid multiple assignments and closure issues
    function startConvertDrag(e) {
        if (convertCaptchaData.success) return;
        if (e.type === 'mousedown' && e.button !== 0) return;
        
        const sliderButton = document.getElementById('convertSliderButton');
        if (!sliderButton) return;

        e.preventDefault();
        e.stopPropagation();
        
        convertCaptchaData.isDragging = true;
        convertCaptchaData.startTime = Date.now();
        convertCaptchaData.movements = 0;
        
        const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const buttonRect = sliderButton.getBoundingClientRect();
        convertCaptchaData.startX = clientX - buttonRect.left;
        
        sliderButton.style.cursor = 'grabbing';
    }

    function doConvertDrag(e) {
        if (!convertCaptchaData.isDragging) return;
        
        convertCaptchaData.movements++;
        const clientX = e.type.includes('touch') ? (e.touches[0] ? e.touches[0].clientX : 0) : e.clientX;
        
        const sliderButton = document.getElementById('convertSliderButton');
        const sliderTrack = sliderButton ? sliderButton.parentElement : null;
        if (!sliderButton || !sliderTrack) return;

        const maxMove = sliderTrack.offsetWidth - sliderButton.offsetWidth;
        
        let newX = clientX - sliderTrack.getBoundingClientRect().left - convertCaptchaData.startX;
        newX = Math.max(0, Math.min(newX, maxMove));
        
        const sliderProgress = document.getElementById('convertSliderProgress');
        const pieceCanvas = document.getElementById('convertCaptchaPiece');
        const canvas = document.getElementById('convertCaptchaCanvas');

        sliderButton.style.left = newX + 'px';
        if (sliderProgress) sliderProgress.style.width = newX + 'px';
        
        if (pieceCanvas && canvas && sliderTrack.offsetWidth > 0) {
            const canvasScale = canvas.width / sliderTrack.offsetWidth;
            const pieceX = newX * canvasScale;
            pieceCanvas.style.left = (5 + pieceX) + 'px';
        }
    }

    function endConvertDrag() {
        if (!convertCaptchaData.isDragging) return;
        convertCaptchaData.isDragging = false;
        
        const sliderButton = document.getElementById('convertSliderButton');
        if (sliderButton) sliderButton.style.cursor = 'grab';
        
        const canvas = document.getElementById('convertCaptchaCanvas');
        const sliderTrack = sliderButton ? sliderButton.parentElement : null;
        const captchaStatus = document.getElementById('convertCaptchaStatus');
        const sliderProgress = document.getElementById('convertSliderProgress');

        if (!canvas || !sliderTrack || !captchaStatus) return;

        const timeElapsed = (Date.now() - convertCaptchaData.startTime) / 1000;
        const sliderX = parseInt(sliderButton.style.left) || 0;
        const canvasScale = canvas.width / sliderTrack.offsetWidth;
        const actualX = Math.round(sliderX * canvasScale);
        const tolerance = 20;
        
        document.getElementById('convert-captcha-val').value = actualX;
        document.getElementById('convert-captcha-timing').value = timeElapsed.toFixed(2);
        document.getElementById('convert-captcha-movements').value = convertCaptchaData.movements;
        
        if (Math.abs(actualX - convertCaptchaData.targetX) <= tolerance) {
            if (timeElapsed < 0.2) {
                captchaStatus.textContent = Loc.t('auth.captcha.too_fast');
                captchaStatus.className = 'captcha-status error';
                setTimeout(initConvertCaptcha, 2000);
                return;
            }
            if (convertCaptchaData.movements < 2) {
                captchaStatus.textContent = Loc.t('auth.captcha.only_slide');
                captchaStatus.className = 'captcha-status error';
                setTimeout(initConvertCaptcha, 2000);
                return;
            }
            convertCaptchaData.success = true;
            captchaStatus.textContent = Loc.t('auth.captcha.success');
            captchaStatus.className = 'captcha-status success';
            sliderButton.style.background = 'linear-gradient(135deg, #00ff88, #00fbff)';
            if (sliderProgress) sliderProgress.style.background = 'linear-gradient(90deg, #00ff88, #00fbff)';
        } else {
            const diff = Math.abs(actualX - convertCaptchaData.targetX);
            captchaStatus.textContent = diff < 30 ? Loc.t('auth.captcha.almost') : Loc.t('auth.captcha.inside_box');
            captchaStatus.className = 'captcha-status error';
            setTimeout(initConvertCaptcha, 2000);
        }
    }

    // Initialize global listeners once
    document.addEventListener('DOMContentLoaded', () => {
        const sliderButton = document.getElementById('convertSliderButton');
        if (sliderButton) {
            sliderButton.addEventListener('mousedown', startConvertDrag);
            sliderButton.addEventListener('touchstart', startConvertDrag, { passive: false });
        }
        
        document.addEventListener('mousemove', doConvertDrag);
        document.addEventListener('touchmove', doConvertDrag, { passive: false });
        document.addEventListener('mouseup', endConvertDrag);
        document.addEventListener('touchend', endConvertDrag);
        
        const refreshBtn = document.getElementById('refreshConvertCaptcha');
        if (refreshBtn) refreshBtn.addEventListener('click', initConvertCaptcha);
    });

    // Auto-detect country on load
    async function detectCountry() {
        if (!currentUser || (currentUser.countryCode && currentUser.countryCode !== 'UN')) return;
        
        try {
            const res = await fetch('https://ipapi.co/json/');
            const data = await res.json();
            if (data.country_code) {
                const code = data.country_code.toLowerCase();
                // Update server
                await fetch('/api/user/update-country', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ countryCode: code })
                });
                currentUser.countryCode = code;
            }
        } catch (e) {
            console.log('Country detection failed', e);
        }
    }
    
    if (currentUser) detectCountry();

    // --- SYSTEM MODAL LOGIC ---
    let systemModalCallback = null;

    function showSystemAlert(message, title = 'SYSTEM ALERT') {
        const modal = document.getElementById('system-modal');
        document.getElementById('sys-modal-title').innerText = title;
        document.getElementById('sys-modal-msg').innerText = message;
        
        const actions = document.getElementById('sys-modal-actions');
        actions.innerHTML = `
            <button onclick="closeSystemModal()" class="cyber-btn" style="min-width: 100px;">OK</button>
        `;
        
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
    }

    function showSystemConfirm(message, onConfirm, title = 'CONFIRMATION REQUIRED') {
        const modal = document.getElementById('system-modal');
        document.getElementById('sys-modal-title').innerText = title;
        document.getElementById('sys-modal-msg').innerText = message;
        
        // Store callback globally (simple approach)
        systemModalCallback = onConfirm;
        
        const actions = document.getElementById('sys-modal-actions');
        actions.innerHTML = `
            <button onclick="closeSystemModal()" class="cyber-btn danger" style="min-width: 100px;">CANCEL</button>
            <button onclick="confirmSystemAction()" class="cyber-btn" style="min-width: 100px;">CONFIRM</button>
        `;
        
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
    }

    function confirmSystemAction() {
        if (systemModalCallback) systemModalCallback();
        closeSystemModal();
    }

    function closeSystemModal() {
        const modal = document.getElementById('system-modal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        systemModalCallback = null;
    }
  </script>
