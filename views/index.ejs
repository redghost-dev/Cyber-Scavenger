<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#050510">
  <title>Cyber Scavenger</title>
  
  <style>
    /* Instant CSS for Seamless Bridge */
    html, body { 
      background-color: #050510 !important; 
      margin: 0; 
      padding: 0; 
      overflow: hidden;
    }
    #cyber-intro {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background-color: #050510;
      z-index: 99999;
      display: flex; flex-direction: column; justify-content: center; align-items: center;
    }
  </style>

  <!-- Google Fonts: Orbitron -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/style.css?v=3.2">
  <link rel="stylesheet" href="/css/intro.css?v=3.2">
  <link rel="stylesheet" href="/css/dock.css?v=3.2">
  <link rel="stylesheet" href="/css/auth.css?v=3.2">
  <link rel="stylesheet" href="/css/main-menu.css?v=3.2">
  <link rel="stylesheet" href="/css/modals.css?v=3.2">
  <link rel="stylesheet" href="/css/settings.css?v=3.2">
    <link rel="stylesheet" href="/css/game-overlays.css?v=4.4">
  <link rel="stylesheet" href="/css/all.min.css?v=3.2">
  <script src="/js/localization.js"></script>
</head>
<body>
  <%- include('partials/intro') %>
  <%- include('partials/ux_effects') %>
  <!-- Landing Screen (Login) -->
  <div id="landing-screen" class="full-screen-overlay <%= user ? 'hidden' : '' %>">
      <!-- Tactical HUD Framework (Simplified here as it's now in partial) -->
      
      <div class="logo-container">
          <div class="logo-glitch" data-text="CYBER SCAVENGER">
              <div class="logo-title" data-i18n="app.title">CYBER<br>SCAVENGER</div>
          </div>
          <div class="logo-sub" data-i18n="app.deployment_protocol">DEPLOYMENT PROTOCOL 2.6.b</div>
      </div>
      
      <div class="auth-wrapper">
          <div class="auth-container">
              <a href="/auth/login" class="cyber-btn main-btn">
                  <span class="btn-glitch-bg"></span>
                  <i class="fas fa-sign-in-alt"></i> <span data-i18n="auth.login_title">SYSTEM LOGIN</span>
              </a>
              
              <a href="/auth/register" class="cyber-btn secondary main-btn">
                  <span class="btn-glitch-bg"></span>
                  <i class="fas fa-user-plus"></i> <span data-i18n="auth.register_title">NEW IDENTITY</span>
              </a>

              <button id="guest-login-btn" class="cyber-btn secondary main-btn guest-btn">
                  <span class="btn-glitch-bg"></span>
                  <span data-i18n="auth.guest_login">PLAY AS GUEST</span>
              </button>
          </div>
      </div>
      
      <div class="version-tag">
          <span data-i18n="app.version_prefix">v1.2.0</span> <span data-i18n="app.global_update">Global Update</span>
      </div>
  </div>

  <!-- Main Menu (Authenticated/Guest) -->
  <div id="main-menu" class="full-screen-overlay <%= user ? '' : 'hidden' %>">
      <!-- Settings Icon Removed -->

      <div class="logo-title main-menu-logo" data-i18n="app.title">CYBER<br>SCAVENGER</div>
      
      <div class="user-stats-panel">
          <% if (user) { %>
              <img id="main-menu-avatar" src="<%= user.avatar %>" class="main-menu-avatar">
              <div class="character-name"><%= user.displayName %></div>
              <div class="character-rank"><span data-i18n="profile.level">Level</span> <%= user.stats.level %> | <%= user.stats.leagueTier %></div>
              <div class="character-wallet" style="margin-top: 10px; display: flex; gap: 15px; justify-content: center; font-size: 0.9rem; color: #fff;">
                  <span><i class="fas fa-coins" style="color: #ffd700;"></i> <span id="user-coins" class="wallet-coins-val"><%= user.wallet.coins %></span></span>
                  <span><i class="fas fa-gem" style="color: #00f2ff;"></i> <span id="user-gems" class="wallet-gems-val"><%= user.wallet.gems %></span></span>
              </div>
          <% } else { %>
              <div id="guest-stats">
                  <div class="guest-avatar-icon"><i class="fas fa-user-secret"></i></div>
                  <div class="character-name" data-i18n="menu.guest_agent">GUEST AGENT</div>
                  <div class="character-rank" data-i18n="menu.local_profile">Local Profile</div>
                  <div class="character-wallet" style="margin-top: 10px; display: flex; gap: 15px; justify-content: center; font-size: 0.9rem; color: #fff;">
                      <span><i class="fas fa-coins" style="color: #ffd700;"></i> <span id="user-coins" class="wallet-coins-val">0</span></span>
                      <span><i class="fas fa-gem" style="color: #00f2ff;"></i> <span id="user-gems" class="wallet-gems-val">0</span></span>
                  </div>
              </div>
          <% } %>
      </div>
      
      <button id="start-game-btn" class="cyber-btn" style="margin-bottom: 80px;">
          <span data-i18n="menu.play">START MISSION</span>
      </button>
      
      <!-- Reward Button (Available for everyone) -->
      <button onclick="watchAdForCoins()" class="cyber-btn reward-btn" style="margin-bottom: 20px;">
          <i class="fas fa-play-circle"></i> <span data-i18n="menu.watch_ad">WATCH AD (+100 COINS)</span>
      </button>
      
      <% if (user && !user.isGuest) { %>
          <a href="/auth/logout" class="cyber-btn danger menu-nav-btn">
              <span data-i18n="menu.logout">LOGOUT</span>
          </a>
      <% } else if (user && user.isGuest) { %>
          <button id="guest-logout-btn" class="cyber-btn danger menu-nav-btn">
              <span data-i18n="menu.exit_guest">EXIT GUEST MODE</span>
          </button>
      <% } %>
  </div>

  <!-- Global Dock Menu -->
  <div id="global-dock-menu" class="dock-menu" style="display: none;">
      <div class="dock-item" onclick="goToHome()">
          <i class="fas fa-home"></i>
          <span data-i18n="menu.home">HOME</span>
      </div>
      <div class="dock-item" onclick="openShop()">
          <i class="fas fa-shopping-cart"></i>
          <span data-i18n="menu.shop">SHOP</span>
      </div>
      <div class="dock-item" onclick="openInventory()">
          <i class="fas fa-box-open"></i>
          <span data-i18n="menu.hangar">HANGAR</span>
      </div>
      <div class="dock-item play-btn" onclick="openPlayMenu()">
          <div class="play-icon-wrapper">
              <i class="fas fa-play"></i>
          </div>
          <span data-i18n="menu.play">PLAY</span>
      </div>
      <div class="dock-item" onclick="openLeaderboard()">
          <i class="fas fa-trophy"></i>
          <span data-i18n="menu.leaderboard">RANK</span>
      </div>
      <div class="dock-item" onclick="openSettings()">
          <i class="fas fa-cog"></i>
          <span data-i18n="menu.settings">CONFIG</span>
      </div>
      <% if (user) { %>
          <div class="dock-item" onclick="openProfile()">
              <img id="dock-profile-avatar" src="<%= user.avatar %>" style="width: 24px; height: 24px; border-radius: 50%; border: 1px solid var(--cyber-blue); box-shadow: 0 0 5px var(--cyber-blue);">
              <span data-i18n="menu.profile">PROFILE</span>
          </div>
      <% } else { %>
          <div class="dock-item" onclick="window.location.href='/auth/login'">
              <i class="fas fa-sign-in-alt" style="color: #aaa;"></i>
              <span data-i18n="auth.login_title">LOGIN</span>
          </div>
      <% } %>
  </div>
  <script>
    // Initial Visibility Check
    window.addEventListener('load', () => {
        const dock = document.getElementById('global-dock-menu');
        const mainMenu = document.getElementById('main-menu');
        if (dock && mainMenu && !mainMenu.classList.contains('hidden')) {
            dock.style.display = 'flex';
        }
    });
  </script>

  <!-- Start Screen (Moved outside game-wrapper for full screen experience) -->
  <div id="start-screen" class="full-screen-overlay hidden" style="z-index: var(--z-hud);">
       <h2 style="color: var(--cyber-blue); font-family: 'Courier New', monospace; margin-bottom: 25px; text-shadow: 0 0 15px var(--cyber-blue); letter-spacing: 3px; font-weight: 900;" data-i18n="start.title">MISSION CONFIG</h2>
       
       <!-- Difficulty Selection -->
       <div style="margin-bottom: 30px; text-align: center; width: 90%; max-width: 400px; background: var(--panel-bg); padding: 20px; border-radius: 12px; border: 1px solid rgba(0, 251, 255, 0.1);">
         <p style="color: rgba(255,255,255,0.6); margin-bottom: 15px; font-size: 0.8rem; letter-spacing: 2px;" data-i18n="start.difficulty">THREAT LEVEL:</p>
         <div style="display: flex; gap: 10px; justify-content: center;">
           <button id="btn-diff-easy" class="cyber-btn secondary small" onclick="setDifficulty('easy')" style="flex: 1; margin: 0; padding: 10px;" data-i18n="start.easy">LOW</button>
           <button id="btn-diff-medium" class="cyber-btn secondary small" onclick="setDifficulty('medium')" style="flex: 1; margin: 0; padding: 10px;" data-i18n="start.medium">MEDIUM</button>
           <button id="btn-diff-hard" class="cyber-btn secondary small" onclick="setDifficulty('hard')" style="flex: 1; margin: 0; padding: 10px;" data-i18n="start.hard">CRITICAL</button>
         </div>
       </div>

       <button onclick="startGame(true)" class="cyber-btn" style="margin-bottom: 15px;">
           <span data-i18n="start.launch">LAUNCH MISSION</span>
       </button>
       <button onclick="backToMainMenu()" class="cyber-btn danger small" style="width: auto; padding: 10px 30px;">
           <span data-i18n="start.abort">ABORT CONNECTION</span>
       </button>
  </div>

        <!-- Settings Modal -->
        <div id="settings-modal" class="hidden">
            <div class="settings-content cyber-panel">
                <h2 class="settings-header" data-i18n="settings.title">GAME SETTINGS</h2>
            
                <div class="settings-body">
                
                    <!-- Audio Settings -->
                    <div class="setting-row">
                        <span class="setting-label" data-i18n="settings.audio">AUDIO</span>
                        <div id="toggle-sound" class="setting-toggle active" onclick="toggleSetting('sound')">
                            <div class="setting-knob"></div>
                        </div>
                    </div>
                    
                    <div class="setting-row">
                        <span class="setting-label" data-i18n="settings.vibration">VIBRATION</span>
                        <div id="toggle-vibration" class="setting-toggle active" onclick="toggleSetting('vibration')">
                            <div class="setting-knob"></div>
                        </div>
                    </div>

                    <!-- Language Settings -->
                    <h3 class="settings-section-title" data-i18n="settings.language">LANGUAGE</h3>
                    <div class="settings-group">
                        <button class="cyber-btn small" onclick="Loc.setLanguage('en')" style="flex: 1; padding: 5px; font-size: 0.8rem; min-width: 0;">ENGLISH</button>
                        <button class="cyber-btn small" onclick="Loc.setLanguage('tr')" style="flex: 1; padding: 5px; font-size: 0.8rem; min-width: 0;">TÜRKÇE</button>
                        <button class="cyber-btn small" onclick="Loc.setLanguage('de')" style="flex: 1; padding: 5px; font-size: 0.8rem; min-width: 0;">DEUTSCH</button>
                    </div>

                    <h3 class="settings-section-title" data-i18n="settings.controls">CONTROLS</h3>
                    
                    <div class="settings-group">
                       <button id="btn-ctrl-keyboard" class="ctrl-btn" onclick="setControlMode('keyboard')" data-i18n="settings.keyboard">⌨️ KEYBOARD</button>
                       <button id="btn-ctrl-mouse" class="ctrl-btn" onclick="setControlMode('mouse')" data-i18n="settings.mouse">🖱️ MOUSE</button>
                       <button id="btn-ctrl-touch" class="ctrl-btn" onclick="setControlMode('touch')" data-i18n="settings.touch">📱 TOUCH</button>
                    </div>

                    <button onclick="startHUDEditor()" class="cyber-btn secondary" style="width: 100%; margin-bottom: 15px;">
                        <i class="fas fa-arrows-alt"></i> <span data-i18n="settings.edit_hud">EDIT TOUCH CONTROLS</span>
                    </button>
                    
                    <button onclick="resetHUDLayout()" class="cyber-btn danger" style="width: 100%; margin-bottom: 15px; font-size: 0.9rem;">
                        <span data-i18n="settings.reset">RESET TO DEFAULT</span>
                    </button>
                </div>
            </div>
        </div>
                </div>
            </div>
        </div>

        <!-- Shop Modal -->
        <div id="shop-modal" class="modal-overlay hidden">
            <div class="modal-content cyber-panel" style="width: 800px; max-width: 95vw; height: calc(100vh - 110px); display: flex; flex-direction: column; background: var(--panel-bg); border: 1px solid var(--cyber-blue); box-shadow: 0 0 25px rgba(0, 251, 255, 0.2);">
                <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; padding: 15px; border-bottom: 1px solid rgba(0, 251, 255, 0.2); background: rgba(0, 20, 40, 0.6);">
                    <div class="header-left" style="display: flex; align-items: center; gap: 15px;">
                        <h2 class="neon-text" style="margin: 0; color: var(--cyber-blue); text-shadow: 0 0 10px var(--cyber-blue); font-size: 1.5rem;" data-i18n="menu.shop">CYBER ARMORY</h2>
                    </div>
                    <div class="header-right" style="display: flex; align-items: center; gap: 10px;">
                        <div class="wallet-display" style="display: flex; gap: 10px; background: rgba(0,0,0,0.6); padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(0, 251, 255, 0.2); font-size: 0.85rem; font-weight: bold;">
                            <div class="currency" style="display: flex; align-items: center; gap: 5px; color: #ffd700;">
                                <i class="fas fa-coins"></i> <span id="shop-wallet-coins" class="wallet-coins-val">0</span>
                            </div>
                            <div class="currency" style="display: flex; align-items: center; gap: 5px; color: var(--cyber-blue);">
                                <i class="fas fa-gem"></i> <span id="shop-wallet-gems" class="wallet-gems-val">0</span>
                            </div>
                        </div>
                        <button onclick="closeModal('shop')" class="close-btn" style="background: none; border: none; color: #fff; font-size: 1.2rem; cursor: pointer; padding: 5px; transition: 0.3s;"><i class="fas fa-times"></i></button>
                    </div>
                </div>
                
                <div class="inventory-tabs" style="display: flex; justify-content: center; gap: 5px; padding: 10px; flex-wrap: wrap;">
                    <button onclick="filterShop('ship')" class="tab-btn active" id="tab-ship" style="flex: 1; min-width: auto; padding: 8px 5px; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" data-i18n="shop.ships">SHIPS</button>
                    <button onclick="filterShop('weapon')" class="tab-btn" id="tab-weapon" style="flex: 1; min-width: auto; padding: 8px 5px; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" data-i18n="shop.weapons">WEAPONS</button>
                    <button onclick="filterShop('trail')" class="tab-btn" id="tab-trail" style="flex: 1; min-width: auto; padding: 8px 5px; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" data-i18n="shop.trails">TRAILS</button>
                    <button onclick="filterShop('powerup')" class="tab-btn" id="tab-powerup" style="flex: 1; min-width: auto; padding: 8px 5px; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" data-i18n="shop.powerups">POWERUPS</button>
                    <button onclick="filterShop('avatar')" class="tab-btn" id="tab-avatar" style="flex: 1; min-width: auto; padding: 8px 5px; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">AVATARS</button>
                </div>

                <div class="inventory-body" style="flex: 1; overflow-y: auto; padding: 20px 20px 120px 20px;">
                    <div id="shop-content" class="inventory-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 15px;">
                        <!-- Items injected via JS -->
                        <div style="grid-column: 1/-1; text-align: center; color: #aaa; padding: 50px;">
                            <i class="fas fa-circle-notch fa-spin fa-3x"></i><br><br>LOADING ARMORY DATA...
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leaderboard Modal -->
        <div id="leaderboard-modal" class="full-screen-overlay hidden" style="background: rgba(2, 5, 10, 0.9); z-index: var(--z-overlay); overflow: hidden; display: none; flex-direction: column; justify-content: flex-start; backdrop-filter: blur(10px);">
            
            <!-- STATIONARY HEADER (Top Part stays fixed) -->
            <div style="width: 100%; z-index: 30001; background: var(--panel-bg); backdrop-filter: blur(15px); border-bottom: 2px solid var(--cyber-blue); box-shadow: 0 10px 30px rgba(0,0,0,0.8); flex-shrink: 0;">
                <!-- Title Bar -->
                <div class="cyber-header" style="position: relative; padding: clamp(10px, 2vh, 15px) 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(0, 251, 255, 0.1);">
                    <div class="header-left" style="display: flex; align-items: center; gap: 15px;">
                        <div class="header-title">
                            <h1 style="margin: 0; font-size: clamp(1.2rem, 4vw, 1.8rem); color: #fff; font-family: 'Orbitron', sans-serif; letter-spacing: 2px; text-transform: uppercase;">ELITE <span style="color: var(--cyber-blue); text-shadow: 0 0 10px var(--cyber-blue);">RANKINGS</span></h1>
                            <p style="margin: 0; color: var(--cyber-blue); font-size: 0.6rem; letter-spacing: 3px; font-weight: bold; opacity: 0.8; text-transform: uppercase;">GLOBAL DATABASE ACCESS</p>
                        </div>
                    </div>
                    <div class="header-right">
                        <button onclick="closeModal('leaderboard')" class="cyber-btn secondary small" style="width: auto; padding: 8px 15px; margin: 0; border-radius: 4px;">
                            <i class="fas fa-times" style="font-size: 1.2rem;"></i>
                        </button>
                    </div>
                </div>
                
                <!-- Nav Buttons inside Header Area -->
                <div style="width: 100%; max-width: 800px; margin: 0 auto; padding: 10px 15px 15px 15px;">
                    <div style="display: flex; justify-content: center; gap: 12px; background: rgba(0,0,0,0.6); padding: 8px; border-radius: 8px; border: 1px solid rgba(0,251,255,0.2); box-shadow: 0 0 20px rgba(0,0,0,0.5);">
                        <button onclick="loadLeaderboard('global')" id="btn-lb-global" class="cyber-btn small active" style="flex: 1; font-size: 0.7rem; letter-spacing: 1.5px; font-family: 'Orbitron', sans-serif; height: 45px; display: flex; align-items: center; justify-content: center; margin: 0;">GLOBAL NETWORK</button>
                        <button onclick="loadLeaderboard('league')" id="btn-lb-league" class="cyber-btn small" style="flex: 1; font-size: 0.7rem; letter-spacing: 1.5px; font-family: 'Orbitron', sans-serif; height: 45px; display: flex; align-items: center; justify-content: center; margin: 0;">LOCAL LEAGUE</button>
                    </div>
                </div>
            </div>

            <!-- SCROLLABLE CONTENT AREA -->
            <div style="flex: 1; overflow-y: auto; width: 100%; scroll-behavior: smooth;">
                <div style="width: 100%; max-width: 800px; margin: 0 auto; padding: 25px 15px 150px 15px;">
                    <div id="leaderboard-content" style="display: flex; flex-direction: column; gap: 12px;">
                        <!-- Rows injected via JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Profile Modal -->
        <div id="profile-modal" class="full-screen-overlay hidden" style="background: var(--bg-darker); z-index: 30000; overflow-y: auto; display: none; flex-direction: column; justify-content: flex-start; padding-top: 80px; backdrop-filter: blur(15px);">
            <div class="cyber-header" style="position: fixed; top: 0; left: 0; width: 100%; z-index: 30001; background: rgba(10, 15, 28, 0.95); padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); box-shadow: 0 5px 20px rgba(0,0,0,0.8);">
                <div class="header-left" style="display: flex; align-items: center; gap: 15px;">
                    <div class="header-title">
                        <h1 class="neon-text" style="margin: 0; font-size: 1.8rem; color: #fff; font-style: italic;">
                            <span data-i18n="profile.title_prefix">AGENT</span> 
                            <span style="color: var(--cyber-blue);" data-i18n="profile.title_suffix">PROFILE</span>
                        </h1>
                        <p style="margin: 0; color: var(--cyber-blue); font-size: 0.7rem; letter-spacing: 2px;" data-i18n="profile.subtitle">IDENTITY RECORD</p>
                    </div>
                </div>
                <div class="header-right">
                    <button onclick="closeModal('profile')" class="cyber-btn small" style="padding: 5px 15px; font-size: 0.8rem;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <div id="profile-content" style="width: 100%; max-width: 800px; margin: 0 auto; padding: 20px 20px 120px 20px;">
                <!-- Content injected via JS -->
            </div>
        </div>

        <!-- Convert Guest Modal -->
        <div id="convert-guest-modal" class="full-screen-overlay hidden" style="background: rgba(5, 10, 20, 0.95); z-index: 30010; overflow-y: auto; display: none; align-items: center; justify-content: flex-start; padding-top: 60px; padding-bottom: 140px; backdrop-filter: blur(20px);">
            <div class="cyber-panel" style="width: 90%; max-width: 450px; padding: 30px; border: 1px solid var(--cyber-blue); box-shadow: 0 0 30px rgba(0, 251, 255, 0.2); margin-bottom: 20px;">
                <div style="text-align: center; margin-bottom: 30px;">
                    <div style="font-size: 3rem; color: var(--cyber-blue); margin-bottom: 15px; filter: drop-shadow(0 0 10px var(--cyber-blue));">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <h2 class="neon-text" style="margin: 0; font-family: 'Orbitron', sans-serif;" data-i18n="auth.upgrade_title">PERMANENT IDENTITY</h2>
                    <p style="color: #888; font-size: 0.8rem; margin-top: 10px; letter-spacing: 1px;" data-i18n="auth.upgrade_desc">SECURE YOUR PROGRESS AND DATA CORES</p>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="color: var(--cyber-blue); font-size: 0.7rem; display: block; margin-bottom: 8px; font-weight: 900; text-transform: uppercase;" data-i18n="auth.username">AGENT CODENAME</label>
                    <input type="text" id="convert-username" data-i18n="auth.username" style="width: 100%; background: rgba(0,0,0,0.5); border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; font-family: monospace; outline: none;">
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="color: var(--cyber-blue); font-size: 0.7rem; display: block; margin-bottom: 8px; font-weight: 900; text-transform: uppercase;" data-i18n="auth.email">SECURE EMAIL</label>
                    <input type="email" id="convert-email" data-i18n="auth.email" style="width: 100%; background: rgba(0,0,0,0.5); border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; font-family: monospace; outline: none;">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="color: var(--cyber-blue); font-size: 0.7rem; display: block; margin-bottom: 8px; font-weight: 900; text-transform: uppercase;" data-i18n="auth.avatar_color">AVATAR THEME</label>
