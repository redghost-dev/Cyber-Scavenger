<!-- Cyber Scavenger: Neural Link Interface -->
<div id="cyber-intro">
    <div class="hud-layer">
        <div class="hud-circle"></div>
        <div class="hud-scanner"></div>
        <div class="hud-brackets"></div>
    </div>
    
    <div class="intro-content">
        <!-- Digital Noise Overlay -->
        <div class="noise-overlay"></div>

        <div class="system-header">
            <span class="header-tag">NEURAL_LINK_v2.0.4</span>
            <span class="header-tag right" id="current-timestamp">12:00:00</span>
        </div>

        <div class="intro-logo" data-text="CYBER SCAVENGER">CYBER<span>SCAVENGER</span></div>
        
        <div class="decryption-visual">
            <div id="hex-stream-left" class="hex-column"></div>
            <div class="core-node">
                <div class="node-rings">
                    <div class="ring r1"></div>
                    <div class="ring r2"></div>
                    <div class="ring r3"></div>
                </div>
                <div id="node-percent" class="node-value">0%</div>
            </div>
            <div id="hex-stream-right" class="hex-column"></div>
        </div>

        <div class="status-box">
            <div class="status-label">SYSTEM_STATUS:</div>
            <div id="intro-status-text" class="intro-status">CONNECTING...</div>
        </div>

        <div class="footer-data">
            <div class="data-group">
                <span>LAT: 41.0082</span>
                <span>LNG: 28.9784</span>
            </div>
            <div class="data-group">
                <span id="u-memory">MEM: 128TB</span>
                <span id="u-signal">SIG: 100%</span>
            </div>
        </div>
    </div>

    <div class="scanline"></div>
    <div class="crt-overlay"></div>
</div>
