<script>
    // Global control function to save performance during gameplay
    function toggleGlobalEffects(show) {
        const container = document.getElementById('global-ux-container');
        if (container) {
            container.style.display = show ? 'block' : 'none';
        }
        window._effectsEnabled = show;
    }

    (function() {
        let isPointerDown = false;
        window._effectsEnabled = true;

        // UI Elemanları: Bu öğelerin üzerinde efekt çalışmayacak
        const uiSelectors = [
            'button', 'input', 'textarea', 'select', 'a', 'label', 
            '.auth-container', '.modal-content', '.dock-menu', '.user-stats-panel', 
            '.cyber-btn', '.overlay-btn', '.inventory-container', '.shop-container', 
            '.card', '.form-group', '.alert', '.joystick-zone', '.control-zone',
            '.cyber-header', '.wallet-display', '.inventory-tabs', '.inventory-body',
            '.tab-btn', '.close-btn', '.dock-item', '.logo-container', '.stats-container',
            '.version-tag', '.hud-side-info'
        ].join(', ');

        function createDistortion(x, y, isTrail = false) {
            if (!window._effectsEnabled) return;
            
            const ripple = document.createElement('div');
            ripple.className = 'click-ripple';
            ripple.style.left = x + 'px';
            ripple.style.top = y + 'px';
            
            if (isTrail) {
                ripple.style.width = '60px'; // Matching the doc's trail size
                ripple.style.height = '60px';
                ripple.style.marginLeft = '-30px';
                ripple.style.marginTop = '-30px';
            }
            
            document.body.appendChild(ripple);
            setTimeout(() => ripple.remove(), 500);
        }

        window.addEventListener('pointerdown', (e) => {
            if (!window._effectsEnabled) return;
            
            // Sadece boş alanlarda çalışması için kontrol
            if (e.target.closest(uiSelectors)) {
                isPointerDown = false;
                return;
            }

            isPointerDown = true;
            createDistortion(e.clientX, e.clientY);
        }, { passive: true });

        window.addEventListener('pointermove', (e) => {
            if (!isPointerDown || !window._effectsEnabled) return;
            
            // UI üzerine girildiğinde iz bırakmayı durdur
            if (e.target.closest(uiSelectors)) return;

            createDistortion(e.clientX, e.clientY, true);
        }, { passive: true });

        window.addEventListener('pointerup', () => isPointerDown = false);
        window.addEventListener('pointercancel', () => isPointerDown = false);
    })();
</script>
