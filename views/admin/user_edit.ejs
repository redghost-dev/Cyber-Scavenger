<%- include('partials/header') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-user-edit me-2"></i><%= title %></h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/users">Kullanıcılar</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= targetUser.username %></li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card bg-dark text-white border-secondary mb-4">
            <div class="card-header border-secondary bg-transparent">
                <h5 class="mb-0">Genel Bilgiler ve İstatistikler</h5>
            </div>
            <div class="card-body">
                <form action="/admin/users/save" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="id" value="<%= targetUser._id %>">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Kullanıcı Adı</label>
                            <input type="text" class="form-control bg-dark text-white border-secondary" value="<%= targetUser.username %>" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-posta</label>
                            <input type="text" class="form-control bg-dark text-white border-secondary" value="<%= targetUser.email %>" readonly>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Rol</label>
                            <select name="role" class="form-select bg-dark text-white border-secondary">
                                <option value="user" <%= targetUser.role === 'user' ? 'selected' : '' %>>Kullanıcı</option>
                                <option value="admin" <%= targetUser.role === 'admin' ? 'selected' : '' %>>Yönetici</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Coin Miktarı</label>
                            <input type="number" name="coins" class="form-control bg-dark text-white border-secondary" value="<%= targetUser.wallet ? targetUser.wallet.coins : 0 %>">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Seviye (Level)</label>
                            <input type="number" name="level" class="form-control bg-dark text-white border-secondary" value="<%= targetUser.stats ? targetUser.stats.level : 1 %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tecrübe (XP)</label>
                            <input type="number" name="experience" class="form-control bg-dark text-white border-secondary" value="<%= targetUser.stats ? targetUser.stats.experience : 0 %>">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="/admin/users" class="btn btn-outline-secondary">İptal</a>
                        <button type="submit" class="btn btn-primary px-5">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Ban/Unban Card -->
        <div class="card bg-dark text-white border-danger mb-4">
            <div class="card-header border-danger bg-transparent">
                <h5 class="mb-0 text-danger">Hesap Durumu</h5>
            </div>
            <div class="card-body text-center">
                <p>Şu anki durum: 
                    <% if (targetUser.isBanned) { %>
                        <span class="badge bg-danger">YASAKLI</span>
                    <% } else { %>
                        <span class="badge bg-success">AKTİF</span>
                    <% } %>
                </p>
                <form action="/admin/users/ban/<%= targetUser._id %>" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn <%= targetUser.isBanned ? 'btn-success' : 'btn-danger' %> w-100">
                        <i class="fas <%= targetUser.isBanned ? 'fa-user-check' : 'fa-user-slash' %> me-1"></i>
                        <%= targetUser.isBanned ? 'Yasağı Kaldır' : 'Kullanıcıyı Yasakla' %>
                    </button>
                </form>
            </div>
        </div>

        <!-- Password Reset Card -->
        <div class="card bg-dark text-white border-warning mb-4">
            <div class="card-header border-warning bg-transparent">
                <h5 class="mb-0 text-warning">Şifre Sıfırla</h5>
            </div>
            <div class="card-body">
                <form action="/admin/users/reset-password/<%= targetUser._id %>" method="POST" onsubmit="return confirm('Şifreyi değiştirmek istediğinize emin misiniz?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label class="form-label">Yeni Şifre</label>
                        <input type="password" name="newPassword" class="form-control bg-dark text-white border-secondary" required minlength="6">
                    </div>
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="fas fa-key me-1"></i> Şifreyi Güncelle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>