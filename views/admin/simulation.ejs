<%- include('partials/header') %>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-primary bg-opacity-10 border-primary">
                <div class="card-body">
                    <h4 class="mb-1 text-primary-custom"><i class="fas fa-brain me-2"></i> Oyun Dengesi & Ekonomi Simülatörü</h4>
                    <p class="text-muted mb-0">Ayarları değiştirdikçe grafiklerin canlı olarak nasıl değiştiğini görün. Kaydetmeden önce dengeyi test edin.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Simulator Inputs (Floating Control Panel) -->
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-transparent border-secondary">
                    <h5 class="mb-0"><i class="fas fa-sliders-h me-2"></i> Simülasyon Parametreleri</h5>
                </div>
                <div class="card-body">
                    <form id="sim-form">
                        <div class="section-title small text-uppercase text-primary mb-3">Oynanış Dinamikleri</div>
                        <div class="mb-3">
                            <label class="form-label small">Başlangıç Spawn Hızı (ms)</label>
                            <input type="number" id="sim-initialSpawnRate" class="form-control" value="<%= config.gameplay.initialSpawnRate || 2500 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Level Başına Azalış (ms)</label>
                            <input type="number" id="sim-spawnRateDec" class="form-control" value="<%= config.gameplay.spawnRateDecreasePerLevel || 200 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Minimum Spawn Hızı (ms)</label>
                            <input type="number" id="sim-minSpawnRate" class="form-control" value="<%= config.gameplay.minSpawnRate || 400 %>">
                        </div>

                        <div class="section-title small text-uppercase text-warning mb-3 mt-4">Ekonomi Parametreleri</div>
                        <div class="mb-3">
                            <label class="form-label small">Coin Düşme Oranı (0-1 arası)</label>
                            <input type="number" step="0.01" id="sim-coinDropRate" class="form-control" value="<%= config.gameplay.coinDropRate || 0.1 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Coin Başına Kazanılan</label>
                            <input type="number" id="sim-coinsPerPickup" class="form-control" value="<%= config.gameplay.coinsPerPickup || 1 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Düşman Başına Puan</label>
                            <input type="number" id="sim-baseKill" class="form-control" value="<%= config.gameplay.baseKillScore || 20 %>">
                        </div>

                        <div class="section-title small text-uppercase text-danger mb-3 mt-4">Güçlendirme (Powerup)</div>
                        <div class="mb-3">
                            <label class="form-label small">Powerup Aralığı (ms)</label>
                            <input type="number" id="sim-pInterval" class="form-control" value="<%= config.gameplay.powerupSpawnInterval || 10000 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Powerup Şansı (0.5 = %50)</label>
                            <input type="number" step="0.1" id="sim-pChance" class="form-control" value="<%= config.gameplay.powerupChance || 0.5 %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">➕ Can (Heal) Oranı (0-1)</label>
                            <input type="number" step="0.05" id="sim-hRate" class="form-control" value="<%= config.gameplay.healDropRate || 0.25 %>">
                        </div>
                        
                        <div class="row g-2">
                           <div class="col-6 mb-2">
                               <label class="form-label small text-muted">🛡️ Kalkan W.</label>
                               <input type="number" step="0.1" id="sim-shieldWeight" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= config.gameplay.shieldWeight || 1.0 %>">
                           </div>
                           <div class="col-6 mb-2">
                               <label class="form-label small text-muted">⏱️ Yavaşlat W.</label>
                               <input type="number" step="0.1" id="sim-slowWeight" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= config.gameplay.slowWeight || 1.0 %>">
                           </div>
                           <div class="col-6 mb-2">
                               <label class="form-label small text-muted">🧲 Mıknatıs W.</label>
                               <input type="number" step="0.1" id="sim-magnetWeight" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= config.gameplay.magnetWeight || 1.0 %>">
                           </div>
                           <div class="col-6 mb-2">
                               <label class="form-label small text-muted">☢️ Nükleer W.</label>
                               <input type="number" step="0.1" id="sim-nukeWeight" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= config.gameplay.nukeWeight || 1.0 %>">
                           </div>
                        </div>
                        
                        <div class="mt-4">
                            <button type="button" onclick="resetSim()" class="btn btn-sm btn-outline-secondary w-100">Değerleri Sıfırla</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Simulation Stats -->
            <div class="card bg-dark border-secondary">
                <div class="card-body">
                    <h6 class="text-white border-bottom border-secondary pb-2 mb-3">Canlı Tahminler (Stats)</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Max Zorluğa Ulaşma:</span>
                        <span id="stat-max-difficulty" class="text-white small">-</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Tahmini Coin/Dakika:</span>
                        <span id="stat-coins-min" class="text-warning small">-</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Tahmini Puan/Dakika:</span>
                        <span id="stat-score-min" class="text-info small">-</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Tahmini Can Düşme (DK):</span>
                        <span id="stat-heal-min" class="text-success small">-</span>
                    </div>
                    <hr class="border-secondary">
                    <div class="text-center">
                        <small class="text-muted italic">*Bu değerler ortalama bir oyuncu performansı varsayılarak hesaplanır.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="row">
                <!-- Difficulty Curve Chart -->
                <div class="col-md-12 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-transparent border-secondary d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Zorluk Eğrisi (Zaman/Level vs Spawn Hızı)</h5>
                            <span class="badge bg-primary">Dinamik</span>
                        </div>
                        <div class="card-body">
                            <canvas id="difficultyChart" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Probabilities Chart -->
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-transparent border-secondary">
                            <h5 class="mb-0">Eşya Düşme Olasılıkları</h5>
                        </div>
                        <div class="card-body shadow-inner">
                            <canvas id="probabilityChart" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Powerup Distribution Chart -->
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-transparent border-secondary">
                            <h5 class="mb-0">Güçlendirici Dağılımı</h5>
                        </div>
                        <div class="card-body shadow-inner">
                            <canvas id="powerupChart" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Economy Chart (Cumulative Growth) -->
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-transparent border-secondary">
                            <h5 class="mb-0">Ekonomi Şişmesi (Enflasyon)</h5>
                        </div>
                        <div class="card-body shadow-inner">
                            <canvas id="economyChart" height="250"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    let difficultyChart, probabilityChart, economyChart, powerupChart;

    function initCharts() {
        const ctxDiff = document.getElementById('difficultyChart').getContext('2d');
        difficultyChart = new Chart(ctxDiff, {
            type: 'line',
            data: {
                labels: Array.from({length: 20}, (_, i) => 'Lvl ' + (i + 1)),
                datasets: [{
                    label: 'Düşman Spawn Aralığı (ms) - Ne kadar azsa o kadar zor',
                    borderColor: '#00ff9d',
                    backgroundColor: 'rgba(0, 255, 157, 0.1)',
                    data: [],
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { reverse: true, grid: { color: '#333' }, ticks: { color: '#aaa' } },
                    x: { grid: { color: '#333' }, ticks: { color: '#aaa' } }
                },
                plugins: { legend: { labels: { color: '#eee' } } }
            }
        });

        const ctxProb = document.getElementById('probabilityChart').getContext('2d');
        probabilityChart = new Chart(ctxProb, {
            type: 'doughnut',
            data: {
                labels: ['Normal Orb', 'Super Orb', 'Gold Coin'],
                datasets: [{
                    data: [],
                    backgroundColor: ['#00f2ff', '#e5e4e2', '#ffd700'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { color: '#eee' } }
                }
            }
        });

        const ctxPower = document.getElementById('powerupChart').getContext('2d');
        powerupChart = new Chart(ctxPower, {
            type: 'doughnut',
            data: {
                labels: ['➕ Can', '🛡️ Kalkan', '⏱️ Yavaşlat', '🧲 Mıknatıs', '☢️ Nükleer'],
                datasets: [{
                    data: [],
                    backgroundColor: ['#ff0055', '#0000ff', '#aa00ff', '#ffff00', '#ff0000'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { color: '#eee' } }
                }
            }
        });

        const ctxEconomy = document.getElementById('economyChart').getContext('2d');
        economyChart = new Chart(ctxEconomy, {
            type: 'bar',
            data: {
                labels: ['Lvl 1', 'Lvl 5', 'Lvl 10', 'Lvl 15', 'Lvl 20'],
                datasets: [
                    { label: 'Dakika Başına Coin', backgroundColor: '#ffd700', data: [] },
                    { label: 'Dakika Başına Puan (k)', backgroundColor: '#00ff9d', data: [] }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: { grid: { color: '#333' }, ticks: { color: '#aaa' } },
                    x: { grid: { color: '#333' }, ticks: { color: '#aaa' } }
                },
                plugins: { legend: { labels: { color: '#eee' } } }
            }
        });

        updateSimulation();
    }

    function updateSimulation() {
        const initialSR = parseInt(document.getElementById('sim-initialSpawnRate').value);
        const spawnRateDec = parseInt(document.getElementById('sim-spawnRateDec').value);
        const minSpawnRate = parseInt(document.getElementById('sim-minSpawnRate').value);
        const dropRate = parseFloat(document.getElementById('sim-coinDropRate').value);
        const coinsPerPickup = parseInt(document.getElementById('sim-coinsPerPickup').value);
        const baseKill = parseInt(document.getElementById('sim-baseKill').value);
        const pInterval = parseInt(document.getElementById('sim-pInterval').value);
        const pChance = parseFloat(document.getElementById('sim-pChance').value);
        const hRate = parseFloat(document.getElementById('sim-hRate').value);

        const sW = parseFloat(document.getElementById('sim-shieldWeight').value) || 1.0;
        const slW = parseFloat(document.getElementById('sim-slowWeight').value) || 1.0;
        const mW = parseFloat(document.getElementById('sim-magnetWeight').value) || 1.0;
        const nW = parseFloat(document.getElementById('sim-nukeWeight').value) || 1.0;

        // 1. Difficulty Curve
        const diffData = [];
        for (let l = 1; l <= 20; l++) {
            let sr = Math.max(minSpawnRate, initialSR - (l * spawnRateDec));
            diffData.push(sr);
        }
        difficultyChart.data.datasets[0].data = diffData;
        difficultyChart.update();

        // 2. Probabilities
        const coinProb = (dropRate * 0.5) * 100;
        const superProb = (dropRate * 0.5) * 100;
        const normalProb = (1 - dropRate) * 100;
        probabilityChart.data.datasets[0].data = [normalProb.toFixed(1), superProb.toFixed(1), coinProb.toFixed(1)];
        probabilityChart.update();

        // 2b. Powerup Probabilities
        const totalOtherWeights = sW + slW + mW + nW;
        const pHealReal = hRate * 100;
        const pShieldReal = ((1 - hRate) * (sW / totalOtherWeights)) * 100;
        const pSlowReal = ((1 - hRate) * (slW / totalOtherWeights)) * 100;
        const pMagnetReal = ((1 - hRate) * (mW / totalOtherWeights)) * 100;
        const pNukeReal = ((1 - hRate) * (nW / totalOtherWeights)) * 100;

        powerupChart.data.datasets[0].data = [
            pHealReal.toFixed(1),
            pShieldReal.toFixed(1),
            pSlowReal.toFixed(1),
            pMagnetReal.toFixed(1),
            pNukeReal.toFixed(1)
        ];
        powerupChart.update();

        // 3. Economy Projections
        const lvls = [1, 5, 10, 15, 20];
        const economyCoins = [];
        const economyScore = [];

        lvls.forEach(l => {
            let sr = Math.max(minSpawnRate, initialSR - (l * spawnRateDec));
            let killsPerMin = (60000 / sr) * 0.8; // Expecting player to kill 80% of spawns
            
            // Expected outcomes per min
            let coinsPerMin = killsPerMin * (dropRate * 0.5) * coinsPerPickup;
            let scorePerMin = (killsPerMin * baseKill) + (killsPerMin * (dropRate * 0.5) * 50); // simplified
            
            economyCoins.push(coinsPerMin.toFixed(0));
            economyScore.push((scorePerMin / 1000).toFixed(1));
        });

        economyChart.data.datasets[0].data = economyCoins;
        economyChart.data.datasets[1].data = economyScore;
        economyChart.update();

        // Update Stats
        const maxDiffLevel = Math.ceil((initialSR - minSpawnRate) / spawnRateDec);
        const healFreq = (60000 / pInterval) * pChance * hRate; 
        
        document.getElementById('stat-max-difficulty').innerText = 'Seviye ' + maxDiffLevel;
        document.getElementById('stat-coins-min').innerText = economyCoins[1] + ' - ' + economyCoins[4] + ' COIN';
        document.getElementById('stat-score-min').innerText = economyScore[1] + 'k - ' + economyScore[4] + 'k PUAN';
        document.getElementById('stat-heal-min').innerText = healFreq.toFixed(2) + ' Adet / Dk';
    }

    function resetSim() {
        document.getElementById('sim-form').reset();
        updateSimulation();
    }

    // Event listeners for live updates
    document.querySelectorAll('#sim-form input').forEach(input => {
        input.addEventListener('input', updateSimulation);
    });

    document.addEventListener('DOMContentLoaded', initCharts);
</script>

<style>
    .section-title {
        font-weight: 700;
        letter-spacing: 1px;
        border-bottom: 1px solid #333;
        padding-bottom: 5px;
    }
    .shadow-inner {
        box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        border-radius: 10px;
        padding: 15px;
    }
    .card {
        transition: all 0.2s ease;
    }
    .card:hover {
        border-color: #444;
    }
</style>

<%- include('partials/footer') %>
