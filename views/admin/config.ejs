                                </label>
                                <input type="number" name="gemsPerAd" class="form-control bg-dark border-secondary text-white" value="<%= config.ads.rewards.gemsPerAd %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">
                                    Günlük Reklam Limiti
                                    <i class="fas fa-info-circle ms-1 text-primary" data-bs-toggle="tooltip" title="Bir kullanıcı günde en fazla kaç tane ödüllü reklam izleyebilir?"></i>
                                </label>
                                <input type="number" name="dailyLimit" class="form-control bg-dark border-secondary text-white" value="<%= config.ads.rewards.dailyLimit %>">
