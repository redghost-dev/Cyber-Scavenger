        <div class="col-12 text-end mb-5">
            <hr class="border-secondary">
            <button type="submit" class="btn btn-primary px-5 py-2">
                <i class="fas fa-save me-2"></i> Ayarları Kaydet
            </button>
        </div>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })

        // --- DRAG AND DROP IMPLEMENTATION ---
        const container = document.getElementById('boss-list-container');
        let draggedItem = null;

        if (container) {
            // Event Delegation for Drag Start
            container.addEventListener('dragstart', function(e) {
                draggedItem = e.target.closest('.boss-card-item');
                if (draggedItem) {
                    draggedItem.style.opacity = '0.5';
                    e.dataTransfer.effectAllowed = 'move';
                    // Optional: Set a drag image
                }
            });

            container.addEventListener('dragend', function(e) {
                if (draggedItem) {
                    draggedItem.style.opacity = '1';
                    draggedItem = null;
                    reindexBosses(); // Update numbers after drop
                }
            });

            container.addEventListener('dragover', function(e) {
                e.preventDefault(); // Necessary to allow dropping
                e.dataTransfer.dropEffect = 'move';
                
                const target = e.target.closest('.boss-card-item');
                
                if (target && target !== draggedItem && container.contains(target)) {
                    const siblings = Array.from(container.querySelectorAll('.boss-card-item'));
                    const draggedIndex = siblings.indexOf(draggedItem);
                    const targetIndex = siblings.indexOf(target);

                    // Simple swap logic based on index comparison
                    // If moving forward in list (dragged < target), place after target
                    // If moving backward (dragged > target), place before target
                    // But in a grid, visual 'after' means next sibling.
                    
                    // To avoid flickering, we only swap if we are really 'over' it.
                    // Since it's a grid, just formatting it linearly works best.
                    
                    if (draggedIndex < targetIndex) {
                        target.after(draggedItem);
                    } else {
                        target.before(draggedItem);
                    }
                }
            });
        }
    });

    function reindexBosses() {
        const container = document.getElementById('boss-list-container');
        const newOrder = Array.from(container.children).filter(c => c.classList.contains('boss-card-item'));
        
        newOrder.forEach((item, newIndex) => {
            // Update Level Badge
            const badge = item.querySelector('.boss-level-badge');
            if(badge) badge.textContent = 'BÖLÜM ' + (newIndex + 1);

            // Update Input Names
            const inputs = item.querySelectorAll('input, select, textarea');
            inputs.forEach(input => {
                const name = input.getAttribute('name');
                if (name) {
                    // distinct regex to replace bosses[X] with bosses[newIndex]
                    const newName = name.replace(/bosses\[\d+\]/, `bosses[${newIndex}]`);
                    input.setAttribute('name', newName);
                }
            });
            
            // Start gradients update if SVGs exist (legacy support)
            const gradients = item.querySelectorAll('linearGradient, radialGradient, filter');
            gradients.forEach(g => {
                const id = g.id;
                if(id) {
                     const baseId = id.split('-')[0];
                     g.id = `${baseId}-${newIndex}`;
                }
            });
            
            // Update Fill URLs in SVGs 
            const fills = item.querySelectorAll('[fill^="url(#"]');
            fills.forEach(f => {
                 const val = f.getAttribute('fill');
                 const baseVal = val.split('-')[0]; // url(#hullGradient
                 f.setAttribute('fill', `${baseVal}-${newIndex})`);
            });
             const filters = item.querySelectorAll('[filter^="url(#"]');
            filters.forEach(f => {
                 const val = f.getAttribute('filter');
                 const baseVal = val.split('-')[0]; // url(#glow
                 f.setAttribute('filter', `${baseVal}-${newIndex})`);
            });
            
            // Update Canvas ID and script if present (New Renderer)
            const canvas = item.querySelector('canvas');
            if(canvas) {
                 canvas.id = `boss-preview-${newIndex}`;
            }
        });
    }
</script>

