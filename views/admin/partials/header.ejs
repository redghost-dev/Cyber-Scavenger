<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Siber Panel</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom Admin CSS -->
    <style>
        :root {
            --sidebar-width: 250px;
            --primary-color: #00ff9d;
            --dark-bg: #0a0a0a;
            --card-bg: #1a1a1a;
        }
        body {
            background-color: var(--dark-bg);
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background-color: #111;
            border-right: 1px solid #333;
            z-index: 1000;
            transition: all 0.3s;
        }
        .main-content {
            margin-left: var(--sidebar-width);
            padding: 20px;
            transition: all 0.3s;
        }
        .nav-link {
            color: #aaa;
            padding: 12px 20px;
            border-left: 3px solid transparent;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--primary-color);
            background-color: rgba(0, 255, 157, 0.05);
            border-left-color: var(--primary-color);
        }
        .nav-link i {
            width: 25px;
        }
        .card {
            background-color: var(--card-bg);
            border: 1px solid #333;
            color: #fff;
        }
        .stat-card {
            transition: transform 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .text-primary-custom {
            color: var(--primary-color) !important;
        }
        /* Fix for dark mode text visibility */
        .text-muted {
            color: #999 !important;
        }
        .form-label {
            color: #ddd !important;
        }
        .extra-small {
            font-size: 0.75rem;
        }
        .card-header h5, .card-header h6, .card-header h4 {
            color: #fff !important;
        }
        .card-body {
            color: #e0e0e0;
        }
        .table-dark {
            --bs-table-bg: transparent;
            --bs-table-color: #e0e0e0;
        }
        .form-control, .form-select {
            background-color: #222 !important;
            border-color: #444 !important;
            color: #fff !important;
        }
        .form-control::placeholder {
            color: #666 !important;
        }
        .form-control:focus, .form-select:focus {
            background-color: #111 !important;
            color: #fff !important;
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 0 0.25rem rgba(0, 255, 157, 0.1);
        }
        .input-group-text {
            background-color: #111;
            border-color: #333;
            color: #999;
        }
        /* Breadcrumb & Pagination Fixes */
        .breadcrumb-item + .breadcrumb-item::before {
            color: #666;
        }
        .breadcrumb-item.active {
            color: #999;
        }
        .breadcrumb-item a {
            color: var(--primary-color);
            text-decoration: none;
        }
        .pagination .page-link {
            background-color: #111;
            border-color: #333;
            color: #e0e0e0;
        }
        .pagination .page-item.disabled .page-link {
            background-color: #0a0a0a;
            color: #444;
        }
        /* Ensure all generic text is readable */
        p, span, div, label, td, th {
            color: inherit; /* Fallback to body color #e0e0e0 */
        }
        @media (max-width: 768px) {
            .sidebar {
                left: -var(--sidebar-width);
            }
            .sidebar.active {
                left: 0;
            }
            .main-content {
                margin-left: 0;
            }
            .main-content.active {
                margin-left: var(--sidebar-width);
            }
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="p-4 text-center border-bottom border-secondary">
            <h4 class="text-primary-custom mb-0">SİBER PANEL</h4>
            <small class="text-muted">Yönetim Sistemi</small>
        </div>
        <nav class="nav flex-column mt-3">
            <a class="nav-link <%= title === 'Yönetim Paneli' ? 'active' : '' %>" href="/admin">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a class="nav-link <%= title === 'Kullanıcı Yönetimi' ? 'active' : '' %>" href="/admin/users">
                <i class="fas fa-users"></i> Kullanıcılar
            </a>
            <a class="nav-link <%= title === 'Oyun Ayarları' ? 'active' : '' %>" href="/admin/config">
                <i class="fas fa-cogs"></i> Oyun Ayarları
            </a>
            <a class="nav-link <%= title === 'Boss Yönetimi' ? 'active' : '' %>" href="/admin/bosses">
                <i class="fas fa-skull-crossbones"></i> Boss Yönetimi
            </a>
            <a class="nav-link <%= title.includes('Simülatör') ? 'active' : '' %>" href="/admin/simulation">
                <i class="fas fa-chart-line"></i> Ekonomi Simülatörü
            </a>
            <a class="nav-link <%= title.includes('Market') || title.includes('Eşya') ? 'active' : '' %>" href="/admin/items">
                <i class="fas fa-shopping-cart"></i> Market
            </a>
            <a class="nav-link <%= title === 'Geri Bildirimler' ? 'active' : '' %>" href="/admin/feedbacks">
                <i class="fas fa-comment-dots"></i> Geri Bildirimler
            </a>
            <a class="nav-link <%= title === 'Hile Kayıtları' ? 'active' : '' %>" href="/admin/cheat-logs">
                <i class="fas fa-shield-alt"></i> Hile Kayıtları
            </a>
            <a class="nav-link <%= title.includes('Dil Çevirileri') || title.includes('Çeviri Düzenle') ? 'active' : '' %>" href="/admin/translations">
                <i class="fas fa-language"></i> Dil Çevirileri
            </a>
            <a class="nav-link <%= title === 'Kullanıcı Sözleşmesi' ? 'active' : '' %>" href="/admin/legal">
                <i class="fas fa-file-contract"></i> Kullanıcı Sözleşmesi
            </a>
            <a class="nav-link <%= title === 'İşlem Günlükleri' ? 'active' : '' %>" href="/admin/audit-logs">
                <i class="fas fa-history"></i> İşlem Günlükleri
            </a>
            <hr class="text-secondary mx-3">
            <a class="nav-link text-danger" href="/auth/logout">
                <i class="fas fa-sign-out-alt"></i> Çıkış Yap
            </a>
            <a class="nav-link mt-auto" href="/" target="_blank">
                <i class="fas fa-external-link-alt"></i> Oyuna Git
            </a>
        </nav>
    </div>

    <div class="main-content" id="content">
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent mb-4 border-bottom border-secondary pb-3">
            <div class="container-fluid">
                <button class="btn btn-outline-secondary d-md-none me-2" id="sidebarCollapse">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="mb-0"><%= title %></h5>
                <div class="ms-auto d-flex align-items-center">
                    <span class="text-muted me-3 small">Hoş geldin, <strong><%= user.username %></strong></span>
                    <img src="<%= user.avatar || '/img/default-avatar.svg' %>" class="rounded-circle" width="32" height="32">
                </div>
            </div>
        </nav>

        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success bg-success bg-opacity-10 border-success text-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i> <%= success_msg %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> <%= error_msg %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
