<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-transparent border-secondary">
                <h5 class="mb-0"><%= item ? 'Eşyayı Düzenle' : 'Yeni Eşya Ekle' %></h5>
            </div>
            <div class="card-body">
                <form action="/admin/items/save" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <% if (item) { %>
                        <input type="hidden" name="id" value="<%= item._id %>">
                    <% } %>

                    <div class="row g-3">
                        <div class="col-12 text-center mb-3">
                            <div id="item-preview-container" class="p-3 rounded bg-black border border-secondary d-inline-block" style="min-width: 100px; min-height: 100px; display: flex; align-items: center; justify-content: center;">
                                <!-- Preview will be rendered here -->
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Eşya Adı</label>
                            <input type="text" name="name" class="form-control bg-dark border-secondary text-white" value="<%= item ? item.name : '' %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Eşya Türü</label>
                            <select name="type" class="form-select bg-dark border-secondary text-white" required>
                                <option value="ship" <%= item && item.type === 'ship' ? 'selected' : '' %>>Gemi (Ship)</option>
                                <option value="skin" <%= item && item.type === 'skin' ? 'selected' : '' %>>Görünüm (Skin)</option>
                                <option value="trail" <%= item && item.type === 'trail' ? 'selected' : '' %>>İz (Trail)</option>
                                <option value="powerup" <%= item && item.type === 'powerup' ? 'selected' : '' %>>Güçlendirici (Powerup)</option>
                                <option value="weapon" <%= item && item.type === 'weapon' ? 'selected' : '' %>>Silah (Weapon)</option>
                                <option value="currency_pack" <%= item && item.type === 'currency_pack' ? 'selected' : '' %>>Para Paketi</option>
                                <option value="avatar" <%= item && item.type === 'avatar' ? 'selected' : '' %>>Avatar</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label text-muted small">Açıklama</label>
                            <textarea name="description" class="form-control bg-dark border-secondary text-white" rows="2"><%= item ? item.description : '' %></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted small">Fiyat</label>
                            <input type="number" name="price" class="form-control bg-dark border-secondary text-white" value="<%= item ? item.price : 0 %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small">Para Birimi</label>
                            <select name="currencyType" class="form-select bg-dark border-secondary text-white">
                                <option value="coin" <%= item && item.currencyType === 'coin' ? 'selected' : '' %>>Coin</option>
                                <option value="gem" <%= item && item.currencyType === 'gem' ? 'selected' : '' %>>Gem</option>
                                <option value="real_money" <%= item && item.currencyType === 'real_money' ? 'selected' : '' %>>Gerçek Para</option>
                            </select>
                        </div>

                        <div class="col-md-8">
                            <label class="form-label text-muted small">Resim URL</label>
                            <input type="text" name="imageUrl" class="form-control bg-dark border-secondary text-white" value="<%= item ? item.imageUrl : '/img/items/default.svg' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small">Renk (Hex)</label>
                            <input type="color" name="color" class="form-control form-control-color bg-dark border-secondary w-100" value="<%= item ? item.color : '#00ff9d' %>">
                        </div>

                        <div class="col-12">
                            <h6 class="mt-3 mb-2 text-primary border-bottom border-secondary pb-2">İstatistikler (Gemi/Güçlendirici/Silah için)</h6>
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <label class="form-label text-muted extra-small">Hız</label>
                                    <input type="number" step="0.1" name="speed" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= item && item.stats ? item.stats.speed : 0 %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted extra-small">Hasar</label>
                                    <input type="number" step="0.1" name="damage" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= item && item.stats ? item.stats.damage : 0 %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted extra-small">Can</label>
                                    <input type="number" step="0.1" name="health" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= item && item.stats ? item.stats.health : 0 %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted extra-small">Süre (sn)</label>
                                    <input type="number" step="0.1" name="duration" class="form-control form-control-sm bg-dark border-secondary text-white" value="<%= item && item.stats ? item.stats.duration : 0 %>">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" name="isPremium" id="isPremium" <%= item && item.isPremium ? 'checked' : '' %>>
                                <label class="form-check-label" for="isPremium">Premium Eşya</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" name="isActive" id="isActive" <%= item ? (item.isActive ? 'checked' : '') : 'checked' %>>
                                <label class="form-check-label" for="isActive">Aktif</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small">Sıralama</label>
                            <input type="number" name="order" class="form-control bg-dark border-secondary text-white" value="<%= item ? item.order : 0 %>">
                        </div>

                        <div class="col-12 text-end mt-4">
                            <a href="/admin/items" class="btn btn-outline-secondary me-2">İptal</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save me-2"></i> Kaydet
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small { font-size: 0.75rem; }
</style>

<%- include('partials/footer') %>

<script>
    function createNeonSprite(color, radius, blur = 10, shape = 'circle') {
        const c = document.createElement('canvas');
        const padding = blur * 2; 
        const size = (radius + padding) * 2;
        c.width = size;
        c.height = size;
        const ctx = c.getContext('2d');
        const center = size / 2;
        ctx.shadowBlur = blur;
        ctx.shadowColor = color;
        ctx.fillStyle = color;
        ctx.beginPath();
        
        if (shape === 'square') {
            const r = radius;
            ctx.moveTo(center - r, center - r);
            ctx.lineTo(center + r, center - r);
            ctx.lineTo(center + r, center + r);
            ctx.lineTo(center - r, center + r);
            ctx.closePath();
            ctx.rect(center - r/2, center - r*1.2, r, r*0.4);
        } else if (shape === 'triangle') {
            const r = radius * 1.3;
            ctx.moveTo(center, center - r);
            ctx.lineTo(center + r * 0.8, center + r);
            ctx.lineTo(center, center + r * 0.5);
            ctx.lineTo(center - r * 0.8, center + r);
            ctx.closePath();
        } else if (shape === 'interceptor') {
            const r = radius * 1.2;
            ctx.moveTo(center, center - r);
            ctx.lineTo(center + r * 0.4, center - r * 0.2);
            ctx.lineTo(center + r, center - r * 0.5);
            ctx.lineTo(center + r * 0.6, center + r);
            ctx.lineTo(center, center + r * 0.6);
            ctx.lineTo(center - r * 0.6, center + r);
            ctx.lineTo(center - r, center - r * 0.5);
            ctx.lineTo(center - r * 0.4, center - r * 0.2);
            ctx.closePath();
        } else {
            ctx.arc(center, center, radius, 0, Math.PI * 2);
        }
        ctx.fill();
        return c;
    }

    function updatePreview() {
        const container = document.getElementById('item-preview-container');
        const type = document.querySelector('select[name="type"]').value;
        const color = document.querySelector('input[name="color"]').value;
        const name = document.querySelector('input[name="name"]').value.toLowerCase();
        const imageUrl = document.querySelector('input[name="imageUrl"]').value;

        container.innerHTML = '';

        if (type === 'ship' || type === 'skin') {
            let shape = 'circle';
            if (name.includes('tank')) shape = 'square';
            else if (name.includes('speed')) shape = 'triangle';
            else if (name.includes('interceptor')) shape = 'interceptor';
            
            const canvas = createNeonSprite(color, 20, 10, shape);
            canvas.style.width = '80px';
            canvas.style.height = '80px';
            container.appendChild(canvas);
        } else if (type === 'trail') {
            container.innerHTML = `<div style="font-size: 50px; color: ${color}; text-shadow: 0 0 15px ${color};"><i class="fas fa-wind"></i></div>`;
        } else if (type === 'powerup') {
            let icon = 'fa-bolt';
            if (name.includes('magnet')) icon = 'fa-magnet';
            else if (name.includes('xp')) icon = 'fa-angle-double-up';
            else if (name.includes('health')) icon = 'fa-heart';
            container.innerHTML = `<div style="font-size: 50px; color: #ffd700; text-shadow: 0 0 15px #ffd700;"><i class="fas ${icon}"></i></div>`;
        } else if (imageUrl && imageUrl !== '/img/items/default.svg') {
            const img = document.createElement('img');
            img.src = imageUrl;
            img.style.maxWidth = '80px';
            img.style.maxHeight = '80px';
            img.className = 'rounded';
            container.appendChild(img);
        } else {
            container.innerHTML = `<div style="font-size: 50px; color: ${color};"><i class="fas fa-cube"></i></div>`;
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        updatePreview();
        
        // Add event listeners for real-time update
        document.querySelector('select[name="type"]').addEventListener('change', updatePreview);
        document.querySelector('input[name="color"]').addEventListener('input', updatePreview);
        document.querySelector('input[name="name"]').addEventListener('input', updatePreview);
        document.querySelector('input[name="imageUrl"]').addEventListener('input', updatePreview);
    });
</script>
