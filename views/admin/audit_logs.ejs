<%- include('partials/header') %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-history me-2"></i>İşlem Günlükleri (Audit Logs)</h1>
</div>

<div class="card bg-dark text-white border-secondary">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th>Admin</th>
                        <th>İşlem</th>
                        <th>Hedef Tür</th>
                        <th>Hedef ID</th>
                        <th>Detay</th>
                        <th>IP Adresi</th>
                        <th>Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr>
                                <td>
                                    <strong><%= log.admin ? log.admin.username : 'Bilinmeyen Admin' %></strong>
                                </td>
                                <td>
                                    <span class="badge <%= log.action.startsWith('DELETE') ? 'bg-danger' : (log.action.startsWith('CREATE') ? 'bg-success' : 'bg-info') %>">
                                        <%= log.action %>
                                    </span>
                                </td>
                                <td><%= log.targetType %></td>
                                <td><small class="text-muted"><%= log.targetId %></small></td>
                                <td><%= log.details %></td>
                                <td><small><%= log.ipAddress %></small></td>
                                <td>
                                    <%= new Date(log.createdAt).toLocaleString('tr-TR') %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Henüz işlem kaydı bulunmuyor.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <% if (totalPages > 1) { %>
    <div class="card-footer bg-transparent border-secondary">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link bg-dark border-secondary text-white" href="/admin/audit-logs?page=<%= currentPage - 1 %>">Geri</a>
                </li>
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link <%= currentPage === i ? 'bg-primary border-primary' : 'bg-dark border-secondary text-white' %>" href="/admin/audit-logs?page=<%= i %>"><%= i %></a>
                    </li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link bg-dark border-secondary text-white" href="/admin/audit-logs?page=<%= currentPage + 1 %>">İleri</a>
                </li>
            </ul>
        </nav>
    </div>
    <% } %>
</div>

<%- include('partials/footer') %>